;;;;==========================================================================
;;;; defun tsp-zoom-to-right-half : 평면도 전용 화면 우측 정렬 줌
;;;;==========================================================================
(defun tsp-zoom-to-right-half (vertices / minX maxX minY maxY w h newMinX newMaxX newMinY newMaxY)
  (setq minX (apply 'min (mapcar 'car vertices)))
  (setq maxX (apply 'max (mapcar 'car vertices)))
  (setq minY (apply 'min (mapcar 'cadr vertices)))
  (setq maxY (apply 'max (mapcar 'cadr vertices)))
  (setq w (- maxX minX) h (- maxY minY))
  (setq minX (- minX (* w 0.3)) maxX (+ maxX (* w 0.3)))
  (setq minY (- minY (* h 0.3)) maxY (+ maxY (* h 0.3)))
  (setq w (- maxX minX) h (- maxY minY))
  ;; 평면도는 기본 비율(w) 적용
  (setq newMinX (- minX w))
  (setq newMaxX maxX)
  (setq newMinY minY)
  (setq newMaxY maxY)
  (command "_.ZOOM" "_W" (list newMinX newMinY) (list newMaxX newMaxY))
  (princ)
)


;;;;==========================================================================
;;;; defun tsp-zoom-legend : 범례 전용 화면 우측 정렬 줌
;;;;==========================================================================
(defun tsp-zoom-legend (vertices / minX maxX minY maxY w h newMinX newMaxX newMinY newMaxY)
  (setq minX (apply 'min (mapcar 'car vertices)))
  (setq maxX (apply 'max (mapcar 'car vertices)))
  (setq minY (apply 'min (mapcar 'cadr vertices)))
  (setq maxY (apply 'max (mapcar 'cadr vertices)))
  (setq w (- maxX minX) h (- maxY minY))
  (setq minX (- minX (* w 0.3)) maxX (+ maxX (* w 0.3)))
  (setq minY (- minY (* h 0.3)) maxY (+ maxY (* h 0.3)))
  (setq w (- maxX minX) h (- maxY minY))
  ;; 범례는 대화상자를 피하기 위해 1.6배(1.6*w) 적용
  (setq newMinX (- minX (* w 1.6)))
  (setq newMaxX maxX)
  (setq newMinY minY)
  (setq newMaxY maxY)
  (command "_.ZOOM" "_W" (list newMinX newMinY) (list newMaxX newMaxY))
  (princ)
)
;;; ==========================================================================
;;; 실시간 중첩 방지 작도 (Real-time Redraw with Clean-up)
;;; ==========================================================================
(if (not (boundp '*tsp-realtime-entities*)) (setq *tsp-realtime-entities* '()))


;;;;==========================================================================
;;;; defun tsp-redraw-realtime-plan : 실시간 작도 시 도면(DWG)에 영구 저장된 중간말뚝 삭제 기록 필터링 유지
;;;;==========================================================================
(defun tsp-redraw-realtime-plan (boundary-ent boundary-orient / next-ent ent-data blk-name layer-name pt is-deleted post-data)
  ;; [Phase 2] Dirty Flag 체크: 변경 사항이 없으면 무거운 작도 로직 건너뜀
  (if (and (boundp '*tsp-data-dirty*) (not *tsp-data-dirty*))
    (princ "\n[TSP] 변경된 내용이 없어 재작도를 생략합니다.")
    (progn
      ;; 설정창(다이얼로그) 세션 중에는 임시 데이터를 사용, 평상시엔 LDATA 영구 기록 사용
      (if *tsp-use-temp-posts*
        (progn
          (setq *tsp-deleted-post-points* *tsp-temp-deleted-posts*)
          (setq *tsp-added-post-points* *tsp-temp-added-posts*)
        )
        (progn
          (setq *tsp-deleted-post-points* (vlax-ldata-get "TSP_DICT" "DELETED_POSTS"))
          (if (not *tsp-deleted-post-points*) (setq *tsp-deleted-post-points* '()))
          (setq *tsp-added-post-points* (vlax-ldata-get "TSP_DICT" "ADDED_POSTS"))
          (if (not *tsp-added-post-points*) (setq *tsp-added-post-points* '()))
        )
      )
      ;; 1. ARX가 관리하는 객체(TSP_GRP_241 등)는 ARX가 자체 정리하므로 LISP 단에서 물리적 삭제(entdel)를 금지함!
      ;; *tsp-realtime-entities* 리스트는 연속 보강재 참조용으로만 리셋
      (setq *tsp-realtime-entities* '())
      
      ;; 현재 작업 중인 경계선(boundary-ent) 핸들을 추출
      (setq cur-boundary-handle (cdr (assoc 5 (entget boundary-ent))))
      
      ;; ARX 크래시 원인인 CONT_BRACE를 차단하기 위해 TSP_LISP_BRACE까지 모두 포함하여 검색
      (setq orphan-ss (ssget "X" '((-3 ("TSP_STRUT_SPEC,TSP_LISP_POST,TSP_LISP_BRACE")))))
      (if orphan-ss
        (progn
          (setq orphan-idx 0)
          (while (< orphan-idx (sslength orphan-ss))
            (setq orphan-ent (ssname orphan-ss orphan-idx))
            (setq xdata-strut (assoc -3 (entget orphan-ent '("TSP_STRUT_SPEC"))))
            (setq xdata-post (assoc -3 (entget orphan-ent '("TSP_LISP_POST"))))
            (setq xdata-brace (assoc -3 (entget orphan-ent '("TSP_LISP_BRACE"))))
            
            (if xdata-strut
              (progn
                (setq xdata (cdadr xdata-strut))
                ;; [레거시 호환] 과거에 TSP_STRUT_SPEC으로 잘못 저장되었던 옛날 보강재도 스캔하여 지움 (크래시 유발자 제거)
                (if (and (> (length xdata) 8) (= (cdr (nth 7 xdata)) "CONT_BRACE") (= (cdr (nth 8 xdata)) cur-boundary-handle))
                  (vl-catch-all-apply 'entdel (list orphan-ent))
                )
              )
            )
            (if xdata-post
              (progn
                (setq xdata (cdadr xdata-post))
                (if (= (cdr (nth 0 xdata)) "MANUAL_POST")
                  (vl-catch-all-apply 'entdel (list orphan-ent))
                )
              )
            )
            (if xdata-brace
              (progn
                (setq xdata (cdadr xdata-brace))
                ;; LISP 전용 APPID로 저장된 연속 보강재 삭제
                (if (and (> (length xdata) 8) (= (cdr (nth 7 xdata)) "CONT_BRACE") (= (cdr (nth 8 xdata)) cur-boundary-handle))
                  (vl-catch-all-apply 'entdel (list orphan-ent))
                )
              )
            )
            (setq orphan-idx (1+ orphan-idx))
          )
        )
       )

      ;; 2. 도면 새로 그리기 시작 지점 마킹
      (setq next-ent (entlast))
      (if next-ent
        (tsp-log "[Redraw] 작도 시작 전 (entlast) 기준점 확보 성공.")
        (tsp-log "[Redraw] 경고! 작도 시작 전 (entlast)가 nil입니다.")
      )
      
      ;; ==========================================================================
      ;; 3. 실제 작도 함수 호출
      ;; ==========================================================================
      ;; 데이터 무결성을 위해 원본 세그먼트 리스트 백업
      (setq original-segment-list *segment-list*)
      (setq temp-segment-list '())
      
      ;; 전체 데이터를 스캔하여 배열 버팀보의 보강재 옵션만 임시로 "0"(꺼짐)으로 변조
      (foreach seg *segment-list*
        (setq supp-list (tsp-sanitize-support-list (cdr (assoc 'SUPPORT-LIST seg))))
        (setq new-supp-list '())
        (if supp-list
          (foreach supp supp-list
            (if (wcmatch (car supp) "버팀보*")
              (progn
                (setq opt (if (> (length supp) 11) (nth 11 supp) nil))
                (if (and opt (= (nth 0 opt) "1"))
                  (progn
                    ;; 11번째 인덱스의 첫 번째 값("1")을 "0"으로 변경하여 하위 함수의 개별 작도 무력화
                    (setq new-opt (cons "0" (cdr opt)))
                    (setq i 0 new-supp '())
                    (foreach item supp
                      (if (= i 11)
                        (setq new-supp (cons new-opt new-supp))
                        (setq new-supp (cons item new-supp))
                      )
                      (setq i (1+ i))
                    )
                    (setq new-supp-list (cons (reverse new-supp) new-supp-list))
                  )
                  (setq new-supp-list (cons supp new-supp-list))
                )
              )
              (setq new-supp-list (cons supp new-supp-list))
            )
          )
        )
        (setq temp-segment-list (cons (subst (cons 'SUPPORT-LIST (reverse new-supp-list)) (assoc 'SUPPORT-LIST seg) seg) temp-segment-list))
      )
      
      ;; 임시 변조된 리스트를 전역 변수에 덮어씌워 일괄 작도 실행 (옛날 보강재는 그려지지 않음)
      (setq *segment-list* (reverse temp-segment-list))
      (tsp-log "[Redraw] ARX 함수 'create-hpile-set-on-boundary' 호출 직전")
      (vl-catch-all-apply 'create-hpile-set-on-boundary (list boundary-ent boundary-orient))
      (tsp-log "[Redraw] ARX 함수 'create-hpile-set-on-boundary' 무사 완료됨")
      
      ;; 작도가 끝나면 즉시 원본 리스트 복구 (엑셀 저장 등 데이터 무결성 보존)
      (setq *segment-list* original-segment-list)

      ;; [수동 추가] 3-1. 수동으로 추가된 중간말뚝 작도
      (if *tsp-added-post-points*
        (progn
          ;; [수정] ARX 크래시 방지 전용 APPID 사용
          (if (not (tblsearch "APPID" "TSP_LISP_POST")) (regapp "TSP_LISP_POST"))
          (foreach post-data *tsp-added-post-points*
            (setq y_scale (if (> (length post-data) 2) (nth 2 post-data) 1.0))
            (setq custom-h  (if (> (length post-data) 3) (nth 3 post-data) 300.0))
            (setq custom-b  (if (> (length post-data) 4) (nth 4 post-data) 300.0))
            (setq custom-tw (if (> (length post-data) 5) (nth 5 post-data) 10.0))
            (setq custom-tf (if (> (length post-data) 6) (nth 6 post-data) 15.0))
            
            (entmake (list '(0 . "INSERT") 
                           (cons 2 (create-post-pile-block custom-h custom-b custom-tw custom-tf)) 
                           (cons 8 "_중간말뚝(Post pile)") 
                           (cons 62 256) 
                           (cons 10 (car post-data)) 
                           '(41 . 1.0) (cons 42 y_scale) '(43 . 1.0) 
                           (cons 50 (cadr post-data))
                           (list -3 (list "TSP_LISP_POST" (cons 1000 "MANUAL_POST")))
                     ))
          )
        )
      )
      
      ;; 4. 방금 새로 생성된 객체를 추적 리스트에 담으면서 삭제된 말뚝 필터링
      (while (setq next-ent (entnext next-ent))
        (setq *tsp-realtime-entities* (cons next-ent *tsp-realtime-entities*))
        
        ;; [수동 삭제 영구 필터링 로직] 블랙리스트 좌표에 속한 객체는 화면에 보이기 전 강제 제거
        (if (and *tsp-deleted-post-points* (> (length *tsp-deleted-post-points*) 0))
          (progn
            (setq ent-data (entget next-ent))
            (if (= (cdr (assoc 0 ent-data)) "INSERT")
              (progn
                (setq layer-name (cdr (assoc 8 ent-data)))
                (setq blk-name (cdr (assoc 2 ent-data)))
                (if (and layer-name blk-name
                         (= (strcase layer-name) (strcase "_중간말뚝(Post pile)")) 
                         (wcmatch (strcase blk-name) "_POST_PILE*"))
                  (progn
                    (setq pt (cdr (assoc 10 ent-data)))
                    (setq pt (list (car pt) (cadr pt) 0.0))
                    (setq is-deleted nil)
                    (foreach del-pt *tsp-deleted-post-points*
                      (if (< (distance pt del-pt) 10.0)
                        (setq is-deleted T)
                      )
                    )
                    ;; [ARX 붕괴 완벽 차단] entdel 대신 객체 투명화(DXF 60) 부여
                    ;; 객체가 메모리에 살아있으므로 ARX 그룹 정리 시 튕기는 현상 원천 차단
                    (if is-deleted
                      (progn
                        (setq edata (entget next-ent))
                        (if (not (assoc 60 edata))
                          (entmod (append edata (list (cons 60 1))))
                          (entmod (subst (cons 60 1) (assoc 60 edata) edata))
                        )
                      )
                    )
                  )
                )
              )
            )
          )
        )
      )
      ;; [Phase 1] 루프 후 원위치 정렬 (삭제 객체 제외)
      (setq *tsp-realtime-entities* (reverse *tsp-realtime-entities*))
      (princ (strcat "\n[디버그: TSP] 루프 종료 후 최종 추적된 신규 객체 수: " (itoa (length *tsp-realtime-entities*))))
      
      ;; ==========================================================================
      ;; 5. 엑셀 불러오기 및 일괄 작도 시 연속 보강재 완벽 복원 로직 (XDATA 연동)
      ;; ==========================================================================
      (if (and (boundp '*segment-list*) *segment-list*)
        (foreach seg *segment-list*
          (setq support-list (cdr (assoc 'SUPPORT-LIST seg)))
          (if support-list
            (foreach support support-list
              (if (wcmatch (car support) "버팀보*")
                (progn
                  (setq s-brace-opt (if (> (length support) 11) (nth 11 support) nil))
                  (if (and s-brace-opt (= (nth 0 s-brace-opt) "1"))
                    (progn
                      (setq manual-pts (if (> (length support) 8) (nth 8 support) '()))
                      (if (and manual-pts (> (length manual-pts) 0))
                        (progn
                          (setq sec-str (if (> (length support) 6) (nth 6 support) ""))
                          (setq count-val (if (> (length support) 4) (nth 4 support) 1))
                          (setq is-double (if (>= count-val 2) T nil))
                          
                          ;; 3D 좌표 충돌(에러) 방지 및 진짜 pt1 추출 리스트
                          (setq strut-ang nil strut-len nil real-pts-list '())
                          
                          ;; manual-pts의 각 점마다 실제 도면에 그려진 버팀보의 진짜 pt1(안쪽 면)을 역추적
                          (foreach pt-raw manual-pts
                            (setq pt-base (list (car pt-raw) (cadr pt-raw) 0.0))
                            (setq matched-pt1 nil)
                            
                            (foreach ent *tsp-realtime-entities*
                              (if (not matched-pt1)
                                (progn
                                  (setq edata (if (entget ent) (entget ent '("TSP_STRUT_SPEC")) nil))
                                  (if (and edata (assoc -3 edata))
                                    (progn
                                      (setq xvals (cdr (car (cdr (assoc -3 edata)))))
                                      (if (and (> (length xvals) 7) (= (cdr (nth 7 xvals)) "MANUAL_STRUT"))
                                        (progn
                                          (setq pt1-raw (cdr (nth 2 xvals)) pt2-raw (cdr (nth 3 xvals)))
                                          (if (and pt1-raw pt2-raw)
                                            (progn
                                              (setq x-pt1 (list (car pt1-raw) (cadr pt1-raw) 0.0))
                                              (setq x-pt2 (list (car pt2-raw) (cadr pt2-raw) 0.0))
                                              (setq line-ang (angle x-pt1 x-pt2))
                                              
                                              ;; 수직 거리 매칭 (단차 무시, 동일 축 확인)
                                              (setq dist-to-line (abs (tsp-project-dist x-pt1 (+ line-ang (/ pi 2.0)) pt-base)))
                                              ;; 수평 거리 매칭 (동일 선상의 다른 버팀보와 구분, 오차 넉넉히 허용)
                                              (setq dist-along (tsp-project-dist x-pt1 line-ang pt-base))
                                              
                                              (if (and (< dist-to-line 10.0) (>= dist-along -1000.0) (<= dist-along (+ (distance x-pt1 x-pt2) 1000.0)))
                                                (progn
                                                  (setq matched-pt1 x-pt1) ;; 진짜 pt1 획득 성공!
                                                  (if (not strut-ang)
                                                    (progn
                                                      (setq strut-ang line-ang)
                                                      (setq strut-len (distance x-pt1 x-pt2))
                                                    )
                                                  )
                                                )
                                              )
                                            )
                                          )
                                        )
                                      )
                                    )
                                  )
                                )
                              )
                            )
                            (if matched-pt1 (setq real-pts-list (cons matched-pt1 real-pts-list)))
                          )
                          
                          (setq real-pts-list (reverse real-pts-list))
                          
                          ;; 진짜 pt1 좌표 리스트를 기반으로 연속 보강재 작도 실행
                          (if (and strut-ang strut-len (> (length real-pts-list) 0))
                            (progn
                              ;; 상위 루프에서 순회 중인 현재 세그먼트(seg)의 ID를 추출하여 전달
                              (setq current-seg-id (cdr (assoc 'ID seg)))
                              (setq batch-braces (vl-catch-all-apply 'tsp-draw-realtime-continuous-braces (list real-pts-list s-brace-opt sec-str is-double strut-ang strut-len current-seg-id)))
                              (if (and batch-braces (not (vl-catch-all-error-p batch-braces)))
                                ;; batch-braces 자체가 리스트이므로 append 사용
                                (setq *tsp-realtime-entities* (append *tsp-realtime-entities* batch-braces))
                              )
                            )
                          )
                        )
                      )
                    )
                  )
                )
              )
            )
          )
        )
      )
      (setq *tsp-data-dirty* nil)
    )
  )
)

;;;;==========================================================================
;;;; defun tsp-fix-mirrored-polyline : 경계선 Z축 양수화(OCS 좌표계 재조정)
;;;;==========================================================================
(defun tsp-fix-mirrored-polyline (ent / ent-data normal new-data item pt bulge)
  (setq ent-data (entget ent))
  (setq normal (cdr (assoc 210 ent-data)))
  (if (and normal (< (caddr normal) 0.0))
    (progn
      (princ "\n[시스템] OCS 좌표 및 Z축을 양수(+)로 자동 보정")
      (setq new-data '())
      (foreach item ent-data
        (cond
          ((= (car item) 10)
           (setq pt (cdr item))
           (setq new-data (append new-data (list (cons 10 (list (- (car pt)) (cadr pt))))))
          )
          ;; 곡선(Bulge) 부호 반전
          ((= (car item) 42)
           (setq bulge (cdr item))
           (setq new-data (append new-data (list (cons 42 (- bulge)))))
          )
          ;; Extrusion Direction (Z축) 정상화
          ((= (car item) 210)
           (setq new-data (append new-data (list (cons 210 '(0.0 0.0 1.0)))))
          )
          (t
           (setq new-data (append new-data (list item)))
          )
        )
      )
      ;; 객체 업데이트
      (entmod new-data)
      (entupd ent)
      T
    )
    nil
  )
)


