             (setq target-indices selected-indices)
             (set_tile \"status_msg\" (strcat \"[다중 복사 준비 완료] 복사해 올 '원본' 세그먼트 1개를 위 목록에서 클릭하세요.\")))
          "
        )
        (action_tile "btn_apply_all"
          "(progn
             (setq apply-all-mode T paste-mode nil apply-soil-mode nil apply-support-mode nil apply-wall-mode nil apply-brace-mode nil)
             (set_tile \"status_msg\" \"[전체 일괄적용] 원본 세그먼트를 클릭하세요. (취소: ESC)\"))")
        (action_tile "btn_apply_soil"
