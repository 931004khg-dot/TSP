;;;;==========================================================================
;;;; 디버깅 전용 실시간 파일 로그 출력 함수
;;;;==========================================================================
(defun tsp-log (msg / f path)
  (setq path "C:\\tsp_debug.log")
  (setq f (open path "a"))
  (if f
    (progn
      (write-line (strcat "[" (rtos (getvar "CDATE") 2 6) "] " msg) f)
      (close f)
    )
  )
  (princ (strcat "\n" msg))
  (princ)
)
