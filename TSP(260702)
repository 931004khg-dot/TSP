           )
          )
          ((= result 4)
           (setq extracted-n-vals (tsp-get-nvalue-from-drawing))
           (if extracted-n-vals
             (progn
               (setq temp-n-vals (append temp-n-vals extracted-n-vals))
               (setq temp-n-vals (vl-sort temp-n-vals '(lambda (a b) (< (car a) (car b)))))
             )
           )
          )
          ((= result 5)
           (if tsp-pause-for-measurement
             (tsp-pause-for-measurement)
             (alert "TSP - 도면 제어 모듈이 로드되지 않았습니다.")
           )
          )
          (t (setq loop-dcl nil))
        )
      )
      (setq loop-dcl nil)
    )
  )
  result
)


;;;;==========================================================================
;;;; defun hpile-dialog-callback : H-Pile 규격 설정 대화상자 콜백
;;;;==========================================================================
(defun hpile-dialog-callback (dcl-path / dcl-id result idx std-len val-h val-b val-tw val-tf)
  (setq dcl-id (load_dialog dcl-path))
  (if (new_dialog "tsp_hpile" dcl-id)
    (progn
      ;; 1. 규격 목록 정의 (전역 변수 사용 + User-defined 자동 추가)
      (start_list "hpile_spec")
      (mapcar 'add_list (append *tsp-std-wall-list* '("User-defined")))
      (end_list)
      (start_list "wale_spec")
      (mapcar 'add_list (append *tsp-std-wall-list* '("User-defined")))
      (end_list)
      ;; 표준 리스트 길이 (User-defined 판별용)
      (setq std-len (length *tsp-std-wall-list*))
      ;; 2. 초기값 설정 로직 (리스트에서 현재 값의 위치를 찾음)
      ;; [H-Pile 설정]
      (if (setq idx (vl-position *tsp-hpile-spec* *tsp-std-wall-list*))
        (set_tile "hpile_spec" (itoa idx))      ; 리스트에 있으면 해당 인덱스 선택
        (set_tile "hpile_spec" (itoa std-len))  ; 없으면 마지막(User-defined) 선택
      )
      ;; 사용자 정의 입력창 활성/비활성 상태 동기화
      (if (= (get_tile "hpile_spec") (itoa std-len))
        (progn
           (if *tsp-hpile-custom*
             (progn
               (set_tile "hpile_h" (itoa (nth 0 *tsp-hpile-custom*)))
               (set_tile "hpile_b" (itoa (nth 1 *tsp-hpile-custom*)))
               (set_tile "hpile_tw" (itoa (nth 2 *tsp-hpile-custom*)))
               (set_tile "hpile_tf" (itoa (nth 3 *tsp-hpile-custom*)))
             )
           )
           (mode_tile "hpile_h" 0) (mode_tile "hpile_b" 0) (mode_tile "hpile_tw" 0) (mode_tile "hpile_tf" 0)
        )
        (progn (mode_tile "hpile_h" 1) (mode_tile "hpile_b" 1) (mode_tile "hpile_tw" 1) (mode_tile "hpile_tf" 1))
      )
      ;; [Wale 설정]
      (if (setq idx (vl-position *tsp-wale-spec* *tsp-std-wall-list*))
        (set_tile "wale_spec" (itoa idx))
        (set_tile "wale_spec" (itoa std-len))
      )
      (if (= (get_tile "wale_spec") (itoa std-len))
        (progn
           (if *tsp-wale-custom*
             (progn
               (set_tile "wale_h" (itoa (nth 0 *tsp-wale-custom*)))
               (set_tile "wale_b" (itoa (nth 1 *tsp-wale-custom*)))
               (set_tile "wale_tw" (itoa (nth 2 *tsp-wale-custom*)))
               (set_tile "wale_tf" (itoa (nth 3 *tsp-wale-custom*)))
             )
           )
           (mode_tile "wale_h" 0) (mode_tile "wale_b" 0) (mode_tile "wale_tw" 0) (mode_tile "wale_tf" 0)
        )
        (progn (mode_tile "wale_h" 1) (mode_tile "wale_b" 1) (mode_tile "wale_tw" 1) (mode_tile "wale_tf" 1))
      )
      (set_tile "ctc" (rtos *tsp-ctc* 2 2))
      (set_tile "timber_thickness" (itoa *tsp-timber-thickness*))
      ;; 3. 액션 처리 (std-len 변수를 사용하여 동적으로 처리)
      (action_tile "hpile_spec" "(if (= (atoi $value) std-len) (progn (mode_tile \"hpile_h\" 0)(mode_tile \"hpile_b\" 0)(mode_tile \"hpile_tw\" 0)(mode_tile \"hpile_tf\" 0)) (progn (mode_tile \"hpile_h\" 1)(mode_tile \"hpile_b\" 1)(mode_tile \"hpile_tw\" 1)(mode_tile \"hpile_tf\" 1)))")
      (action_tile "wale_spec" "(if (= (atoi $value) std-len) (progn (mode_tile \"wale_h\" 0)(mode_tile \"wale_b\" 0)(mode_tile \"wale_tw\" 0)(mode_tile \"wale_tf\" 0)) (progn (mode_tile \"wale_h\" 1)(mode_tile \"wale_b\" 1)(mode_tile \"wale_tw\" 1)(mode_tile \"wale_tf\" 1)))")
      (action_tile "accept"
        "(progn
           (setq *tsp-wall-type* \"HPILE\")
           ;; H-Pile 저장
           (setq idx (atoi (get_tile \"hpile_spec\")))
           (if (< idx std-len)
             (setq *tsp-hpile-spec* (nth idx *tsp-std-wall-list*)) ;; 리스트에서 선택
             (setq *tsp-hpile-spec* \"User-defined\" *tsp-hpile-custom* (list (atoi (get_tile \"hpile_h\")) (atoi (get_tile \"hpile_b\")) (atoi (get_tile \"hpile_tw\")) (atoi (get_tile \"hpile_tf\"))))
           )
           ;; Wale 저장
           (setq idx (atoi (get_tile \"wale_spec\")))
           (if (< idx std-len)
             (setq *tsp-wale-spec* (nth idx *tsp-std-wall-list*)) ;; 리스트에서 선택
             (setq *tsp-wale-spec* \"User-defined\" *tsp-wale-custom* (list (atoi (get_tile \"wale_h\")) (atoi (get_tile \"wale_b\")) (atoi (get_tile \"wale_tw\")) (atoi (get_tile \"wale_tf\"))))
           )
           ;; 기타 변수 저장
           (setq *tsp-ctc* (atof (get_tile \"ctc\")))
           (setq *tsp-timber-thickness* (atoi (get_tile \"timber_thickness\")))
           (done_dialog 1)
         )"
      )
      (action_tile "back" "(done_dialog 2)")
      (action_tile "cancel" "(done_dialog 0)")
      (setq result (start_dialog))
      (unload_dialog dcl-id)
      result
    )
  )
)


;;;;==========================================================================
;;;; defun brace-dialog-callback : 다단 사보강재(Corner Strut) 설정 대화상자 콜백
;;;;==========================================================================
(defun brace-dialog-callback (dcl-path temp-seg-data limits rem-count / dcl-id result temp-b-rows std-len idx res-spec res-custom input-dist abs-dist prev-dist update-brace-list i str-dist disp num-b-rows min-req next-b-row next-dist sel-idx new-list allowed-dist hard-limit soft-limit tag-str jack-list res-jack b-jack dlg-name do-proceed tmp-id seg-id-str init-data init-upg cur-wale-spec cur-wale-vals cur-wale-h update-upgrade-ui res-upg upg-idx last-auto-max-spec is-init-phase cur-idx prev-idx seg-prev seg-cur p-corner p-prev p-next a1 a2 delta internal-angle-deg warn-id warn-res skip-brace loop-brace ret-val user-input-dist user-brace-spec user-brace-jack old-view-ctr old-view-size zoom-h scr-size aspect-ratio view-w target-cx target-cy orig-seg-data did-temp-draw user-chk-upgrade user-upg-spec tmp-upg tmp-brace tmp-seg init-slender init-is-manual init-interval init-enable init-margin slender-list validate-and-close update-stiffener-ui user-res-upg sel-indices user-brace-conn conn-list res-conn b-conn)
  (setq seg-id-str (itoa (if (assoc 'ID temp-seg-data) (cdr (assoc 'ID temp-seg-data)) 0)))
  (setq init-data (cdr (assoc 'CORNER-BRACE temp-seg-data)))
  (setq init-upg (cdr (assoc 'UPGRADE-WALE temp-seg-data)))
  (setq cur-wale-spec (cdr (assoc 'WALE-SPEC temp-seg-data)))
  (setq cur-wale-vals (if (= cur-wale-spec "User-defined") (cdr (assoc 'WALE-CUSTOM temp-seg-data)) (parse-h-spec cur-wale-spec)))
  (setq cur-wale-h (if cur-wale-vals (nth 0 cur-wale-vals) 300))

  (setq cur-idx (1- (if (assoc 'ID temp-seg-data) (cdr (assoc 'ID temp-seg-data)) 1)))
  (setq prev-idx (if (= cur-idx 0) (1- (length *segment-list*)) (1- cur-idx)))
  
  (setq seg-prev (if (and (>= prev-idx 0) (< prev-idx (length *segment-list*))) (nth prev-idx *segment-list*) nil))
  (setq seg-cur temp-seg-data)
  
  (setq p-corner (cdr (assoc 'V-START seg-cur)))
  (setq p-prev (if seg-prev (cdr (assoc 'V-START seg-prev)) nil))
  (setq p-next (cdr (assoc 'V-END seg-cur)))

  (setq internal-angle-deg 90.0)
  (if (and p-corner p-prev p-next)
    (progn
      (setq a1 (angle p-corner p-prev))
      (setq a2 (angle p-corner p-next))
      (setq delta (abs (- a1 a2)))
      (if (> delta pi) (setq delta (- (* 2.0 pi) delta)))
      (setq internal-angle-deg (* delta (/ 180.0 pi)))
    )
  )
  
  (princ (strcat "\n " seg-id-str "번 모서리의 실제 계산된 사이각: " (rtos internal-angle-deg 2 2) "도"))

  (setq skip-brace nil warn-res 0)
  (if (and (or (null (cadr init-data)) (= (length (cadr init-data)) 0)) 
           (>= internal-angle-deg 119.5))
    (progn
      (setq warn-id (load_dialog dcl-path))
      (if (and warn-id (new_dialog "tsp_brace_angle_warn" warn-id))
        (progn
          (set_tile "angle_msg" (strcat "코너 각도가 " (rtos internal-angle-deg 2 1) "도 입니다."))
          (action_tile "btn_skip" "(done_dialog 1)")
          (action_tile "btn_cont" "(done_dialog 2)")
          (setq warn-res (start_dialog))
          (unload_dialog warn-id)
        )
        (if warn-id (unload_dialog warn-id))
      )
      (if (/= warn-res 2) (setq skip-brace T))
    )
  )

  (if skip-brace
        (list (if (and rem-count (= rem-count 1)) "COMP" "NEXT") '("N" nil) init-upg)
        (progn
          (setq hard-limit (car limits))
          (setq soft-limit (cadr limits))
          
          (setq full-brace-list (append *tsp-std-wall-list* (mapcar '(lambda (x) (vl-string-subst "2H " "H " x)) *tsp-std-wall-list*)))
          
          ;;;;==========================================================================
          ;;;; defun get-auto-spec : 허용 길이 초과 여부를 검사하여 필요시 2H로 자동 변환
          ;;;;==========================================================================
          (defun get-auto-spec (base-spec base-custom target-dist is-mod / limit-val act-wale-h real-d real-t-L l-m)
            (setq limit-val (if (= (get_tile "slenderness_limit") "0") 100.0 120.0))
            (setq act-wale-h cur-wale-h)
            (if (= (get_tile "chk_upgrade_wale") "1")
              (setq act-wale-h (nth 0 (parse-h-spec (nth (atoi (get_tile "upgrade_wale_spec")) *tsp-std-wall-list*))))
            )
            (setq real-d (max 0.0 (- target-dist (/ act-wale-h 1000.0))))
              (setq real-t-L (* real-d (sqrt (* 2.0 (- 1.0 (cos (* internal-angle-deg (/ pi 180.0))))))))
              (setq l-m (tsp-calc-unsupported-length base-custom limit-val))
             
              ;; [추가] 25m 자중 좌굴 한계 초과 경고 (Soft Warning)
              (if (and (> real-t-L 25.0) (wcmatch base-spec "*H*"))
                (if (not *tsp-brace-buckle-warned*)
                  (progn
                    (alert (strcat "경고: 사보강재의 예상 길이(" (rtos real-t-L 2 1) "m)가 자중 좌굴 한계(25m)를 초과합니다.\n안전성에 유의하여 작도를 진행합니다."))
                    (setq *tsp-brace-buckle-warned* T)
                  )
                )
              )

              (if (and (> real-t-L l-m) (wcmatch base-spec "H *"))
                (if is-mod
                  ;; 수정(Mod) 모드일 때: 사용자가 1겹(H)을 강제로 선택한 경우
                  (progn
                    (if (not *tsp-warned-flag*)
                      (progn
                        (alert "경고: 사보강재의 최대 길이가 세장비 허용 한계를 초과합니다!\n안전을 위해 맞버팀대(2H)가 권장되나, 사용자의 요청에 의해 1겹(H)으로 강제 적용됩니다.\n구조 검토를 반드시 확인하세요.")
                        (setq *tsp-warned-flag* T)
                      )
                    )
                    base-spec ; H로 강제 유지
                  )
                  ;; 추가(Add) 모드일 때: 기존처럼 2H로 안전하게 자동 치환
                  (vl-string-subst "2H " "H " base-spec)
                )
                base-spec
              )
            )

          (setq old-view-ctr (getvar "VIEWCTR"))
      (setq old-view-size (getvar "VIEWSIZE"))
      (if p-corner
        (progn
          (setq zoom-h (* (if (> hard-limit 1.0) hard-limit 5.0) 1000.0 3.0))
          (setq scr-size (getvar "SCREENSIZE"))
          (setq aspect-ratio (/ (car scr-size) (cadr scr-size)))
          (setq view-w (* zoom-h aspect-ratio))
          (setq target-cx (- (car p-corner) (* view-w 0.3)))
          (setq target-cy (cadr p-corner))
          (command "_.ZOOM" "_C" (list target-cx target-cy) zoom-h)
        )
      )

      (if (and init-data (= (car init-data) "Y") (cadr init-data))
        (setq temp-b-rows (cadr init-data))
        (setq temp-b-rows '())
      )
      
      (setq init-slender (if (> (length init-data) 2) (nth 2 init-data) "1"))
      (setq init-is-manual (if (> (length init-data) 3) (nth 3 init-data) "0"))
      (setq init-interval (if (> (length init-data) 4) (nth 4 init-data) "0.0"))
      (setq init-enable (if (> (length init-data) 5) (nth 5 init-data) "1"))
      (setq init-margin (if (> (length init-data) 6) (nth 6 init-data) "50"))
      (setq init-post-enable (if (> (length init-data) 7) (nth 7 init-data) "0"))
      (setq init-post-side (if (> (length init-data) 8) (nth 8 init-data) "L"))
      (setq init-post-layout (if (> (length init-data) 9) (nth 9 init-data) "1"))
      (setq init-post-invert (if (> (length init-data) 10) (nth 10 init-data) "0"))

      (setq dlg-name (if (and rem-count (= rem-count 0)) "tsp_brace_single" "tsp_brace"))
      
      (setq user-input-dist nil user-brace-spec nil user-brace-jack nil user-brace-conn nil)
      (setq orig-seg-data (nth cur-idx *segment-list*))
      (setq did-temp-draw nil)

      ;; 취소 시 복원을 위한 임시 세션 데이터 초기화
      (setq *tsp-temp-added-posts* (vlax-ldata-get "TSP_DICT" "ADDED_POSTS"))
      (if (not *tsp-temp-added-posts*) (setq *tsp-temp-added-posts* '()))
      (setq *tsp-temp-deleted-posts* (vlax-ldata-get "TSP_DICT" "DELETED_POSTS"))
      (if (not *tsp-temp-deleted-posts*) (setq *tsp-temp-deleted-posts* '()))
      (setq *tsp-use-temp-posts* T)

      (setq loop-brace T ret-val nil)
      (setq *tsp-brace-buckle-warned* nil) ; 25m 자중 좌굴 경고 플래그 초기화

      (while loop-brace
        (setq dcl-id (load_dialog dcl-path))
        (if (new_dialog dlg-name dcl-id)
          (progn
            (set_tile "brace_dlg_title" (strcat seg-id-str "번 모서리 사보강재(Corner Strut) 설정"))
            (set_tile "brace_info" (strcat "▶ 절대 한계: " (rtos hard-limit 2 2) "m / 권장(50%): " (rtos soft-limit 2 2) "m"))
            (start_list "brace_spec")
            ;; 맞버팀대(2H)가 포함된 확장 리스트를 드롭다운에 출력
            (mapcar 'add_list (append full-brace-list '("User-defined")))
            (end_list)
            (setq std-len (length full-brace-list))
            (setq jack-list '("스크류잭" "유압잭"))
            (start_list "brace_jack") (mapcar 'add_list jack-list) (end_list)
            (setq conn-list '("화타쐐기 없음" "화타쐐기 TYPE-G1"))
            (start_list "brace_conn") (mapcar 'add_list conn-list) (end_list)
            
            (setq slender-list '("100 (표준 기준)" "120 (최대 예외 한계)"))
            (start_list "slenderness_limit") (mapcar 'add_list slender-list) (end_list)
            
            ;; 추가된 UI 초기값 설정
            (set_tile "chk_stiffener_enable" init-enable)
            (set_tile "slenderness_limit" init-slender)
            (set_tile "chk_manual_interval" init-is-manual)
            (set_tile "stiffener_interval" init-interval)
            (set_tile "stiffener_margin" init-margin)
            (set_tile "chk_post_enable" init-post-enable)
            (if (= init-post-side "R") (set_tile "post_side_R" "1") (set_tile "post_side_L" "1"))
            (start_list "post_layout_mode") (mapcar 'add_list '("전체 배치" "교차 배치")) (end_list)
            (set_tile "post_layout_mode" init-post-layout)
            
            ;; 교차 반전 토글 초기화 및 활성/비활성 제어
            (set_tile "chk_post_invert" init-post-invert)
            (if (= init-post-layout "1") (mode_tile "chk_post_invert" 0) (mode_tile "chk_post_invert" 1))

            ;; 배치 옵션 및 교차 반전 토글 클릭 시 실시간 갱신을 위해 데이터 캡처 후 (done_dialog 5) 호출
            (action_tile "post_layout_mode" "(progn (setq init-post-layout $value) (if (= $value \"1\") (mode_tile \"chk_post_invert\" 0) (progn (mode_tile \"chk_post_invert\" 1) (set_tile \"chk_post_invert\" \"0\") (setq init-post-invert \"0\"))) (setq user-input-dist (get_tile \"brace_dist\")) (setq user-brace-spec (get_tile \"brace_spec\")) (setq user-brace-jack (get_tile \"brace_jack\")) (setq user-brace-conn (get_tile \"brace_conn\")) (setq user-chk-upgrade (get_tile \"chk_upgrade_wale\")) (setq user-upg-spec (get_tile \"upgrade_wale_spec\")) (setq init-slender (get_tile \"slenderness_limit\")) (setq init-is-manual (get_tile \"chk_manual_interval\")) (setq init-interval (get_tile \"stiffener_interval\")) (setq init-enable (get_tile \"chk_stiffener_enable\")) (setq init-margin (get_tile \"stiffener_margin\")) (setq init-post-enable (get_tile \"chk_post_enable\")) (setq init-post-side (if (= (get_tile \"post_side_R\") \"1\") \"R\" \"L\")) (done_dialog 5))")
            (action_tile "chk_post_invert" "(progn (setq init-post-invert $value) (setq user-input-dist (get_tile \"brace_dist\")) (setq user-brace-spec (get_tile \"brace_spec\")) (setq user-brace-jack (get_tile \"brace_jack\")) (setq user-brace-conn (get_tile \"brace_conn\")) (setq user-chk-upgrade (get_tile \"chk_upgrade_wale\")) (setq user-upg-spec (get_tile \"upgrade_wale_spec\")) (setq init-slender (get_tile \"slenderness_limit\")) (setq init-is-manual (get_tile \"chk_manual_interval\")) (setq init-interval (get_tile \"stiffener_interval\")) (setq init-enable (get_tile \"chk_stiffener_enable\")) (setq init-margin (get_tile \"stiffener_margin\")) (setq init-post-enable (get_tile \"chk_post_enable\")) (setq init-post-side (if (= (get_tile \"post_side_R\") \"1\") \"R\" \"L\")) (setq init-post-layout (get_tile \"post_layout_mode\")) (done_dialog 5))")

            (start_list "upgrade_wale_spec") (mapcar 'add_list *tsp-std-wall-list*) (end_list)
            
            ;; 도면 미리보기 후 다이얼로그 복귀 시, 사용자가 조작했던 상향 설정값을 잃지 않고 우선 복원
            (if user-chk-upgrade
              (progn
                (set_tile "chk_upgrade_wale" user-chk-upgrade)
                (if user-upg-spec
                  (set_tile "upgrade_wale_spec" user-upg-spec)
                )
              )
              (if init-upg
                (progn
                  (set_tile "chk_upgrade_wale" (if (= (car init-upg) "Y") "1" "0"))
                  (if (setq upg-idx (vl-position (cadr init-upg) *tsp-std-wall-list*))
                    (set_tile "upgrade_wale_spec" (itoa upg-idx)) (set_tile "upgrade_wale_spec" "2")
                  )
                )
                (progn (set_tile "chk_upgrade_wale" "0") (set_tile "upgrade_wale_spec" "2"))
              )
            )
            
            (defun update-upgrade-ui (/ max-h max-spec check-h b-idx check-vals spec-idx)
              (setq max-h 0 max-spec nil)
              (foreach b temp-b-rows
                (setq check-h (nth 0 (cadr b)))
                (if (> check-h max-h) (progn (setq max-h check-h) (setq max-spec (car b))))
              )
              (setq b-idx (atoi (get_tile "brace_spec")))
              (if (< b-idx std-len)
                (progn
                  ;; 2H 규격이더라도 파서가 에러를 내지 않도록 "H "로 임시 치환하여 치수 검사
                  (setq check-vals (parse-h-spec (vl-string-subst "H " "2H " (nth b-idx full-brace-list))))
                  (if (and check-vals (> (nth 0 check-vals) max-h))
                    (progn (setq max-h (nth 0 check-vals)) (setq max-spec (nth b-idx full-brace-list)))
                  )
                )
                (progn
                  (setq check-vals (list (atoi (get_tile "brace_h")) 0 0 0))
                  (if (> (nth 0 check-vals) max-h)
                    (progn (setq max-h (nth 0 check-vals)) (setq max-spec "User-defined"))
                  )
                )
              )
              (if (> max-h cur-wale-h)
                (progn
                  (mode_tile "chk_upgrade_wale" 0)
                  (mode_tile "upgrade_wale_spec" 0)
                  (if (not (equal last-auto-max-spec max-spec))
                    (progn
                      (if (not is-init-phase)
                        (progn
                          (set_tile "chk_upgrade_wale" "1")
                          (if (and max-spec (/= max-spec "User-defined") (setq spec-idx (vl-position max-spec *tsp-std-wall-list*)))
                            (set_tile "upgrade_wale_spec" (itoa spec-idx))
                          )
                        )
                      )
                      (setq last-auto-max-spec max-spec)
                    )
                  )
                )
                (progn
                  (mode_tile "chk_upgrade_wale" 1)
                  (mode_tile "upgrade_wale_spec" 1)
                  (set_tile "chk_upgrade_wale" "0")
                  (setq last-auto-max-spec nil)
                )
              )
            )

;;;;==========================================================================
;;;; defun update-stiffener-ui : 사보강재 간격 및 세장비 계산 UI 업데이트
;;;;==========================================================================
            (defun update-stiffener-ui (/ limit-val is-manual b-custom max-dist L-max real-dist real-total-L num-div req-interval str-L ang-rad last-row is-enabled active-wale-h upg-idx)
              (setq is-enabled (get_tile "chk_stiffener_enable"))
              (if (= is-enabled "0")
                (progn
                  (mode_tile "slenderness_limit" 1)
                  (mode_tile "chk_manual_interval" 1)
                  (mode_tile "stiffener_interval" 1)
                  (mode_tile "stiffener_margin" 1)
                  (set_tile "stiffener_info" "보강재 배열 생성 생략 (사보강재 메인 프레임만 생성)")
                )
                (progn
                  (mode_tile "slenderness_limit" 0)
                  (mode_tile "chk_manual_interval" 0)
                  (mode_tile "stiffener_margin" 0)
                  
                  (setq limit-val (if (= (get_tile "slenderness_limit") "0") 100.0 120.0))
                  (setq is-manual (get_tile "chk_manual_interval"))
                  (if (= is-manual "1") (mode_tile "stiffener_interval" 0) (mode_tile "stiffener_interval" 1))

                  (if (and temp-b-rows (> (length temp-b-rows) 0))
                    (progn
                      (setq last-row (last temp-b-rows))
                      (setq b-custom (nth 1 last-row))
                      (setq max-dist (nth 2 last-row))
                      (setq ang-rad (* internal-angle-deg (/ pi 180.0)))
                      
                      ;; 1. 현재 적용될 띠장(Wale)의 H(높이)값 동적 추출
                      (setq active-wale-h cur-wale-h)
                      (if (= (get_tile "chk_upgrade_wale") "1")
                        (progn
                          (setq upg-idx (atoi (get_tile "upgrade_wale_spec")))
                          (if (< upg-idx std-len)
                            (setq active-wale-h (nth 0 (parse-h-spec (nth upg-idx *tsp-std-wall-list*))))
                          )
                        )
                      )
                      
                      ;; 2. 이격거리에서 띠장 두께(H)를 뺀 실질 이격거리 산출
                      (setq real-dist (max 0.0 (- max-dist (/ active-wale-h 1000.0))))
                      
                      ;; 3. 최대 사보강재 길이 산출 (실질 이격거리 기준 기하학적 길이)
                      (setq real-total-L (* real-dist (sqrt (* 2.0 (- 1.0 (cos ang-rad))))))

                      ;; 4. 실제 길이(real-total-L)를 기준으로 세장비 및 등분 계산
                      (setq L-max (tsp-calc-unsupported-length b-custom limit-val))
                      (setq num-div (fix (+ (/ real-total-L L-max) 0.9999)))
                      (if (< num-div 1) (setq num-div 1))
                      (setq req-interval (/ real-total-L num-div))

                      (setq str-L (strcat "최대 사보강재 길이: " (rtos real-total-L 2 3) "m / 허용: " (rtos L-max 2 1) "m"))
                      (if (> num-div 1)
                        (set_tile "stiffener_info" (strcat str-L " -> " (itoa num-div) "등분 (" (rtos req-interval 2 2) "m)"))
                        (set_tile "stiffener_info" (strcat str-L " -> 보강재 불필요"))
                      )
                      (if (= is-manual "0")
                        (set_tile "stiffener_interval" (rtos req-interval 2 2))
                      )
                    )
                    (set_tile "stiffener_info" "사보강재(Corner Strut)를 먼저 추가하세요.")
                  )
                )
              )
            )


;;;;==========================================================================
;;;; defun update-brace-list : 사보강재 리스트 갱신 및 다음 열 입력용 연결방식 콤보박스 자동 제어 기능
;;;;==========================================================================
            (defun update-brace-list (/ i prev item spec m-dist rel-dist disp tag-str b-jack b-conn)
              (start_list "brace_list")
              (setq i 0 prev 0.0)
              (foreach item temp-b-rows
                (setq spec (car item) m-dist (nth 2 item) b-jack (nth 3 item) b-conn (nth 4 item))
                (if (null b-jack) (setq b-jack "스크류잭"))
                (if (null b-conn) (setq b-conn (if (= i 0) "화타쐐기 없음" "화타쐐기 TYPE-G1")))
                (setq rel-dist (- m-dist prev))
                (if (> m-dist hard-limit)
                  (setq tag-str "  [!] 절대 한계 초과")
                  (if (> m-dist soft-limit) (setq tag-str "  [!] 권장 한계 초과") (setq tag-str ""))
                )
                (if (= i 0)
                  (setq disp (strcat (itoa (1+ i)) "열: " spec " [" b-conn "] / " (rtos m-dist 2 2) "m" tag-str))
                  (setq disp (strcat (itoa (1+ i)) "열: " spec " (" b-jack ") [" b-conn "] / +" (rtos rel-dist 2 2) "m (누적 " (rtos m-dist 2 2) "m)" tag-str))
                )
                (add_list disp)
                (setq prev m-dist i (1+ i))
              )
              (end_list)
              (update-stiffener-ui) ; 갱신마다 예측값 및 활성상태 반영
              
              ;; 사용자가 연결방식을 수동 조작했다면 자동 전환 일시 중단
              (if (= (length temp-b-rows) 0)
                (progn
                  (set_tile "brace_conn" "0") ; 목록이 비어있으면 1열용 "화타쐐기 없음" 자동 선택
                  (setq is-conn-touched nil)  ; 초기화 상태이므로 수동 조작 기록 완벽히 리셋
                )
                (if (not is-conn-touched)
                  (set_tile "brace_conn" "1") ; 수동 조작이 없을 때만 "화타쐐기 TYPE-G1" 자동 선택
                )
              )
            )

            (update-brace-list)
            
            (if user-input-dist 
              (set_tile "brace_dist" user-input-dist) 
              (if (>= hard-limit 1.5) (set_tile "brace_dist" "1.5") (set_tile "brace_dist" "1.0"))
            )
            (set_tile "brace_spec" (if user-brace-spec user-brace-spec "2"))
            (set_tile "brace_jack" (if user-brace-jack user-brace-jack "0"))
            ;; 초기화 시에도 사용자의 이전 수동 조작값을 기억하되, 없을 경우 열 개수에 따른 자동 로직 따름
            (set_tile "brace_conn" (if user-brace-conn user-brace-conn (if (> (length temp-b-rows) 0) "1" "0")))
            
            (mode_tile "brace_h" 1) (mode_tile "brace_b" 1) (mode_tile "brace_tw" 1) (mode_tile "brace_tf" 1)
            (action_tile "brace_spec" 
              (strcat 
                "(if (= (atoi $value) std-len) "
                "  (progn (mode_tile \"brace_h\" 0)(mode_tile \"brace_b\" 0)(mode_tile \"brace_tw\" 0)(mode_tile \"brace_tf\" 0)) "
                "  (progn (mode_tile \"brace_h\" 1)(mode_tile \"brace_b\" 1)(mode_tile \"brace_tw\" 1)(mode_tile \"brace_tf\" 1))) "
                "(if (wcmatch (nth (atoi $value) full-brace-list) \"2H *\") "
                "  (if (< (atof (get_tile \"brace_dist\")) 2.0) (set_tile \"brace_dist\" \"2.0\"))) "
                "(update-upgrade-ui)"
              )
            )
            (action_tile "brace_h" "(update-upgrade-ui)")
            
            ;; 연결방식 콤보박스 수동 조작 감지 스위치 켜기
            (action_tile "brace_conn" "(setq is-conn-touched T)")
            
            ;; UI 액션 콜백 할당
            (action_tile "chk_stiffener_enable" "(update-stiffener-ui)")
            (action_tile "slenderness_limit" "(update-stiffener-ui)")
            (action_tile "chk_manual_interval" "(update-stiffener-ui)")

            (setq is-init-phase T)
            (update-upgrade-ui)
            (setq is-init-phase nil)

            (action_tile "btn_measure"
              "(progn 
                 (setq user-input-dist (get_tile \"brace_dist\"))
                 (setq user-brace-spec (get_tile \"brace_spec\"))
                 (setq user-brace-jack (get_tile \"brace_jack\"))
                 (setq user-brace-conn (get_tile \"brace_conn\"))
                 (setq user-chk-upgrade (get_tile \"chk_upgrade_wale\"))
                 (setq user-upg-spec (get_tile \"upgrade_wale_spec\"))
                 (setq init-slender (get_tile \"slenderness_limit\"))
                 (setq init-is-manual (get_tile \"chk_manual_interval\"))
                 (setq init-interval (get_tile \"stiffener_interval\"))
                 (setq init-enable (get_tile \"chk_stiffener_enable\"))
                 (setq init-margin (get_tile \"stiffener_margin\"))
                 (setq init-post-enable (get_tile \"chk_post_enable\"))
                 (setq init-post-side (if (= (get_tile \"post_side_R\") \"1\") \"R\" \"L\"))
                 (setq init-post-layout (get_tile \"post_layout_mode\"))
                 (setq init-post-invert (get_tile \"chk_post_invert\"))
                 (done_dialog 5)
               )"
            )

            (action_tile "btn_add"
              (strcat
                "(progn (setq input-dist (atof (get_tile \"brace_dist\"))) (setq num-b-rows (length temp-b-rows)) (setq prev-dist (if (> num-b-rows 0) (nth 2 (last temp-b-rows)) 0.0)) (setq abs-dist (+ prev-dist input-dist)) "
                "(setq is-dbl-sel (wcmatch (if (< (atoi (get_tile \"brace_spec\")) std-len) (nth (atoi (get_tile \"brace_spec\")) full-brace-list) \"\") \"2H *\")) "
                "(setq min-req (if is-dbl-sel (if (= num-b-rows 0) 1.5 1.2) (if (= num-b-rows 0) 1.0 0.8))) "
                "(if (< input-dist min-req) "
                "  (if is-dbl-sel "
                "    (if (= num-b-rows 0) (alert (strcat \"맞버팀대(2H) 1열은 코너부 간섭을 피하기 위해 최소 \" (rtos min-req 2 1) \"m 이상 이격해야 합니다.\")) (alert (strcat \"맞버팀대(2H) 다중열 설치 시 부재 간 간섭 방지를 위해 최소 \" (rtos min-req 2 1) \"m 이상 이격해야 합니다.\"))) "
                "    (if (= num-b-rows 0) (alert (strcat \"1열 사보강재(Corner Strut)는 여유 공간을 위해 최소 \" (rtos min-req 2 1) \"m 이상 이격해야 합니다.\")) (alert (strcat \"여러 열 설치 시 부재 간 간섭 방지를 위해 최소 \" (rtos min-req 2 1) \"m 이상 이격해야 합니다.\"))) "
                "  ) "
                "(progn (setq do-proceed T) (if (> abs-dist hard-limit) (progn (setq tmp-id (load_dialog dcl-path)) (if (new_dialog \"tsp_brace_hard_warn\" tmp-id) (progn (if (< hard-limit min-req) (progn (set_tile \"warn_msg1\" (strcat \"물리적 여유 공간(\" (rtos hard-limit 2 2) \"m)이 최소 기준(\" (rtos min-req 2 1) \"m) 부족입니다.\")) (set_tile \"warn_msg2\" \"시공 불가 예상 구간이나, 이대로 강제 돌파(적용)하시겠습니까?\"))) (action_tile \"accept\" \"(done_dialog 1)\") (action_tile \"cancel\" \"(done_dialog 0)\") (if (= (start_dialog) 0) (setq do-proceed nil)))) (unload_dialog tmp-id)) "
                "(if (> abs-dist soft-limit) (progn (setq tmp-id (load_dialog dcl-path)) (if (new_dialog \"tsp_brace_warn\" tmp-id) (progn (action_tile \"accept\" \"(done_dialog 1)\") (action_tile \"cancel\" \"(done_dialog 0)\") (if (= (start_dialog) 0) (setq do-proceed nil)))) (unload_dialog tmp-id)))) "
                "(if do-proceed (progn (setq idx (atoi (get_tile \"brace_spec\"))) (if (< idx std-len) (progn (setq res-spec (nth idx full-brace-list)) (setq res-custom (parse-h-spec (vl-string-subst \"H \" \"2H \" res-spec)))) (progn (setq res-spec \"User-defined\") (setq res-custom (list (atoi (get_tile \"brace_h\")) (atoi (get_tile \"brace_b\")) (atoi (get_tile \"brace_tw\")) (atoi (get_tile \"brace_tf\")))))) "
                "(setq tmp-spec (get-auto-spec res-spec res-custom abs-dist nil)) "
                "(if (and (wcmatch tmp-spec \"2H *\") (not (wcmatch res-spec \"2H *\")) (< input-dist 2.0)) "
                "  (progn "
                "    (setq input-dist 2.0) "
                "    (setq abs-dist (+ prev-dist input-dist)) "
                "    (set_tile \"brace_dist\" \"2.0\") "
                "    (alert \"세장비 허용 한계를 초과하여 맞버팀대(2H)로 자동 전환되었으며, 공간 확보를 위해 이격거리가 2.0m로 자동 보정되었습니다.\") "
                "  ) "
                ") "
                "(setq res-spec tmp-spec) "
                "(setq res-jack (nth (atoi (get_tile \"brace_jack\")) jack-list)) (setq res-conn (nth (atoi (get_tile \"brace_conn\")) conn-list)) (setq temp-b-rows (append temp-b-rows (list (list res-spec res-custom abs-dist res-jack res-conn)))) (update-brace-list) (update-upgrade-ui) )))))"
              )
            )
            
            (action_tile "btn_mod"
              (strcat
                "(progn (setq *tsp-warned-flag* nil *tsp-brace-buckle-warned* nil) (setq sel-idx-str (get_tile \"brace_list\")) (setq sel-indices (if (and sel-idx-str (/= sel-idx-str \"\")) (tsp-parse-space-string sel-idx-str) nil)) "
                "(if sel-indices (progn "
                "(setq idx (atoi (get_tile \"brace_spec\"))) (if (< idx std-len) (progn (setq res-spec (nth idx full-brace-list)) (setq res-custom (parse-h-spec (vl-string-subst \"H \" \"2H \" res-spec)))) (progn (setq res-spec \"User-defined\") (setq res-custom (list (atoi (get_tile \"brace_h\")) (atoi (get_tile \"brace_b\")) (atoi (get_tile \"brace_tw\")) (atoi (get_tile \"brace_tf\")))))) "
                "(setq res-jack (nth (atoi (get_tile \"brace_jack\")) jack-list)) (setq res-conn (nth (atoi (get_tile \"brace_conn\")) conn-list)) "
                "(if (= (length sel-indices) 1) (progn "
                "(setq sel-idx (car sel-indices)) (setq input-dist (atof (get_tile \"brace_dist\"))) (setq prev-dist (if (> sel-idx 0) (nth 2 (nth (1- sel-idx) temp-b-rows)) 0.0)) (setq abs-dist (+ prev-dist input-dist)) "
                "(setq is-dbl-sel (wcmatch res-spec \"2H *\")) "
                "(setq min-req (if is-dbl-sel (if (= sel-idx 0) 1.5 1.2) (if (= sel-idx 0) 1.0 0.8))) "
                "(setq next-b-row (if (< (1+ sel-idx) (length temp-b-rows)) (nth (1+ sel-idx) temp-b-rows) nil)) (setq next-dist (if next-b-row (nth 2 next-b-row) nil)) "
                "(if (< input-dist min-req) "
                "  (if is-dbl-sel "
                "    (if (= sel-idx 0) (alert (strcat \"맞버팀대(2H) 1열은 코너부 간섭을 피하기 위해 최소 \" (rtos min-req 2 1) \"m 이상 이격해야 합니다.\")) (alert (strcat \"맞버팀대(2H) 다중열 설치 시 부재 간 간섭 방지를 위해 최소 \" (rtos min-req 2 1) \"m 이상 이격해야 합니다.\"))) "
                "    (if (= sel-idx 0) (alert (strcat \"1열 사보강재(Corner Strut)는 여유 공간을 위해 최소 \" (rtos min-req 2 1) \"m 이상 이격해야 합니다.\")) (alert (strcat \"여러 열 설치 시 부재 간 간섭 방지를 위해 최소 \" (rtos min-req 2 1) \"m 이상 이격해야 합니다.\"))) "
                "  ) "
                "(if (and next-dist (< (- next-dist abs-dist) 0.8)) (alert \"수정 시 다음 열과의 간격이 0.8m 미만이 되어 간섭이 발생합니다. 다음 열을 먼저 수정하거나 거리를 조절하세요.\") (progn (setq do-proceed T) (if (> abs-dist hard-limit) (progn (setq tmp-id (load_dialog dcl-path)) (if (new_dialog \"tsp_brace_hard_warn\" tmp-id) (progn (if (< hard-limit min-req) (progn (set_tile \"warn_msg1\" (strcat \"물리적 여유 공간(\" (rtos hard-limit 2 2) \"m)이 최소 기준(\" (rtos min-req 2 1) \"m) 부족입니다.\")) (set_tile \"warn_msg2\" \"시공 불가 예상 구간이나, 이대로 강제 돌파(적용)하시겠습니까?\"))) (action_tile \"accept\" \"(done_dialog 1)\") (action_tile \"cancel\" \"(done_dialog 0)\") (if (= (start_dialog) 0) (setq do-proceed nil)))) (unload_dialog tmp-id)) "
                "(if (> abs-dist soft-limit) (progn (setq tmp-id (load_dialog dcl-path)) (if (new_dialog \"tsp_brace_warn\" tmp-id) (progn (action_tile \"accept\" \"(done_dialog 1)\") (action_tile \"cancel\" \"(done_dialog 0)\") (if (= (start_dialog) 0) (setq do-proceed nil)))) (unload_dialog tmp-id)))) "
                "(if do-proceed (progn (setq tmp-spec (get-auto-spec res-spec res-custom abs-dist T)) (setq i 0 new-list '()) (foreach item temp-b-rows (if (= i sel-idx) (setq new-list (append new-list (list (list tmp-spec res-custom abs-dist res-jack res-conn)))) (setq new-list (append new-list (list item)))) (setq i (1+ i))) (setq temp-b-rows new-list) (update-brace-list) (update-upgrade-ui) )))))) "
                "(progn (setq i 0 new-list '()) (foreach item temp-b-rows (if (vl-position i sel-indices) (progn (setq cur-abs-dist (nth 2 item)) (setq tmp-spec (get-auto-spec res-spec res-custom cur-abs-dist T)) (setq new-list (append new-list (list (list tmp-spec res-custom cur-abs-dist res-jack res-conn))))) (setq new-list (append new-list (list item)))) (setq i (1+ i))) (setq temp-b-rows new-list) (update-brace-list) (update-upgrade-ui) )) "
                ") (alert \"수정할 항목을 선택하세요!\")))"
              )
            )
            
            (action_tile "btn_del" "(progn (setq sel-idx-str (get_tile \"brace_list\")) (if (and sel-idx-str (/= sel-idx-str \"\")) (progn (setq sel-indices (tsp-parse-space-string sel-idx-str)) (setq new-list '() i 0) (foreach item temp-b-rows (if (not (vl-position i sel-indices)) (setq new-list (append new-list (list item)))) (setq i (1+ i))) (setq temp-b-rows new-list) (update-brace-list) (update-upgrade-ui)) (alert \"삭제할 항목을 선택하세요!\")))")
            
            (defun validate-and-close (done_val / limit-val b-custom L-max input-int)
              ;; 띠장 상향 데이터 소실 방지 로직 도입
              (setq user-res-upg 
                (if (= (get_tile "chk_upgrade_wale") "1") 
                  (list "Y" (nth (atoi (get_tile "upgrade_wale_spec")) *tsp-std-wall-list*) nil)
                  (if (and init-upg (= (car init-upg) "Y"))
                    init-upg ; 기존 띠장 상향 설정 보존
                    nil
                  )
                )
              )
              (setq init-enable (get_tile "chk_stiffener_enable"))
              (setq init-slender (get_tile "slenderness_limit"))
              (setq init-is-manual (get_tile "chk_manual_interval"))
              (setq init-interval (get_tile "stiffener_interval"))
              (setq init-margin (get_tile "stiffener_margin"))
              (setq init-post-enable (get_tile "chk_post_enable"))
              (setq init-post-side (if (= (get_tile "post_side_R") "1") "R" "L"))
              (setq init-post-layout (get_tile "post_layout_mode"))
              (setq init-post-invert (get_tile "chk_post_invert"))
              
              (if (and temp-b-rows (> (length temp-b-rows) 0) (= init-enable "1") (= init-is-manual "1"))
                (progn
                  (setq limit-val (if (= init-slender "0") 100.0 120.0))
                  (setq b-custom (nth 1 (last temp-b-rows)))
                  (setq L-max (tsp-calc-unsupported-length b-custom limit-val))
                  (setq input-int (atof init-interval))
                  (if (and (> input-int 0.01) (> input-int L-max))
                    (alert (strcat "입력한 수동 간격(" (rtos input-int 2 2) "m)이 세장비 허용 한계(" (rtos L-max 2 2) "m)를 초과하여 구조적으로 위험합니다. 값을 낮춰주세요."))
                    (done_dialog done_val)
                  )
                )
                (done_dialog done_val)
              )
            )

            (setq save-ui-state-str
              "(progn
                 (setq user-input-dist (get_tile \"brace_dist\"))
                 (setq user-brace-spec (get_tile \"brace_spec\"))
                 (setq user-brace-jack (get_tile \"brace_jack\"))
                 (setq user-brace-conn (get_tile \"brace_conn\"))
                 (setq user-chk-upgrade (get_tile \"chk_upgrade_wale\"))
                 (setq user-upg-spec (get_tile \"upgrade_wale_spec\"))
                 (setq init-slender (get_tile \"slenderness_limit\"))
                 (setq init-is-manual (get_tile \"chk_manual_interval\"))
                 (setq init-interval (get_tile \"stiffener_interval\"))
                 (setq init-enable (get_tile \"chk_stiffener_enable\"))
                 (setq init-margin (get_tile \"stiffener_margin\"))
                 (setq init-post-enable (get_tile \"chk_post_enable\"))
                 (setq init-post-side (if (= (get_tile \"post_side_R\") \"1\") \"R\" \"L\"))
                 (setq init-post-layout (get_tile \"post_layout_mode\"))
                 (setq init-post-invert (get_tile \"chk_post_invert\"))
               )"
            )
            (action_tile "btn_post_add" (strcat save-ui-state-str "(done_dialog 97)"))
            (action_tile "btn_post_del" (strcat save-ui-state-str "(done_dialog 98)"))
            (action_tile "btn_post_reset" (strcat save-ui-state-str "(done_dialog 99)"))

            (action_tile "btn_comp" "(validate-and-close 1)")
            (action_tile "accept" (if (and rem-count (= rem-count 1)) "(validate-and-close 1)" "(validate-and-close 2)"))
            (action_tile "cancel" "(done_dialog 0)")
            
            (setq result (start_dialog))
            (unload_dialog dcl-id)
            
            ;; 결과 저장 시 추가된 파라미터(init-enable, init-margin, init-post-enable)를 리스트에 묶어 보존
            (cond
             ((= result 1) 
               (setq ret-val (list "COMP" (if (> (length temp-b-rows) 0) (list "Y" temp-b-rows init-slender init-is-manual init-interval init-enable init-margin init-post-enable init-post-side init-post-layout init-post-invert) (list "Y" nil)) user-res-upg))
               (setq loop-brace nil)
              )
              ((= result 2) 
               (setq ret-val (list "NEXT" (if (> (length temp-b-rows) 0) (list "Y" temp-b-rows init-slender init-is-manual init-interval init-enable init-margin init-post-enable init-post-side init-post-layout init-post-invert) (list "Y" nil)) user-res-upg))
               (setq loop-brace nil)
              )
              ((= result 5)
               (setq tmp-upg (if (= user-chk-upgrade "1") (list "Y" (nth (atoi user-upg-spec) *tsp-std-wall-list*) nil) nil))
               (setq tmp-brace (if (> (length temp-b-rows) 0) (list "Y" temp-b-rows init-slender init-is-manual init-interval init-enable init-margin init-post-enable init-post-side init-post-layout init-post-invert) (list "Y" nil)))
               (setq tmp-seg (subst (cons 'CORNER-BRACE tmp-brace) (assoc 'CORNER-BRACE temp-seg-data) temp-seg-data))
               (setq tmp-seg (subst (cons 'UPGRADE-WALE tmp-upg) (assoc 'UPGRADE-WALE tmp-seg) tmp-seg))
               (setq *segment-list* (update-list-item *segment-list* cur-idx tmp-seg))
               
               (if (and *tsp-boundary-ent* *tsp-boundary-orient*)
                 (tsp-redraw-realtime-plan *tsp-boundary-ent* *tsp-boundary-orient*)
               )
               
               (if tsp-pause-for-measurement
                 (tsp-pause-for-measurement)
                 (alert "TSP - 도면 제어 모듈이 로드되지 않았습니다.")
               )
               
               (setq *segment-list* (update-list-item *segment-list* cur-idx orig-seg-data))
               (setq did-temp-draw T)
              )

              ((or (= result 97) (= result 98) (= result 99))
               ;; 1. 현재 DCL 상태를 임시 전역 리스트(*segment-list*)에 덮어쓰기
               (setq tmp-upg (if (= user-chk-upgrade "1") (list "Y" (nth (atoi user-upg-spec) *tsp-std-wall-list*) nil) nil))
               (setq tmp-brace (if (> (length temp-b-rows) 0) (list "Y" temp-b-rows init-slender init-is-manual init-interval init-enable init-margin init-post-enable init-post-side init-post-layout init-post-invert) (list "Y" nil)))
               (setq tmp-seg (subst (cons 'CORNER-BRACE tmp-brace) (assoc 'CORNER-BRACE temp-seg-data) temp-seg-data))
               (setq tmp-seg (subst (cons 'UPGRADE-WALE tmp-upg) (assoc 'UPGRADE-WALE tmp-seg) tmp-seg))
               (setq *segment-list* (update-list-item *segment-list* cur-idx tmp-seg))

               ;; 2. 해당 수동 작도/삭제 함수 호출 (현재 세그먼트 ID를 추출하여 함수에 전달)
               (setq tmp-id (if (assoc 'ID temp-seg-data) (cdr (assoc 'ID temp-seg-data)) 0))
               (cond
                 ((= result 97)
                  (if (not (boundp 'tsp-manual-add-post)) 
                    (alert "수동 추가 함수(tsp-manual-add-post)가 로드되지 않았습니다.") 
                    (tsp-manual-add-post tmp-id)
                  )
                 )
                 ((= result 98)
                  (if (not (boundp 'tsp-manual-delete-post)) 
                    (alert "수동 삭제 함수(tsp-manual-delete-post)가 로드되지 않았습니다.") 
                    (tsp-manual-delete-post tmp-id)
                  )
                 )
                 ((= result 99)
                  (if (not (boundp 'tsp-delete-manual-post-by-segment)) 
                    (alert "개별 초기화 함수(tsp-delete-manual-post-by-segment)가 로드되지 않았습니다.") 
                    (progn
                      (tsp-delete-manual-post-by-segment tmp-id)
                      (princ (strcat "\n[초기화] Seg-" (itoa tmp-id) " 구역의 수동 중간말뚝이 초기화되었습니다."))
                    )
                  )
                 )
               )

               ;; 3. 원래 세그먼트 데이터로 원상복구 (사용자가 최종 취소를 누를 경우를 대비한 오염 방지)
               (setq *segment-list* (update-list-item *segment-list* cur-idx orig-seg-data))
               (setq did-temp-draw T)
              )
              (t 
               (setq ret-val nil)
               (setq loop-brace nil)
              )
            )
          )
          (progn (if dcl-id (unload_dialog dcl-id)) (setq ret-val nil loop-brace nil))
        )
      ) ;; end while loop-brace
      
      ;; 1. 확인(COMP/NEXT)을 눌렀을 때만 임시 데이터를 영구 LDATA에 반영
      (if ret-val
        (progn
          (vlax-ldata-put "TSP_DICT" "ADDED_POSTS" *tsp-temp-added-posts*)
          (vlax-ldata-put "TSP_DICT" "DELETED_POSTS" *tsp-temp-deleted-posts*)
        )
      )
      (setq *tsp-use-temp-posts* nil) ;; 임시 세션 종료
      
      (if (and old-view-ctr old-view-size)
        (command "_.ZOOM" "_C" old-view-ctr old-view-size)
      )
      
      ;; 2. 취소(Cancel)를 눌렀거나 화면 임시 갱신이 있었던 경우, 원상복구를 위해 화면 새로고침
      (if (or (null ret-val) did-temp-draw)
        (if (and *tsp-boundary-ent* *tsp-boundary-orient*)
          (tsp-redraw-realtime-plan *tsp-boundary-ent* *tsp-boundary-orient*)
        )
      )
      
      ret-val
    )
  )
)


;;;;==========================================================================
;;;; defun tsp-get-wale-offset : 특정 세그먼트의 띠장 내측면까지의 오프셋 거리 계산
;;;;==========================================================================
(defun tsp-get-wale-offset (seg-data / wall-type wale-vals wale-h wale-spec)
  (setq wall-type (cdr (assoc 'WALL-TYPE seg-data)))
  (if (not wall-type) (setq wall-type "HPILE"))
  (if (= wall-type "CIP")
    (progn
      (setq wale-spec (nth (atoi (if (cdr (assoc 'CIP-WALE-IDX seg-data)) (cdr (assoc 'CIP-WALE-IDX seg-data)) "0")) *tsp-std-wall-list*))
      (setq wale-vals (parse-h-spec wale-spec))
      (setq wale-h (if wale-vals (nth 0 wale-vals) 300.0))
      wale-h
    )
    (progn
      (setq wale-spec (cdr (assoc 'WALE-SPEC seg-data)))
      (if (null wale-spec) (setq wale-spec "H 300x300x10/15"))
      (setq wale-vals (if (= wale-spec "User-defined") (cdr (assoc 'WALE-CUSTOM seg-data)) (parse-h-spec wale-spec)))
      (setq wale-h (if wale-vals (nth 0 wale-vals) 300.0))
      wale-h
    )
  )
)


