             (set_tile \"status_msg\" \"[지반 일괄적용] 지반 정보를 가진 원본 세그먼트를 클릭하세요. (취소: ESC)\"))")
        (action_tile "btn_apply_support"
          "(progn
             (setq apply-support-mode T paste-mode nil apply-all-mode nil apply-soil-mode nil apply-wall-mode nil apply-brace-mode nil)
             (set_tile \"status_msg\" \"[지보재 일괄적용] 지보재 정보를 가진 원본 세그먼트를 클릭하세요. (취소: ESC)\"))")
        (action_tile "btn_apply_wall"
          "(progn
             (setq apply-wall-mode T paste-mode nil apply-all-mode nil apply-soil-mode nil apply-support-mode nil apply-brace-mode nil)
