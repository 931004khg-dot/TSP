)

;;;;==========================================================================
;;;; defun tsp-draw-wedge-connection : 화타쐐기 작도 및 가림 판정용 다각형 외곽선 반환
;;;;==========================================================================
(defun tsp-draw-wedge-connection (pt_inner p1_flange p2_flange strut_dir wale_dir wale_norm conn_type / 
                                  p1_wall p2_wall vW dot pExt_wall pOth_wall isExt2 
                                  p1 p2 p3 fill_1 fill_2 dist_f1 dist_f2 half_bp
                                  wp_1 wp_2 wp_3 wp_4 ep_b1 ep_b2 ep_t1 ep_t2
                                  p1_foot_temp p1_temp l2_p2_temp p2_temp p2_foot_temp
                                  dir_to_p2 dir_to_p1 p2_foot p1_foot
                                  p1_14 p2_14 p1_64 p2_64 p_cut p2_end p3_end br_p1 br_p2 wedge_segs get-poly-segs)

  ;; 다각형 정점들로부터 닫힌 선분 리스트를 추출하는 내부 함수
  (defun get-poly-segs (pts / segs i)
    (setq segs '() i 0)
    (while (< i (length pts))
      (setq segs (append segs (list (list (nth i pts) (nth (if (= i (1- (length pts))) 0 (1+ i)) pts)))))
      (setq i (1+ i))
    )
    segs
  )

  (setq wedge_segs '())
  ;; 1. 사보강재 진행 방향(isExt2) 판별 로직
  (setq p1_wall (inters p1_flange (polar p1_flange strut_dir 100.0) pt_inner (polar pt_inner wale_dir 100.0) nil))
  (setq p2_wall (inters p2_flange (polar p2_flange strut_dir 100.0) pt_inner (polar pt_inner wale_dir 100.0) nil))
  (setq vW (list (- (car p2_wall) (car p1_wall)) (- (cadr p2_wall) (cadr p1_wall))))
  (setq dot (+ (* (car vW) (cos strut_dir)) (* (cadr vW) (sin strut_dir))))
  (if (> dot 0)
    (setq isExt2 T pExt_wall p2_wall pOth_wall p1_wall)
    (setq isExt2 nil pExt_wall p1_wall pOth_wall p2_wall)
  )

  ;; 3. 연결 방식(conn_type)에 따른 작도 및 다각형 추출 분기
  (if (= conn_type "화타쐐기 없음")
    (progn
      (setq p1 pt_inner)
      (setq p2 (polar p1 wale_norm 14.0))

      (setq fill_1 (inters p1_flange (polar p1_flange strut_dir 100.0) p2 (polar p2 wale_dir 100.0) nil))
      (setq fill_2 (inters p2_flange (polar p2_flange strut_dir 100.0) p2 (polar p2 wale_dir 100.0) nil))

      (setq dist_f1 (distance p2 fill_1))
      (setq dist_f2 (distance p2 fill_2))
      (setq half_bp (max 250.0 (+ (max dist_f1 dist_f2) 50.0)))

      (setq wp_3 (polar p2 (+ wale_dir pi) half_bp))
      (setq wp_4 (polar p2 wale_dir half_bp))
      (setq wp_1 (polar wp_4 (+ wale_norm pi) 14.0))
      (setq wp_2 (polar wp_3 (+ wale_norm pi) 14.0))
      (tsp-draw-closed-poly (list wp_1 wp_2 wp_3 wp_4) "_화타쐐기(Wedge)" 2)
      (setq wedge_segs (append wedge_segs (get-poly-segs (list wp_1 wp_2 wp_3 wp_4))))

      (setq p3 (polar p2 strut_dir 220.0))
      (setq ep_b1 (inters p3 (polar p3 (+ strut_dir (/ pi 2.0)) 100.0) p1_flange (polar p1_flange strut_dir 100.0) nil))
      (setq ep_b2 (inters p3 (polar p3 (+ strut_dir (/ pi 2.0)) 100.0) p2_flange (polar p2_flange strut_dir 100.0) nil))

      (tsp-draw-closed-poly (list ep_b1 ep_b2 fill_2 fill_1) "_화타쐐기(Wedge)" 2)
      (setq wedge_segs (append wedge_segs (get-poly-segs (list ep_b1 ep_b2 fill_2 fill_1))))

      (setq ep_t1 (polar ep_b1 strut_dir 14.0))
      (setq ep_t2 (polar ep_b2 strut_dir 14.0))
      (tsp-draw-closed-poly (list ep_b1 ep_b2 ep_t2 ep_t1) "_화타쐐기(Wedge)" 2)
      (setq wedge_segs (append wedge_segs (get-poly-segs (list ep_b1 ep_b2 ep_t2 ep_t1))))

      (if isExt2
        (setq br_p1 ep_t2 br_p2 ep_t1)
        (setq br_p1 ep_t1 br_p2 ep_t2)
      )
    )
    (progn
      (setq p1_foot_temp pOth_wall)
      (setq p1_temp (polar p1_foot_temp wale_norm 64.0))
      (setq l2_p2_temp (polar p1_temp (angle pOth_wall pExt_wall) 100.0))
      (setq p2_temp (inters p1_temp l2_p2_temp pExt_wall (polar pExt_wall strut_dir 100.0) nil))
      (setq p2_foot_temp (polar p2_temp (+ wale_norm pi) 64.0))

      (setq dir_to_p2 (angle pt_inner p2_foot_temp))
      (setq dir_to_p1 (+ dir_to_p2 pi))
      (setq p2_foot (polar pt_inner dir_to_p2 (distance pt_inner p2_foot_temp)))
      (setq p1_foot (polar pt_inner dir_to_p1 (distance pt_inner p2_foot_temp)))

      (setq p1_14 (polar p1_foot wale_norm 14.0))
      (setq p1_64 (polar p1_foot wale_norm 64.0))
      (setq p2_14 (polar p2_foot wale_norm 14.0))
      (setq p2_64 p2_temp)

      (setq p_cut (inters p2_64 (polar p2_64 (+ strut_dir (/ pi 2.0)) 100.0) pOth_wall (polar pOth_wall strut_dir 100.0) nil))
      (setq p2_end (polar p2_64 strut_dir 14.0))
      (setq p3_end (polar p_cut strut_dir 14.0))

      (tsp-draw-closed-poly (list p1_foot p2_foot p2_14 p1_14) "_화타쐐기(Wedge)" 2)
      (setq wedge_segs (append wedge_segs (get-poly-segs (list p1_foot p2_foot p2_14 p1_14))))
      
      (tsp-draw-closed-poly (list p1_14 p1_64 p_cut p2_64 p2_14) "_화타쐐기(Wedge)" 2)
      (setq wedge_segs (append wedge_segs (get-poly-segs (list p1_14 p1_64 p_cut p2_64 p2_14))))
      
      (tsp-draw-closed-poly (list p2_64 p_cut p3_end p2_end) "_화타쐐기(Wedge)" 2)
      (setq wedge_segs (append wedge_segs (get-poly-segs (list p2_64 p_cut p3_end p2_end))))

      (if isExt2
        (setq br_p1 p3_end br_p2 p2_end)
        (setq br_p1 p2_end br_p2 p3_end)
      )
    )
  )

  ;; 잭 삽입점 및 가림 판정용 다각형 선분 동시 반환
  (list br_p1 br_p2 wedge_segs)
)


;;;;==========================================================================
;;;; defun tsp-draw-all-corner-braces : 사보강재(Corner Strut) 및 다중 대칭 보강재(Brace Array) 작도 통합 모듈
;;;;==========================================================================
(defun tsp-draw-all-corner-braces (boundary-ent boundary-orient / boundary-handle is-closed orig-vertices num-vertices max-segments idx prev-seg-idx next-seg-idx prev-def next-def prev-vertex curr-vertex next-vertex p-brace c-upg upg-vals prev-wale-spec prev-wale-vals w-h-prev next-wale-spec next-wale-vals w-h-next dir-A dir-B norm-A norm-B brace-b-rows b-row-idx b-spec b-custom b-dist-m b-jack b-conn b-dist b-h half-w pt-A-base pt-B-base pt-A-inner pt-B-inner brace-dir L1-A L1-B L2-A L2-B pA1 pA2 pB1 pB2 conn_pts_A conn_pts_B brace_A1 brace_A2 brace_B1 brace_B2 jack-side jack-len pt-jack-ins jack-rot brace_A1_in brace_A2_in brace_B1_in brace_B2_in b-tw half-tw mid_A_in mid_B_in web1_A web1_B web2_A web2_B max_brace_len brace_boundaries stiff-h stiff-tw pt_A_face_p1 pt_B_face_p1 pt-inner-corner vec_A vec_B vec_sum stiff-dir half-ang brace_len slender-limit is-manual manual-interval stiff-enable stiff-margin L-max total-L num-div interval cur-off offsets off axis-p1 axis-p2 p_out_L_line p_out_R_line pA_inf1 pA_inf2 pB_inf1 pB_inf2 hit-L_A hit-L_B hit-R_A hit-R_B hit-L hit-R proj-L proj-R max-proj hit-C_A hit-C_B hit-C p_flat_center p_flat_L p_flat_R p_stiff_base_center p_stiff_base_L p_stiff_base_R p_start_center p_out_L p_out_R p_in_L p_in_R max_dist_overall p_x1 p_x2 d1 d2 current_d merged_intervals sorted last_m pt_from pt_to p_end_L p_end_R valid-hit intervals cur_int hit-A hit-B hit-Wale wall-norm wl_dir ang_diff flat-half-w p_w1 p_w2 p_f1 p_f2 p_fL p_fR d_foot p_foot_A p_foot_B p_flat_A p_flat_B p_stiff_base_A p_stiff_base_B)

  (defun valid-hit (hit p-cor dir)
    (if hit (if (> (tsp-project-dist p-cor dir hit) -1e-3) hit nil) nil)
  )

  ;; 객체의 고유 핸들을 추출하여 변수에 저장
  (setq boundary-handle (tsp-get-entity-handle boundary-ent))
  
  (setq is-closed (is-closed-polyline boundary-ent))
  (setq orig-vertices (mapcar '(lambda (item) (cdr (assoc 'V-START item))) *segment-list*))
  (if (not is-closed) (setq orig-vertices (append orig-vertices (list (cdr (assoc 'V-END (last *segment-list*)))))))
  (setq num-vertices (length orig-vertices))
  (setq max-segments (if is-closed num-vertices (1- num-vertices)))

  (setq idx 0)
  (while (< idx num-vertices)
    (setq prev-seg-idx (if (= idx 0) (if is-closed (1- num-vertices) -1) (1- idx)))
    (setq next-seg-idx (if (>= idx max-segments) -1 idx))
    (setq prev-def (if (>= prev-seg-idx 0) (cdr (assoc 'IS-DEFINED (nth prev-seg-idx *segment-list*))) nil))
    (setq next-def (if (>= next-seg-idx 0) (cdr (assoc 'IS-DEFINED (nth next-seg-idx *segment-list*))) nil))
    
    (if (and prev-def next-def)
      (progn
        (setq prev-vertex (nth prev-seg-idx orig-vertices) curr-vertex (nth idx orig-vertices) next-vertex (nth (if is-closed (if (= idx (1- num-vertices)) 0 (1+ idx)) (1+ idx)) orig-vertices))
        (setq p-brace nil)
        (if (and (>= idx 0) (< idx (length *segment-list*))) (setq p-brace (cdr (assoc 'CORNER-BRACE (nth idx *segment-list*)))))
        
        (if (and p-brace (= (car p-brace) "Y"))
          (progn
            (setq brace-b-rows (cadr p-brace))
            (setq slender-limit (if (> (length p-brace) 2) (nth 2 p-brace) "1"))
            (setq is-manual (if (> (length p-brace) 3) (nth 3 p-brace) "0"))
            (setq manual-interval (if (> (length p-brace) 4) (nth 4 p-brace) "0.0"))
            (setq stiff-enable (if (> (length p-brace) 5) (nth 5 p-brace) "1"))
            (setq stiff-margin (if (> (length p-brace) 6) (atof (nth 6 p-brace)) 50.0))

            (setq c-upg (cdr (assoc 'UPGRADE-WALE (nth idx *segment-list*))))
            (setq upg-vals (if (and c-upg (= (car c-upg) "Y")) (parse-h-spec (cadr c-upg)) nil))
            
            ;; 띠장(Wale) 오프셋 작도 로직과 완벽히 동기화되도록 '기본 띠장'과 '상향 띠장' 중 최대값(max)을 적용
            (setq prev-wale-spec (cdr (assoc 'WALE-SPEC (nth prev-seg-idx *segment-list*))))
            (setq prev-wale-vals (if (= prev-wale-spec "User-defined") (cdr (assoc 'WALE-CUSTOM (nth prev-seg-idx *segment-list*))) (parse-h-spec prev-wale-spec)))
            (setq base-h-prev (if prev-wale-vals (nth 0 prev-wale-vals) 300))
            (setq w-h-prev (if upg-vals (max (nth 0 upg-vals) base-h-prev) base-h-prev))
            
            (setq next-wale-spec (cdr (assoc 'WALE-SPEC (nth next-seg-idx *segment-list*))))
            (setq next-wale-vals (if (= next-wale-spec "User-defined") (cdr (assoc 'WALE-CUSTOM (nth next-seg-idx *segment-list*))) (parse-h-spec next-wale-spec)))
            (setq base-h-next (if next-wale-vals (nth 0 next-wale-vals) 300))
            (setq w-h-next (if upg-vals (max (nth 0 upg-vals) base-h-next) base-h-next))
            
            (setq dir-A (angle curr-vertex prev-vertex) dir-B (angle curr-vertex next-vertex))
            (setq norm-A (+ (angle prev-vertex curr-vertex) (* boundary-orient (/ pi 2.0))))
            (setq norm-B (+ (angle curr-vertex next-vertex) (* boundary-orient (/ pi 2.0))))
            
            (setq b-row-idx 0 max_brace_len 0.0 brace_boundaries '() stiff-h 300.0 stiff-tw 10.0 brace-row-data-list '())
            
            (setq pt_A_face_p1 (polar curr-vertex norm-A w-h-prev))
            (setq pt_B_face_p1 (polar curr-vertex norm-B w-h-next))
            (setq pt-inner-corner (inters pt_A_face_p1 (polar pt_A_face_p1 dir-A 100.0) pt_B_face_p1 (polar pt_B_face_p1 dir-B 100.0) nil))
            (if (null pt-inner-corner) (setq pt-inner-corner curr-vertex))
            
            ;; 굴착면 안쪽을 향하도록 법선(norm) 벡터를 합산
            (setq vec_nA (list (cos norm-A) (sin norm-A)))
            (setq vec_nB (list (cos norm-B) (sin norm-B)))
            (setq vec_n_sum (list (+ (car vec_nA) (car vec_nB)) (+ (cadr vec_nA) (cadr vec_nB))))
            (setq stiff-dir (angle '(0 0 0) vec_n_sum))
            
            ;; 모서리 내각(delta)의 절반을 삼각함수로 안전하게 산출
            (setq delta (abs (- dir-A dir-B)))
            (if (> delta pi) (setq delta (- (* 2.0 pi) delta)))
            (setq half-ang (/ delta 2.0))
            
            (create-strut-jack-block) (create-strut-screw-jack-block)
            (if (not (tblsearch "APPID" "TSP_STRUT_SPEC")) (regapp "TSP_STRUT_SPEC"))
            
              ;;;; 사보강재 단일/맞버팀대(Double Strut) 작도 로직
              (foreach b-row brace-b-rows
                (setq b-spec (nth 0 b-row) b-custom (nth 1 b-row) b-dist-m (nth 2 b-row) b-jack (nth 3 b-row) b-conn (nth 4 b-row))
                (if (null b-jack) (setq b-jack "스크류잭"))
                (if (null b-conn) (setq b-conn (if (= b-row-idx 0) "화타쐐기 없음" "화타쐐기 TYPE-G1")))
                
                (setq b-dist (* b-dist-m 1000.0) b-h (nth 0 b-custom) b-width (nth 1 b-custom) half-w (/ b-width 2.0) stiff-h b-h stiff-tw (nth 2 b-custom))
                
                (setq pt-A-base (polar curr-vertex dir-A b-dist) pt-B-base (polar curr-vertex dir-B b-dist))
                (setq pt-A-inner (list (car (polar pt-A-base norm-A w-h-prev)) (cadr (polar pt-A-base norm-A w-h-prev)) 0.0))
                (setq pt-B-inner (list (car (polar pt-B-base norm-B w-h-next)) (cadr (polar pt-B-base norm-B w-h-next)) 0.0))
                
                (create-layer-if-not-exists "_mpoint" "2")
                (entmake (list '(0 . "POINT") '(100 . "AcDbEntity") '(100 . "AcDbPoint") (cons 8 "_mpoint") (cons 62 2) (list 10 (car pt-A-inner) (cadr pt-A-inner) 0.0)))
                (entmake (list '(0 . "POINT") '(100 . "AcDbEntity") '(100 . "AcDbPoint") (cons 8 "_mpoint") (cons 62 2) (list 10 (car pt-B-inner) (cadr pt-B-inner) 0.0)))

                (setq brace-dir (angle pt-A-inner pt-B-inner))
                (setq is-double (wcmatch b-spec "2H *"))
                (setq strut-offsets (if is-double (list b-width (- b-width)) (list 0.0)))
                
                (setq sub-idx 0)
                (foreach s-off strut-offsets
                  (setq off-dir (+ brace-dir (/ pi 2.0)))
                  (setq p-off-A (polar pt-A-inner off-dir s-off))
                  (setq p-off-B (polar pt-B-inner off-dir s-off))
                  
                  (setq sub-pt-A-inner (inters pt-A-inner (polar pt-A-inner dir-A 100.0) p-off-A p-off-B nil))
                  (setq sub-pt-B-inner (inters pt-B-inner (polar pt-B-inner dir-B 100.0) p-off-A p-off-B nil))
                  
                  (if (and sub-pt-A-inner sub-pt-B-inner)
                    (progn
                      (setq sub-brace_len (distance sub-pt-A-inner sub-pt-B-inner))
                      (if (> sub-brace_len max_brace_len) (setq max_brace_len sub-brace_len))
                      
                      (setq sub-brace-dir (angle sub-pt-A-inner sub-pt-B-inner))
                      (setq L1-A (polar sub-pt-A-inner (+ sub-brace-dir (/ pi 2.0)) half-w) L1-B (polar sub-pt-B-inner (+ sub-brace-dir (/ pi 2.0)) half-w))
                      (setq L2-A (polar sub-pt-A-inner (- sub-brace-dir (/ pi 2.0)) half-w) L2-B (polar sub-pt-B-inner (- sub-brace-dir (/ pi 2.0)) half-w))
                      
                      (setq pA1 (inters sub-pt-A-inner (polar sub-pt-A-inner dir-A 100.0) L1-A L1-B nil))
                      (setq pA2 (inters sub-pt-A-inner (polar sub-pt-A-inner dir-A 100.0) L2-A L2-B nil))
                      (setq pB1 (inters sub-pt-B-inner (polar sub-pt-B-inner dir-B 100.0) L1-A L1-B nil))
                      (setq pB2 (inters sub-pt-B-inner (polar sub-pt-B-inner dir-B 100.0) L2-A L2-B nil))
                      
                      (create-layer-if-not-exists "_사보강재(Corner_Strut)" "3") (create-layer-if-not-exists "_화타쐐기(Wedge)" "2")
                      
                      (if (and pA1 pB1 pA2 pB2)
                        (progn
                          (setq conn_pts_A (tsp-draw-wedge-connection sub-pt-A-inner pA1 pA2 sub-brace-dir dir-A norm-A b-conn))
                          (setq brace_A1 (car conn_pts_A) brace_A2 (cadr conn_pts_A) wedge_segs_A (caddr conn_pts_A))
                          
                          (setq conn_pts_B (tsp-draw-wedge-connection sub-pt-B-inner pB1 pB2 (+ sub-brace-dir pi) dir-B norm-B b-conn))
                          (setq brace_B1 (car conn_pts_B) brace_B2 (cadr conn_pts_B) wedge_segs_B (caddr conn_pts_B))
                          
                          ;; 맞버팀대(2H) 교차 배치 로직 적용
                          (if is-double
                            (setq jack-side (if (= sub-idx 0) "A" "B"))
                            (progn
                              (setq jack-side nil) 
                              (if (> b-row-idx 0) (if (= (rem b-row-idx 2) 1) (setq jack-side "A") (setq jack-side "B")))
                            )
                          )
                          
                          (setq jack-len 583.0)
                          (if (= jack-side "A")
                            (progn
                              (setq pt-jack-ins (list (/ (+ (car brace_A1) (car brace_A2)) 2.0) (/ (+ (cadr brace_A1) (cadr brace_A2)) 2.0) 0.0) jack-rot sub-brace-dir)
                              (entmake (list '(0 . "INSERT") (cons 2 b-jack) (cons 8 (if (= b-jack "스크류잭") "_스크류잭" "_유압잭")) (cons 62 2) (cons 10 pt-jack-ins) '(41 . 1.0) '(42 . 1.0) '(43 . 1.0) (cons 50 jack-rot)))
                              (setq brace_A1 (polar brace_A1 sub-brace-dir jack-len) brace_A2 (polar brace_A2 sub-brace-dir jack-len))
                            )
                          )
                          (if (= jack-side "B")
                            (progn
                              (setq pt-jack-ins (list (/ (+ (car brace_B1) (car brace_B2)) 2.0) (/ (+ (cadr brace_B1) (cadr brace_B2)) 2.0) 0.0) jack-rot (+ sub-brace-dir pi))
                              (entmake (list '(0 . "INSERT") (cons 2 b-jack) (cons 8 (if (= b-jack "스크류잭") "_스크류잭" "_유압잭")) (cons 62 2) (cons 10 pt-jack-ins) '(41 . 1.0) '(42 . 1.0) '(43 . 1.0) (cons 50 jack-rot)))
                              (setq brace_B1 (polar brace_B1 (+ sub-brace-dir pi) jack-len) brace_B2 (polar brace_B2 (+ sub-brace-dir pi) jack-len))
                            )
                          )
                          (tsp-draw-closed-poly (list brace_A1 brace_A2 brace_B2 brace_B1) "_사보강재(Corner_Strut)" 3)
                          
                          (setq cur-seg-id (cdr (assoc 'ID (nth idx *segment-list*))))
                          (setq outer-margin (* 2.0 (+ (if is-double b-width 0.0) half-w 100.0)))
                          (setq pA_bound (polar pt-A-inner dir-A outer-margin))
                          (setq pB_bound (polar pt-B-inner dir-B outer-margin))
                          
                          (setq strut-xdata 
                            (list -3 
                              (list "TSP_STRUT_SPEC" 
                                (cons 1070 cur-seg-id) 
                                (cons 1040 (float b-h)) 
                                (cons 1040 (float b-width)) 
                                (cons 1040 (float (nth 2 b-custom))) 
                                (cons 1040 (float (nth 3 b-custom)))
                                (cons 1010 pt-inner-corner)
                                (cons 1010 pA_bound)
                                (cons 1010 pB_bound)
                                (cons 1000 boundary-handle)
                              )
                            )
                          )
                          
                          (entmod (append (entget (entlast)) (list strut-xdata)))
                          
                          (setq brace_A1_in (polar brace_A1 sub-brace-dir 14.0) brace_A2_in (polar brace_A2 sub-brace-dir 14.0))
(setq brace_B1_in (polar brace_B1 (+ sub-brace-dir pi) 14.0) brace_B2_in (polar brace_B2 (+ sub-brace-dir pi) 14.0))

