                                        (if (< p_dist_col 0.1)
                                          (setq hits (append hits (list (tsp-project-dist p_start stiff-dir (car seg)) 
                                                                        (tsp-project-dist p_start stiff-dir (cadr seg)))))
                                        )
                                      )
                                    )
                                  )
                                )
                              )
                              (if (>= (length hits) 1)
                                (progn
                                  (setq hits (vl-sort hits '<))
                                  (setq d1 (max 0.0 (car hits)))
                                  (setq d2 (max 0.0 (last hits)))
                                  (if (not (equal d1 d2 0.01))
                                    (setq intervals (append intervals (list (cons d1 d2))))
                                  )
                                )
                              )
                            )
                            (setq merged_intervals '())
                            (if intervals
                              (progn
                                (setq sorted (vl-sort intervals (function (lambda (a b) (< (car a) (car b))))))
                                (setq merged_intervals (list (car sorted)))
                                (foreach cur (cdr sorted)
                                  (setq last_m (last merged_intervals))
                                  (if (<= (car cur) (cdr last_m))
                                    (setq merged_intervals (subst (cons (car last_m) (max (cdr last_m) (cdr cur))) last_m merged_intervals))
                                    (setq merged_intervals (append merged_intervals (list cur)))
                                  )
                                )
                              )
                            )
                            (setq current_d 0.0)
                            (foreach cur_int merged_intervals
                              (if (> (car cur_int) current_d)
                                (progn
                                  (setq pt_from (polar p_start stiff-dir current_d) pt_to (polar p_start stiff-dir (car cur_int)))
                                  (entmake (list '(0 . "LWPOLYLINE") '(100 . "AcDbEntity") '(100 . "AcDbPolyline") (cons 8 "_보강재(Brace)") (cons 62 col) (if (= ltype "DASHED") (cons 6 "DASHED") '(6 . "BYLAYER")) (if (= ltype "DASHED") (cons 48 (* (if (and (boundp '*tsp-scale-plan*) *tsp-scale-plan*) *tsp-scale-plan* 600.0) (/ 500.0 600.0) (if (= (getvar "MEASUREMENT") 1) (/ 1.0 25.0) 1.0))) '(48 . 1.0)) '(90 . 2) '(70 . 0) (list 10 (car pt_from) (cadr pt_from)) (list 10 (car pt_to) (cadr pt_to))))
                                )
                              )
                              (setq current_d (cdr cur_int))
                            )
                            (if (< current_d adj_total_L)
                              (progn
                                (setq pt_from (polar p_start stiff-dir current_d) pt_to (polar p_start stiff-dir adj_total_L))
                                (entmake (list '(0 . "LWPOLYLINE") '(100 . "AcDbEntity") '(100 . "AcDbPolyline") (cons 8 "_보강재(Brace)") (cons 62 col) (if (= ltype "DASHED") (cons 6 "DASHED") '(6 . "BYLAYER")) (if (= ltype "DASHED") (cons 48 (* (if (and (boundp '*tsp-scale-plan*) *tsp-scale-plan*) *tsp-scale-plan* 600.0) (/ 500.0 600.0) (if (= (getvar "MEASUREMENT") 1) (/ 1.0 25.0) 1.0))) '(48 . 1.0)) '(90 . 2) '(70 . 0) (list 10 (car pt_from) (cadr pt_from)) (list 10 (car pt_to) (cadr pt_to))))
                              )
                            )
                          )
                          
                          (setq p_end_center (polar p_start_center stiff-dir total_L))
                          (setq p_end_L (polar p_end_center (+ stiff-dir (/ pi 2.0)) stiff-half-w))
                          (setq p_end_R (polar p_end_center (- stiff-dir (/ pi 2.0)) stiff-half-w))
                          (entmake (list '(0 . "LWPOLYLINE") '(100 . "AcDbEntity") '(100 . "AcDbPolyline") (cons 8 "_보강재(Brace)") (cons 62 256) '(90 . 2) '(70 . 0) (list 10 (car p_end_L) (cadr p_end_L)) (list 10 (car p_end_R) (cadr p_end_R))))
                        )
                      )
                    )
                  )
                  (setq stiff-idx (1+ stiff-idx))
                )
              )
            )
          )
        )
      )
    )
    (setq idx (1+ idx))
  )
  (princ)
)


;;;;==========================================================================
;;;; defun create-hpile-set-on-boundary : 평면도 생성 (H-Pile / C.I.P 분기 처리 적용)
;;;;==========================================================================
(defun create-hpile-set-on-boundary (boundary-ent boundary-orient / last-ent vertices
                                      seg-data seg-wall-type has-cip has-hpile i
                                      vla-bnd total-len s-item s-manual-pts s-sec-str s-jack-type
                                      remapped-pts p d new-pt s-pt1 s-pt2 draw-result)

  ;; 1. 기존 그룹 정리 (번호표 포함 모든 객체 삭제)
  (tsp-clear-drawing-group boundary-ent)
  ;; 2. 마지막 엔티티 추적 시작 (가장 완벽한 위치)
  (setq last-ent (entlast))

  ;; 모든 세그먼트의 말뚝 개수를 누적할 전역 리스트를 0으로 사전 초기화
  (setq *tsp-segment-pile-counts* '())
  (setq i 0)
  (while (< i (length *segment-list*))
    (setq *tsp-segment-pile-counts* (cons 0 *tsp-segment-pile-counts*))
    (setq i (1+ i))
  )
  (setq *tsp-segment-pile-counts* (reverse *tsp-segment-pile-counts*))

  ;; 데이터 캐싱을 위한 H-Pile 좌표 리스트 초기화
  (setq *tsp-hpile-points* '())

  ;; 3. 안전망(vl-catch-all-apply) 구축: 내부 로직에서 에러가 발생해도 튕기지 않도록 보호
  (setq draw-result 
    (vl-catch-all-apply
      '(lambda ()
         ;; 4-1. 세그먼트에 CIP / HPILE 이 섞여있는지 파악
         (setq has-cip nil  has-hpile nil)
         (if *segment-list*
           (foreach seg-data *segment-list*
             (if (cdr (assoc 'IS-DEFINED seg-data))
               (progn
                 (setq seg-wall-type (cdr (assoc 'WALL-TYPE seg-data)))
                 (if (= seg-wall-type "CIP")
                   (setq has-cip T)
                   (setq has-hpile T)
                 )
               )
             )
           )
         )
         ;; 4-2. H-Pile+토류판 세그먼트 작도
         (if has-hpile
           (progn
             (princ "\n[작도] H-Pile 및 토류판 생성 중...")
             (place-hpile-timber-along-boundary boundary-ent boundary-orient)
           )
         )
         ;; 4-3. CIP 세그먼트 작도
         (if has-cip
           (progn
             (princ "\n[작도] C.I.P(현장타설말뚝) 배열 생성 중...")
             (tsp-draw-cip-plan-per-segment boundary-ent boundary-orient)
           )
         )
         ;; 4-4. 전역값 폴백 (안전장치)
         (if (and (not has-cip) (not has-hpile))
           (progn
             (if (= *tsp-wall-type* "CIP")
               (progn
                 (princ "\n[작도] C.I.P(현장타설말뚝) 배열 생성 중... (전역 폴백)")
                 (tsp-draw-cip-plan boundary-ent boundary-orient)
               )
               (progn
                 (princ "\n[작도] H-Pile 및 토류판 생성 중... (전역 폴백)")
                 (place-hpile-timber-along-boundary boundary-ent boundary-orient)
               )
             )
           )
         )

         ;; 5. 버팀보(Strut) 평면 재작도
         (if *segment-list*
           (progn
             (princ "\n[버팀보 재작도] 데이터 분석 및 작도 시작...")
             (setq vla-bnd (vlax-ename->vla-object boundary-ent))
             (setq total-len (vlax-curve-getdistatparam vla-bnd (vlax-curve-getendparam vla-bnd)))
             
             (setq poly-verts (mapcar '(lambda (x / v)
                                         (setq v (trans (cdr (assoc 'V-START x)) boundary-ent 0))
                                         (list (car v) (cadr v) 0.0)
                                       )
                                       *segment-list*))

             (foreach seg-data *segment-list*
               (foreach s-item (cdr (assoc 'SUPPORT-LIST seg-data))
                 (if (wcmatch (car s-item) "버팀보*")
                   (progn
                     (princ (strcat "\n[버팀보 확인] 이름: " (nth 1 s-item) " 데이터 로드 중..."))
                     (setq s-shape      (if (> (length s-item) 2) (nth 2 s-item) "H형강"))
                     (setq s-sec-str    (if (> (length s-item) 6) (nth 6 s-item) ""))
                     (setq s-jack-type  (if (> (length s-item) 7) (nth 7 s-item) ""))
                     (setq s-manual-pts (if (> (length s-item) 8) (nth 8 s-item) nil))

                     (if s-manual-pts
                       (princ (strcat "\n  -> 수집된 점 데이터 개수: " (itoa (length s-manual-pts))))
                       (princ "\n  -> 수집된 점 데이터가 없습니다 (nil).")
                     )

                     (if (and s-manual-pts (>= (length s-manual-pts) 1))
                       (progn
                         (setq remapped-pts '())
                         (foreach p s-manual-pts
                           (setq p-on-curve (vl-catch-all-apply 'vlax-curve-getClosestPointTo (list vla-bnd p)))
                           (if (not (vl-catch-all-error-p p-on-curve))
                             (setq d (vl-catch-all-apply 'vlax-curve-getdistatpoint (list vla-bnd p-on-curve)))
                             (setq d nil)
                           )
                           (if (or (vl-catch-all-error-p d) (null d)) (setq d 0.0))
                           (if (> d total-len) (setq d total-len))
                           (setq new-pt (vlax-curve-getpointatdist vla-bnd d))
                           (setq remapped-pts (cons new-pt remapped-pts))
                         )
                         (setq remapped-pts (reverse remapped-pts))
                         (princ (strcat "\n  -> 경계선 좌표 매핑 성공. 총 " (itoa (length remapped-pts)) "개의 기준점에서 레이저 투사 시작."))

                         (setq draw-count 0)
                         (foreach bp remapped-pts
                           (setq min-dist 1e99 seg-idx1 0 i 0 best-seg1 nil)
                           (foreach seg *segment-list*
                             (setq p1 (cdr (assoc 'V-START seg)))
                             (setq p2 (cdr (assoc 'V-END seg)))
                             (setq d (abs (- (+ (distance p1 bp) (distance bp p2)) (distance p1 p2))))
                             (if (< d min-dist)
                               (progn (setq min-dist d seg-idx1 i best-seg1 seg))
                             )
                             (setq i (1+ i))
                           )

                           (setq p-base-flat (list (car bp) (cadr bp) 0.0))
                           (setq p1 (trans (cdr (assoc 'V-START best-seg1)) boundary-ent 0))
                           (setq p2 (trans (cdr (assoc 'V-END best-seg1)) boundary-ent 0))
                           (setq p1 (list (car p1) (cadr p1) 0.0))
                           (setq p2 (list (car p2) (cadr p2) 0.0))

                           (setq tang-ang (angle p1 p2))
                           (setq norm-ang1 (+ tang-ang (/ pi 2.0)))
                           (setq norm-ang2 (- tang-ang (/ pi 2.0)))

                           (setq p-ray1 (polar p-base-flat norm-ang1 1e6))
                           (setq p-ray2 (polar p-base-flat norm-ang2 1e6))

                           (setq pts '() i 0)
                           (foreach seg *segment-list*
                             (setq sp1 (trans (cdr (assoc 'V-START seg)) boundary-ent 0))
                             (setq sp2 (trans (cdr (assoc 'V-END seg)) boundary-ent 0))
                             (setq sp1-flat (list (car sp1) (cadr sp1) 0.0))
                             (setq sp2-flat (list (car sp2) (cadr sp2) 0.0))

                             (setq int-pt1 (inters p-base-flat p-ray1 sp1-flat sp2-flat T))
                             (setq int-pt2 (inters p-base-flat p-ray2 sp1-flat sp2-flat T))

                             (if (and int-pt1 (> (distance p-base-flat int-pt1) 10.0))
                               (setq pts (cons (list int-pt1 i norm-ang1) pts))
                             )
                             (if (and int-pt2 (> (distance p-base-flat int-pt2) 10.0))
                               (setq pts (cons (list int-pt2 i norm-ang2) pts))
                             )
                             (setq i (1+ i))
                           )
                           (setq pts (reverse pts))

                           (setq valid-pts '())
                           (foreach pt-data pts
                             (setq int-pt (car pt-data))
                             (setq mid-pt (list (/ (+ (car p-base-flat) (car int-pt)) 2.0) (/ (+ (cadr p-base-flat) (cadr int-pt)) 2.0) 0.0))
                             (if (tsp-is-point-inside mid-pt poly-verts)
                               (setq valid-pts (cons pt-data valid-pts))
                             )
                           )
                           (setq valid-pts (reverse valid-pts))

                           (if valid-pts
                             (progn
                               (setq valid-pts (vl-sort valid-pts '(lambda (a b) (< (distance p-base-flat (car a)) (distance p-base-flat (car b))))))
                               (setq p-opp (car (car valid-pts)))
                               (setq seg-idx2 (cadr (car valid-pts)))
                               (setq norm-ang (caddr (car valid-pts)))

                               (setq offset1 (tsp-get-wale-offset (nth seg-idx1 *segment-list*)))
                               (setq offset2 (tsp-get-wale-offset (nth seg-idx2 *segment-list*)))

                               (if (> (distance bp p-opp) (+ offset1 offset2))
                                 (progn
                                   (setq pt1-draw (polar bp norm-ang offset1))
                                   (setq pt2-draw (polar p-opp (+ norm-ang pi) offset2))

                                   (if (wcmatch s-shape "H형강")
                                     (progn
                                       ;; 1. 개수를 파악하여 2H 맞버팀대 여부(is-double) 결정
                                       (setq s-count (if (> (length s-item) 4) (nth 4 s-item) 1))
                                       (setq is-double (if (>= s-count 2) T nil))
                                       ;; 2. 보강재 및 중간말뚝 옵션 추출
                                       (setq s-brace-opt (if (> (length s-item) 11) (nth 11 s-item) nil))
                                       ;; 3. 현재 작도 기준점이 속한 세그먼트의 고유 ID 추출
                                       (setq cur-seg-id (cdr (assoc 'ID best-seg1)))
                                       ;; _mpoint 레이어 POINT 객체 생성
                                       (create-layer-if-not-exists "_mpoint" "2")
                                       (entmake (list '(0 . "POINT") '(100 . "AcDbEntity") '(100 . "AcDbPoint") (cons 8 "_mpoint") (cons 62 2) (list 10 (car pt1-draw) (cadr pt1-draw) 0.0)))
                                       (entmake (list '(0 . "POINT") '(100 . "AcDbEntity") '(100 . "AcDbPoint") (cons 8 "_mpoint") (cons 62 2) (list 10 (car pt2-draw) (cadr pt2-draw) 0.0)))
                                       ;; 7개의 인수를 모두 전달하여 버팀보 및 부속물 통합 작도
                                       (tsp-draw-manual-strut pt1-draw pt2-draw s-sec-str s-jack-type is-double s-brace-opt cur-seg-id)
                                       (setq draw-count (1+ draw-count))
                                     )
                                   )
                                 )
                               )
                             )
                           )
                         ) ;; foreach bp end
                         (princ (strcat "\n  -> [최종 완료] 도면에 작도된 버팀보 묶음 개수: " (itoa draw-count)))
                       )
                     )
                   )
                 )
               )
             )
           )
         )

         ;; 6. 사보강재, 띠장, 번호표 통합 작도
         (princ "\n[작도] 사보강재(Corner Brace) 생성 중...")
         (tsp-draw-all-corner-braces boundary-ent boundary-orient)

         (princ "\n[작도] 띠장(Wale) 생성 중...")
         (create-wale-offsets boundary-ent boundary-orient)

         (if *segment-list*
           (progn
             (setq vertices (mapcar '(lambda (item) (cdr (assoc 'V-START item))) *segment-list*))
             (if (not (is-closed-polyline boundary-ent))
               (setq vertices (append vertices (list (cdr (assoc 'V-END (last *segment-list*))))))
             )
             (draw-segment-numbers boundary-ent boundary-orient vertices)
             (draw-corner-numbers boundary-ent boundary-orient vertices)
           )
         )
      ) ; lambda 종료
    ) ; catch-all-apply 종료
  ) ; setq 종료

  ;; =======================================================================
  ;; 7. [핵심] 무슨 일이 있어도 그룹화는 무조건 실행시켜 고아 객체 발생 차단
  ;; =======================================================================
  (tsp-group-last-entities last-ent boundary-ent)
  (command "._DRAWORDER" boundary-ent "" "_F")
  
  ;; 8. 내부에서 충돌(Crash)이 발생했다면, 커맨드창에 붉은 글로 에러 내용 보고
  (if (vl-catch-all-error-p draw-result)
    (princ (strcat "\n[에러 알림] 버팀보 작도 중 내부 충돌이 발생했습니다. (객체 추적은 정상 보존됨)\n상세 원인: " (vl-catch-all-error-message draw-result)))
    (princ "\n평면도 생성 및 갱신 완료.")
  )
)

;;;;==========================================================================
;;;; defun tsp-ceil :  숫자 올림 보조 함수 (LISP 기본 기능 보완)
;;;;==========================================================================
(defun tsp-ceil (val)
  (if (= (type val) 'INT)
    val
    (if (= val (float (fix val)))
      (fix val)
      (1+ (fix val))
    )
  )
)
;;;; defun tsp-create-cip-guideline : 외측 방향을 고려한 D/2 오프셋 보조선 생성


;;;;==========================================================================
;;;; defun tsp-create-cip-guideline : 외측 방향을 고려한 D/2 오프셋 보조선 생성 (검증오류 픽스)
;;;;==========================================================================
(defun tsp-create-cip-guideline (boundary-ent dia boundary-orient is-closed / vobj d start-pt p2 seg-angle out-norm target-pt off-obj off-ent closest-pt)
  (setq vobj (vlax-ename->vla-object boundary-ent))
  ;; dia가 문자열인지 숫자인지 판별하여 안전하게 처리 (에러 방지)
  (setq d (/ (if (= (type dia) 'STR) (atof dia) dia) 2.0))
  ;; H-Pile 로직에서 추출한 완벽한 외측 벡터 계산 (안팎 판별 오류 방지)
  (setq start-pt (vlax-curve-getStartPoint vobj))
  (setq p2 (vlax-curve-getPointAtParam vobj 1.0))
  (setq seg-angle (angle start-pt p2))
  (setq out-norm (+ seg-angle (* boundary-orient (/ pi 2.0))))
  ;; H-Pile과 완벽히 동일한 방식: 바깥쪽(흙 방향)을 향하도록 마이너스(-d) 적용
  (setq target-pt (polar start-pt out-norm (- d)))
  ;; 양수 거리로 오프셋 후, 수학적으로 계산된 target-pt와 일치하는지 교차 검증
  (setq off-obj (vl-catch-all-apply 'vla-offset (list vobj d)))
  (if (not (vl-catch-all-error-p off-obj))
    (progn
      (setq off-ent (vlax-vla-object->ename (vlax-safearray-get-element (vlax-variant-value off-obj) 0)))
      ;; 오프셋선 방향이 강제 반전되었을 때 시작점(off-start)이 달라지는 현상을 막기 위해,
      ;; target-pt와 가장 가까운 실제 폴리선 상의 점(closest-pt)을 도출하여 검증합니다.
      (setq closest-pt (vlax-curve-getClosestPointTo (vlax-ename->vla-object off-ent) target-pt))
      (if (> (distance (list (car target-pt) (cadr target-pt)) (list (car closest-pt) (cadr closest-pt))) 0.1)
        (progn
          (entdel off-ent)
          (setq off-obj (vl-catch-all-apply 'vla-offset (list vobj (- d))))
          (if (not (vl-catch-all-error-p off-obj))
            (setq off-ent (vlax-vla-object->ename (vlax-safearray-get-element (vlax-variant-value off-obj) 0)))
            (setq off-ent nil)
          )
        )
      )
      off-ent
    )
    nil
  )
)
;;;; defun tsp-calc-cip-layout : C.I.P 배열 중심점 및 간격 계산 (양끝 고정, 내부 균등 분배)


;;;;==========================================================================
;;;; defun tsp-calc-cip-layout : 경계선(곡선)을 따라 C.I.P 중심점 배열 및 간격 계산
;;;;==========================================================================
(defun tsp-calc-cip-layout (curve-ent is-closed dia mode overlap / total-length target-pitch count actual-pitch i dist check-dist pt ang deriv centers next-dist)
  (setq total-length (vlax-curve-getdistatparam curve-ent (vlax-curve-getendparam curve-ent)))
  (setq target-pitch (if (= mode "0") dia (- dia overlap))) ; 0: 맞닿음(Tangent), 1: 겹침(Secant)
  
  ;; 폐합 여부에 따라 실제 배치 간격(actual-pitch)을 균등 분배하여 재계산
  (if is-closed
    (progn
      ;; 총 길이를 타겟 간격으로 나누고 반올림(0.5 더한 후 fix)하여 정확한 배치 개수 도출
      (setq count (fix (+ (/ total-length target-pitch) 0.5)))
      ;; 자투리 길이를 분산시킨 완벽한 간격 재계산
      (setq actual-pitch (/ total-length count))
    )
    (progn
      ;; 열린 경계선은 기존의 타겟 간격을 그대로 사용
      (setq actual-pitch target-pitch)
    )
  )
  
  (setq centers '())

  (if is-closed
    (progn
      ;; 닫힌 경계 (Closed boundary)
      (setq dist 0.0)
      (setq i 0)
      ;; 무한 루프나 겹침 초과를 방지하기 위해 계산된 count까지만 배열하도록 조건(< i count) 추가
      (while (and dist (< dist total-length) (< i count))
        (setq pt (vlax-curve-getpointatdist curve-ent dist))
        ;; 꼭짓점 접선각 오류 방지를 위한 미세 보정 (eps = 1e-6)
        (setq check-dist (+ dist 1e-6))
        (if (> check-dist total-length)
          (setq check-dist (- dist 1e-6))
        )
        (setq deriv (vlax-curve-getfirstderiv curve-ent (vlax-curve-getparamatdist curve-ent check-dist)))
        (setq ang (angle '(0 0 0) deriv))
        
        ;; [Phase 1] cons 최적화
        (setq centers (cons (list i dist pt ang) centers))
        
        ;; 다음 C.I.P 중심점 찾기 (균등 분배된 'actual-pitch' 기준 현의 길이 탐색)
        (setq next-dist (tsp-find-next-dist-by-chord curve-ent dist actual-pitch total-length))
        (setq dist next-dist)
        (setq i (1+ i))
      )
      (setq count i)
    )
    (progn
      ;; 열린 경계 (Open boundary)
      (setq dist (/ dia 2.0)) ; 양끝 D/2 보정 적용
      (setq i 0)
      (while (and dist (<= dist (- total-length (/ dia 2.0))))
        (setq pt (vlax-curve-getpointatdist curve-ent dist))
        ;; 꼭짓점 접선각 오류 방지를 위한 미세 보정 (eps = 1e-6)
        (setq check-dist (+ dist 1e-6))
        (if (> check-dist total-length)
          (setq check-dist (- dist 1e-6))
        )
        (setq deriv (vlax-curve-getfirstderiv curve-ent (vlax-curve-getparamatdist curve-ent check-dist)))
        (setq ang (angle '(0 0 0) deriv))
        
        ;; [Phase 1] cons 최적화
        (setq centers (cons (list i dist pt ang) centers))
        
        ;; 다음 C.I.P 중심점 찾기 (열린 구간은 타겟 간격과 동일한 'actual-pitch' 적용)
        (setq next-dist (tsp-find-next-dist-by-chord curve-ent dist actual-pitch total-length))
        (setq dist next-dist)
        (setq i (1+ i))
      )
      (setq count i)
    )
  )

  ;; [Phase 1] 뒤집기 완료
  (setq centers (reverse centers))

  (list
    (cons 'MODE (if is-closed "CLOSED" "OPEN"))
    (cons 'COUNT count)
    (cons 'ACTUAL-PITCH actual-pitch)
    (cons 'ITEMS centers)
  )
)


;;;;==========================================================================
;;;; defun tsp-draw-cip-elements : C.I.P 배열 요소를 작도하고, 브래킷을 생성하는 함수
;;;;==========================================================================
(defun tsp-draw-cip-elements (layout dia interval-idx hpile-idx boundary-orient / interval items hpile-spec-name hpile-vals h b tw tf hpile-block idx dist pt ang outward-normal hpile-rotation insert-pt half-h-offset in-norm p-start-center p-end-center p1 p2 p3 p4 br-layer br-color br-pl hatch-obj mspace doc sa err-eval old-hpannotative old-meas err-hatch)

  (defun draw-bracket-poly (pts layer color / lst ent)
    (setq lst (list '(0 . "LWPOLYLINE") '(100 . "AcDbEntity") '(100 . "AcDbPolyline")
                    (cons 8 layer) (cons 62 color) (cons 90 (length pts)) '(70 . 1)))
    (foreach p pts (setq lst (append lst (list (list 10 (car p) (cadr p))))))
    (setq ent (entmakex lst))
    (if (not ent)
      (progn
        (setq lst (subst (cons 8 (getvar "CLAYER")) (assoc 8 lst) lst))
        (setq ent (entmakex lst))
      )
    )
    ent
  )

  (setq interval (cond ((= interval-idx "1") 2) ((= interval-idx "2") 3) (t 1)))
  (setq items (cdr (assoc 'ITEMS layout)))
  
  (setq hpile-spec-name (nth (atoi hpile-idx) *tsp-std-wall-list*))
  (setq hpile-vals (parse-h-spec hpile-spec-name))
  (setq h (nth 0 hpile-vals) b (nth 1 hpile-vals) tw (nth 2 hpile-vals) tf (nth 3 hpile-vals))
  
  (setq hpile-block (create-hpile-section-block h b tw tf))
  
  (create-layer-if-not-exists "_CIP" "2")
  (setq br-layer "_브래킷(bracket)")
  (setq br-color 8)
  (create-layer-if-not-exists br-layer (itoa br-color))

  (setq doc (vla-get-activedocument (vlax-get-acad-object)))
  (if (= (getvar "CVPORT") 1)
    (setq mspace (vla-get-paperspace doc))
    (setq mspace (vla-get-modelspace doc))
  )

  (foreach item items
    (setq idx (nth 0 item) dist (nth 1 item) pt (nth 2 item) ang (nth 3 item))
    
    (entmake (list '(0 . "CIRCLE") (cons 8 "_CIP") (list 10 (car pt) (cadr pt) 0.0) (cons 40 (/ (if (= (type dia) 'STR) (atof dia) dia) 2.0))))
    
    (if (= (rem idx interval) 0)
      (progn
        (setq outward-normal (+ ang (* boundary-orient (/ pi 2.0))))
        (setq hpile-rotation (+ outward-normal (/ pi 2.0)))
        (setq half-h-offset (/ (if (= (type h) 'STR) (atof h) h) 2.0))
        (setq insert-pt (polar pt outward-normal half-h-offset))
        (entmake (list '(0 . "INSERT") (cons 2 hpile-block) '(8 . "_측면말뚝") (list 10 (car insert-pt) (cadr insert-pt) 0.0) '(41 . 1.0) '(42 . 1.0) '(43 . 1.0) (cons 50 hpile-rotation)))
        
        (setq err-eval (vl-catch-all-apply '> (list dia h)))
        
        (if (not (vl-catch-all-error-p err-eval))
          (if err-eval
            (progn
              ;; 띠장 방향 계산
              (setq in-norm outward-normal) 
              (setq p-start-center (polar pt in-norm (/ h 2.0)))
              (setq p-end-center (polar pt in-norm (/ dia 2.0)))
              (setq p1 (polar p-start-center (+ in-norm (/ pi 2.0)) (/ b 2.0)))
              (setq p2 (polar p-end-center (+ in-norm (/ pi 2.0)) (/ b 2.0)))
              (setq p3 (polar p-end-center (- in-norm (/ pi 2.0)) (/ b 2.0)))
              (setq p4 (polar p-start-center (- in-norm (/ pi 2.0)) (/ b 2.0)))
              
              (setq br-pl (draw-bracket-poly (list p1 p2 p3 p4) br-layer br-color))
              (if br-pl
                (progn
                  (setq old-hpannotative (getvar "HPANNOTATIVE"))
                  (if old-hpannotative (setvar "HPANNOTATIVE" 0))

                  (setq err-hatch (vl-catch-all-apply 'vla-addhatch (list mspace 0 "ANSI31" :vlax-true)))
                  (if (not (vl-catch-all-error-p err-hatch))
                    (progn
                      (setq hatch-obj err-hatch)
                      (vl-catch-all-apply 'vla-put-patternscale (list hatch-obj (if (= (getvar "MEASUREMENT") 0) 400.0 20.0)))
                      (vl-catch-all-apply 'vla-put-layer (list hatch-obj br-layer))
                      (vl-catch-all-apply 'vla-put-color (list hatch-obj br-color))
                      (setq sa (vlax-make-safearray 9 (cons 0 0)))
                      (vlax-safearray-fill sa (list (vlax-ename->vla-object br-pl)))
                      (vl-catch-all-apply 'vla-appendouterloop (list hatch-obj sa))
                      (vl-catch-all-apply 'vla-evaluate (list hatch-obj))
                    )
                  )

                  (if old-hpannotative (setvar "HPANNOTATIVE" old-hpannotative))
                )
              )
            )
          )
        )
      )
    )
  )
  (princ)
)


;;;;==========================================================================
;;;; defun tsp-acos : 아크코사인 함수 (수학 연산 지원)
;;;;==========================================================================
(defun tsp-acos (x)
  (cond
    ((>= x 1.0) 0.0)
    ((<= x -1.0) pi)
    (t (atan (sqrt (- 1.0 (* x x))) x))
  )
)

;;;;==========================================================================
;;;; defun tsp-normalize-angle : 각도를 0 ~ 2pi 사이로 정규화
;;;;==========================================================================
(defun tsp-normalize-angle (a)
  (while (>= a (* 2.0 pi)) (setq a (- a (* 2.0 pi))))
  (while (< a 0.0) (setq a (+ a (* 2.0 pi))))
  a
)

;;;;==========================================================================
;;;; defun tsp-ang-dist : 두 각도의 차이(최단거리) 산출
;;;;==========================================================================
(defun tsp-ang-dist (a b / d)
  (setq d (abs (- a b)))
  (if (> d pi) (- (* 2.0 pi) d) d)
)

;;;;==========================================================================
;;;; defun get-grouting-arc-angles : 그라우팅 원과 CIP 원의 겹침을 잘라내기 위한 시작/끝 각도 산출
;;;;==========================================================================
(defun get-grouting-arc-angles (G C1 C2 R_G R_C out-norm / d1 d2 theta1 theta2 a1 a2 a1A a1B a2A a2B E S diff1A diff1B diff2A diff2B S-out S-E)
  (setq d1 (distance G C1) d2 (distance G C2))
  (setq S nil E nil)
  (if (and (< d2 (+ R_G R_C)) (> d2 (abs (- R_G R_C))))
    (progn
      (setq theta2 (tsp-acos (/ (+ (* R_G R_G) (* d2 d2) (- (* R_C R_C))) (* 2.0 R_G d2))))
      (setq a2 (angle G C2))
      (setq a2A (tsp-normalize-angle (+ a2 theta2)))
      (setq a2B (tsp-normalize-angle (- a2 theta2)))
      (setq diff2A (tsp-ang-dist a2A out-norm))
      (setq diff2B (tsp-ang-dist a2B out-norm))
      (if (< diff2A diff2B) (setq S a2A) (setq S a2B))
    )
  )
  (if (and (< d1 (+ R_G R_C)) (> d1 (abs (- R_G R_C))))
    (progn
      (setq theta1 (tsp-acos (/ (+ (* R_G R_G) (* d1 d1) (- (* R_C R_C))) (* 2.0 R_G d1))))
      (setq a1 (angle G C1))
      (setq a1A (tsp-normalize-angle (+ a1 theta1)))
      (setq a1B (tsp-normalize-angle (- a1 theta1)))
      (setq diff1A (tsp-ang-dist a1A out-norm))
      (setq diff1B (tsp-ang-dist a1B out-norm))
      (if (< diff1A diff1B) (setq E a1A) (setq E a1B))
    )
  )
  (if (and S E)
    (progn
      (setq S-out (tsp-normalize-angle (- out-norm S)))
      (setq S-E (tsp-normalize-angle (- E S)))
      (if (<= S-out S-E)
        (list S E)
        (list E S)
      )
    )
    nil
  )
)

;;;;==========================================================================
;;;; defun tsp-draw-grouting : 지정된 두 CIP 원 사이에 그라우팅 원 및 호(Arc) 작도
;;;;==========================================================================
(defun tsp-draw-grouting (C1 C2 cip-d grouting-dia boundary-orient / G-mid seg-ang G-out-norm R_C G R_G arc-angles)
  (setq G-mid (list (/ (+ (car C1) (car C2)) 2.0) (/ (+ (cadr C1) (cadr C2)) 2.0) 0.0))
  (setq seg-ang (angle C1 C2))
  ;; 부호를 (-)로 변경하여 띠장(굴착면)의 반대편인 배면 방향으로 직각 교차점 산출
  (setq G-out-norm (- seg-ang (* boundary-orient (/ pi 2.0))))
  (setq R_C (/ cip-d 2.0))
  (setq G (polar G-mid G-out-norm R_C))
  (setq R_G (/ grouting-dia 2.0))
  (create-layer-if-not-exists "_그라우팅" "5")
  (setq arc-angles (get-grouting-arc-angles G C1 C2 R_G R_C G-out-norm))
  (if arc-angles
    (entmake (list '(0 . "ARC") (cons 8 "_그라우팅") (cons 62 5) (cons 10 G) (cons 40 R_G) (cons 50 (car arc-angles)) (cons 51 (cadr arc-angles))))
    (entmake (list '(0 . "CIRCLE") (cons 8 "_그라우팅") (cons 62 5) (cons 10 G) (cons 40 R_G)))
  )
  (if (= grouting-dia 600.0)
    (entmake (list '(0 . "CIRCLE") (cons 8 "_그라우팅") (cons 62 5) (cons 10 G) (cons 40 25.0)))
  )
)

;;;;==========================================================================
;;;; defun tsp-draw-cip-plan-per-segment : 세그먼트별 연속 CIP 작도 및 브래킷 통합
;;;;==========================================================================
(defun tsp-draw-cip-plan-per-segment (boundary-ent boundary-orient / is-closed orig-vertices n-verts max-segs seg-idx seg-data seg-wall-type chain-pts j next-data next-type stop-chain end-pt save-dia save-mode save-overlap save-interval save-hpile-idx temp-pl vla-pl test-pt vla-offset-list vla-path d wall-dist out-norm hpile-vals h b cip-ctc max-path-len num-verts k dist-start dist-end start-d end-d effective-len num-intervals actual-dist i curr-dist curr-pt param deriv ang interval hpile-block ins-pt hpile-rot seg-hpile-count doc mspace br-layer br-color num-dia num-h num-b h-scale err-catch p-start-center p-end-center p1 p2 p3 p4 br-pl hatch-obj sa save-equal-divide save-grouting grouting-dia old-offsetgap p-orig-start p-path-0 p-path-1 ang-b-start dist-a-start ang-a-start path-origin-dist p-orig-end end-param p-path-last p-path-prev ang-b-end dist-a-end ang-a-end end-shift path-end-dist full-loop sim-dist sim-count prev-sim-dist chain-end-dist d-wrap next-sim err-over err-under num-gaps dist-list d-acc d-raw-list n-dist-raw n-dist last-raw-d total-error raw-pts wrap-d pt adj-indices idx v pt-prev pt-curr dist-prev next-d next-adj curr-adj wrap-dist prev-cip-pt first-cip-pt pt-on-orig orig-param target-k target-index total-counted-in-list v-idx init-val delta max-anchor-L max-anchor-ang max-anchor-free max-anchor-bond has-anchor cip-wale-spec cip-wale-vals cip-wale-h prev-hpile-raw-dist anchor-raw-dist anchor-d-wrap over-dist end-pt-path end-param-path anchor-pt anchor-out-norm cur-brace next-brace next-seg-real-idx dist-to-start dist-to-end brace-blocked chk-last-b-row chk-b-custom chk-b-dist chk-b-h chk-margin cos-val proj-free proj-bond proj-prot pt-base pt-free-end pt-bond-end pt-h1 pt-h2 pt-h3 pt-h4 pt-anchor-start s-item cur-free cur-bond cur-ang cur-L cur-support-list pt-on-orig-anch orig-param-anch target-k-anch target-index-anch cur-vertex-anch next-vertex-anch)
  
  ;; [보조 함수] 닫힌 폴리라인 강제 생성
  (defun draw-bracket-poly (pts layer color / lst ent)
    (setq lst (list '(0 . "LWPOLYLINE") '(100 . "AcDbEntity") '(100 . "AcDbPolyline")
                    (cons 8 layer) (cons 62 color) (cons 90 (length pts)) '(70 . 1)))
    (foreach p pts (setq lst (append lst (list (list 10 (car p) (cadr p))))))
    (setq ent (entmakex lst))
    (if (not ent)
      (progn
        (setq lst (subst (cons 8 (getvar "CLAYER")) (assoc 8 lst) lst))
        (setq ent (entmakex lst))
      )
    )
    ent
  )

  ;; COM 객체용 공간 및 레이어 설정 (브래킷용)
  (setq doc (vla-get-activedocument (vlax-get-acad-object)))
  (if (= (getvar "CVPORT") 1)
    (setq mspace (vla-get-paperspace doc))
    (setq mspace (vla-get-modelspace doc))
  )
  (setq br-layer "_브래킷(bracket)")
  (setq br-color 8)
  (create-layer-if-not-exists br-layer (itoa br-color))

  (setq is-closed (is-closed-polyline boundary-ent))
  (setq orig-vertices (mapcar '(lambda (s) (cdr (assoc 'V-START s))) *segment-list*))  
  (setq *tsp-actual-drawn-hpiles* 0)
  (if (not is-closed)
    (setq orig-vertices (append orig-vertices (list (cdr (assoc 'V-END (last *segment-list*))))))
  )
  (setq n-verts (length orig-vertices))
  (setq max-segs (if is-closed n-verts (1- n-verts)))
  
  (setq seg-idx 0)
  (while (< seg-idx max-segs)
    (setq seg-data (nth seg-idx *segment-list*))
    (setq seg-wall-type (cdr (assoc 'WALL-TYPE seg-data)))
    
    (if (and (= seg-wall-type "CIP") (cdr (assoc 'IS-DEFINED seg-data)))
      (progn
        ;; 1. 연속된 CIP 세그먼트 찾기 (체인 형성)
        (setq chain-pts (list (nth seg-idx orig-vertices)))
        (setq j (1+ seg-idx))
        (setq stop-chain nil)
        
        (while (and (< j max-segs) (not stop-chain))
          (setq next-data (nth j *segment-list*))
          (setq next-type (cdr (assoc 'WALL-TYPE next-data)))
          (if (and (= next-type "CIP") (cdr (assoc 'IS-DEFINED next-data)))
            (progn
              (setq chain-pts (append chain-pts (list (nth j orig-vertices))))
              (setq j (1+ j))
            )
            (setq stop-chain T)
          )
        )
        ;; 체인의 마지막 끝점 안전하게 추가
        (setq end-pt (nth j orig-vertices))
        (if (not end-pt) (setq end-pt (nth 0 orig-vertices)))
        (setq chain-pts (append chain-pts (list end-pt)))
        
        ;; 2. 세그먼트 파라미터 로드
        (setq save-dia *tsp-cip-dia*
              save-mode *tsp-cip-mode-idx*
              save-overlap *tsp-cip-overlap*
              save-equal-divide *tsp-cip-equal-divide*
              save-interval *tsp-cip-interval-idx*
              save-hpile-idx *tsp-cip-hpile-idx*
              save-grouting *tsp-cip-grouting-idx*)
        (setq *tsp-cip-dia* (cdr (assoc 'CIP-DIA seg-data)))
        (setq *tsp-cip-mode-idx* (cdr (assoc 'CIP-MODE-IDX seg-data)))
        (setq *tsp-cip-overlap* (cdr (assoc 'CIP-OVERLAP seg-data)))
        (setq *tsp-cip-equal-divide* (if (assoc 'CIP-EQUAL-DIVIDE seg-data) (cdr (assoc 'CIP-EQUAL-DIVIDE seg-data)) "0"))
        (setq *tsp-cip-interval-idx* (cdr (assoc 'CIP-INTERVAL-IDX seg-data)))
        (setq *tsp-cip-hpile-idx* (cdr (assoc 'CIP-HPILE-IDX seg-data)))
        (setq *tsp-cip-grouting-idx* (cdr (assoc 'CIP-GROUTING-IDX seg-data)))
        (setq grouting-dia (if (= *tsp-cip-grouting-idx* "1") 600.0 200.0))
        
        (setq d (atof *tsp-cip-dia*))
        (setq wall-dist (/ d 2.0))
        (setq cip-ctc (if (= *tsp-cip-mode-idx* "0") d (- d (atof *tsp-cip-overlap*))))
        (setq hpile-vals (parse-h-spec (nth (atoi *tsp-cip-hpile-idx*) *tsp-std-wall-list*)))
        (setq h (nth 0 hpile-vals) b (nth 1 hpile-vals))
        (setq hpile-block (create-hpile-section-block h b (nth 2 hpile-vals) (nth 3 hpile-vals)))
        (setq interval (cond ((= *tsp-cip-interval-idx* "1") 2) ((= *tsp-cip-interval-idx* "2") 3) (t 1)))

        ;; 3. 임시 연속 폴리선 생성 및 오프셋
        (setq temp-pl (entmakex (append (list '(0 . "LWPOLYLINE") '(100 . "AcDbEntity") '(100 . "AcDbPolyline") 
                                              (cons 90 (length chain-pts)) '(70 . 0))
                                        (mapcar '(lambda (p) (list 10 (car p) (cadr p))) chain-pts))))
        (setq vla-pl (vlax-ename->vla-object temp-pl))
        
        (setq out-norm (+ (angle (nth 0 chain-pts) (nth 1 chain-pts)) (* boundary-orient (/ pi 2.0))))
        (setq test-pt (polar (nth 0 chain-pts) out-norm (- wall-dist)))
        
        (setq old-offsetgap (getvar "OFFSETGAPTYPE"))
        (setvar "OFFSETGAPTYPE" 1)

        (setq vla-offset-list (vl-catch-all-apply 'vla-offset (list vla-pl wall-dist)))
        (if (not (vl-catch-all-error-p vla-offset-list))
          (progn
            (setq vla-path (vlax-safearray-get-element (vlax-variant-value vla-offset-list) 0))
            (if (> (distance (list (car test-pt) (cadr test-pt)) 
                             (list (car (vlax-curve-getStartPoint vla-path)) (cadr (vlax-curve-getStartPoint vla-path)))) 0.1)
              (progn
                (vla-delete vla-path)
                (setq vla-path (vlax-safearray-get-element (vlax-variant-value (vla-offset vla-pl (- wall-dist))) 0))
              )
            )
            (setvar "OFFSETGAPTYPE" old-offsetgap)
            
            ;; 4. 연속 선형 기반 CIP 및 H-Pile 배열
            (setq max-path-len (vlax-curve-getdistatparam vla-path (vlax-curve-getendparam vla-path)))
            (setq num-verts (1+ (fix (vlax-curve-getendparam vla-path))))
            (create-layer-if-not-exists "_CIP" "2")
            
            (setq k 0)
            (while (< k (- num-verts 1))
              (setq init-val (if (and (= seg-idx 0) (= k 0)) 1 0))
              (setq *tsp-segment-pile-counts* (update-list-item *tsp-segment-pile-counts* (+ seg-idx k) init-val))
              (setq k (1+ k))
            )
            
            ;; 오프셋 보정
            (setq p-orig-start (nth 0 chain-pts))
            (setq p-path-0 (vlax-curve-getPointAtParam vla-path 0.0))
            (setq p-path-1 (vlax-curve-getPointAtParam vla-path 1.0))
            
            (setq ang-b-start (angle p-path-0 p-path-1))
            (setq dist-a-start (distance p-path-0 p-orig-start))
            (setq ang-a-start (angle p-path-0 p-orig-start))
            
            (setq path-origin-dist (* dist-a-start (cos (- ang-a-start ang-b-start))))
            (if (< path-origin-dist 0.0) (setq path-origin-dist 0.0))
            
            (setq start-d (+ path-origin-dist (/ b 2.0)))

            (setq p-orig-end (last chain-pts))
            (setq end-param (vlax-curve-getEndParam vla-path))
            (setq p-path-last (vlax-curve-getPointAtParam vla-path end-param))
            (setq p-path-prev (vlax-curve-getPointAtParam vla-path (1- end-param)))
            
            (setq ang-b-end (angle p-path-prev p-path-last))
            (setq dist-a-end (distance p-path-last p-orig-end))
            (setq ang-a-end (angle p-path-last p-orig-end))
            
            (setq end-shift (* dist-a-end (cos (- ang-a-end (+ ang-b-end pi)))))
            (if (< end-shift 0.0) (setq end-shift 0.0))
            
            (setq path-end-dist (- max-path-len end-shift))
            (setq end-d (- path-end-dist (/ b 2.0)))
            
            (if (<= end-d start-d)
              (progn
                (setq start-d (/ b 2.0))
                (setq end-d (- max-path-len (/ b 2.0)))
              )
            )
            
            (setq effective-len (- end-d start-d))
            
            (setq full-loop (and is-closed (= (length chain-pts) (1+ max-segs))))
            (if full-loop
              (progn
                (setq effective-len max-path-len)
                (setq end-d (+ start-d max-path-len))
              )
            )
            
            (defun get-robust-chord-inc (path start-wrap chord-len max-len is-closed / p1 low high b-iter mid wrap-test p2-catch d-test)
              (setq p1 (vlax-curve-getpointatdist path start-wrap))
              (setq low chord-len high (* chord-len 1.5))
              (setq b-iter 0)
              (while (< b-iter 15)
                (setq mid (/ (+ low high) 2.0))
                (setq wrap-test (+ start-wrap mid))
                (if (and is-closed (> max-len 0.0)) (while (>= wrap-test max-len) (setq wrap-test (- wrap-test max-len))))
                (setq p2-catch (vl-catch-all-apply 'vlax-curve-getpointatdist (list path wrap-test)))
                (if (or (vl-catch-all-error-p p2-catch) (not p2-catch))
                  (setq high mid)
                  (progn
                    (setq d-test (distance (list (car p1) (cadr p1)) (list (car p2-catch) (cadr p2-catch))))
                    (if (< d-test chord-len) (setq low mid) (setq high mid))
                  )
                )
                (setq b-iter (1+ b-iter))
              )
              mid
            )

            (setq sim-dist start-d)
            (setq sim-count 0)
            (setq prev-sim-dist start-d)
            (setq chain-end-dist (if full-loop (+ start-d max-path-len) max-path-len))
            (while (< sim-dist chain-end-dist)
              (setq prev-sim-dist sim-dist)
              (setq d-wrap sim-dist)
              (if (> max-path-len 0.0) (while (>= d-wrap max-path-len) (setq d-wrap (- d-wrap max-path-len))))
              (setq next-sim (tsp-find-next-dist-by-chord vla-path d-wrap cip-ctc max-path-len))
              (if next-sim
                (setq sim-dist (+ sim-dist (- next-sim d-wrap)))
                (setq sim-dist (+ sim-dist (get-robust-chord-inc vla-path d-wrap cip-ctc max-path-len full-loop)))
              )
              (setq sim-count (1+ sim-count))
            )
            (setq err-over (- sim-dist chain-end-dist))
            (setq err-under (- chain-end-dist prev-sim-dist))
            (if (< err-under err-over)
              (setq num-gaps (1- sim-count))
              (setq num-gaps sim-count)
            )
            (if (< num-gaps 1) (setq num-gaps 1))
            
            (setq dist-list '())
            (setq chain-end-dist (if full-loop (+ start-d max-path-len) max-path-len))
            (setq d-acc start-d)
            (setq d-raw-list (list d-acc))
            
            (if full-loop
              (progn
                (while (< d-acc chain-end-dist)
                  (setq d-wrap d-acc)
                  (if (> max-path-len 0.0) (while (>= d-wrap max-path-len) (setq d-wrap (- d-wrap max-path-len))))
                  (setq n-dist-raw (tsp-find-next-dist-by-chord vla-path d-wrap cip-ctc max-path-len))
                  (if n-dist-raw
                    (setq n-dist (+ d-acc (- n-dist-raw d-wrap)))
                    (setq n-dist (+ d-acc (get-robust-chord-inc vla-path d-wrap cip-ctc max-path-len full-loop)))
                  )
                  (setq d-raw-list (append d-raw-list (list n-dist)))
                  (setq d-acc n-dist)
                )
                
                (setq last-raw-d (last d-raw-list))
                (setq total-error (- last-raw-d chain-end-dist))

                (setq raw-pts '())
                (foreach d-val d-raw-list
                  (setq wrap-d d-val)
                  (if (> max-path-len 0.0) (while (>= wrap-d max-path-len) (setq wrap-d (- wrap-d max-path-len))))
                  (if (< wrap-d 0.0) (setq wrap-d 0.0))
                  (setq pt (vlax-curve-getpointatdist vla-path wrap-d))
                  (setq raw-pts (append raw-pts (list pt)))
                )
                
                (setq adj-indices '())
                (foreach v orig-vertices
                  (setq idx 1)
                  (while (< idx (length raw-pts))
                    (setq pt-prev (nth (1- idx) raw-pts))
                    (setq pt-curr (nth idx raw-pts))
                    
                    (setq dist-prev (distance (list (car pt-prev) (cadr pt-prev)) (list (car v) (cadr v))))
                    (setq dist-curr (distance (list (car pt-curr) (cadr pt-curr)) (list (car v) (cadr v))))
                    
                    (if (and (<= dist-prev (+ d 1.0)) (<= dist-curr (+ d 1.0)))
                      (if (not (member idx adj-indices))
                        (setq adj-indices (append adj-indices (list idx)))
                      )
                    )
                    (setq idx (1+ idx))
                  )
                )

                (if (= (length adj-indices) 0)
                  (progn
                    (setq idx 1)
                    (while (< idx (length d-raw-list))
                      (setq adj-indices (append adj-indices (list idx)))
                      (setq idx (1+ idx))
                    )
                  )
                )

                (setq delta (/ total-error (float (length adj-indices))))
                
                (setq dist-list (list start-d))
                (setq curr-adj start-d)
                (setq idx 1)
                (while (< idx (length d-raw-list))
                  (setq d-wrap curr-adj)
                  (if (> max-path-len 0.0) (while (>= d-wrap max-path-len) (setq d-wrap (- d-wrap max-path-len))))
                  (setq n-dist-raw (tsp-find-next-dist-by-chord vla-path d-wrap cip-ctc max-path-len))
                  
                  (if n-dist-raw
                    (setq next-d (+ curr-adj (- n-dist-raw d-wrap)))
                    (setq next-d (+ curr-adj (get-robust-chord-inc vla-path d-wrap cip-ctc max-path-len full-loop)))
                  )
                  
                  (if (member idx adj-indices)
                    (setq next-adj (- next-d delta))
                    (setq next-adj next-d)
                  )
                  
                  (setq curr-adj next-adj)
                  (setq dist-list (append dist-list (list curr-adj)))
                  (setq idx (1+ idx))
                )
                
                (setq dist-list (reverse (cdr (reverse dist-list))))
                (setq dist-list (append dist-list (list chain-end-dist)))
              )
              (progn
                (while (< (+ d-acc wall-dist) chain-end-dist)
                  (setq d-wrap d-acc)
                  (setq n-dist-raw (tsp-find-next-dist-by-chord vla-path d-wrap cip-ctc max-path-len))
                  (if n-dist-raw
                    (setq n-dist (+ d-acc (- n-dist-raw d-wrap)))
                    (setq n-dist (+ d-acc (get-robust-chord-inc vla-path d-wrap cip-ctc max-path-len nil)))
                  )
                  (setq d-raw-list (append d-raw-list (list n-dist)))
                  (setq d-acc n-dist)
                )
                (setq dist-list d-raw-list)
              )
            )
            (setq num-gaps (1- (length dist-list)))

            ;; [2] 통합 작도 실행 루프 (앵커 포함)
            (setq i 0)
            (setq prev-cip-pt nil first-cip-pt nil)
            (setq prev-hpile-raw-dist nil)
            
            (foreach wrap-raw dist-list
              (setq wrap-dist wrap-raw)
              
              (if (and full-loop (> max-path-len 0.0))
                (while (>= wrap-dist max-path-len) (setq wrap-dist (- wrap-dist max-path-len)))
              )
              (if (< wrap-dist 0.0) (setq wrap-dist 0.0))

              (if (not (and full-loop (= i num-gaps)))
                (progn
                  (if (> wrap-dist max-path-len)
                    (progn
                      (setq over-dist (- wrap-dist max-path-len))
                      (setq end-pt-path (vlax-curve-getpointatdist vla-path max-path-len))
                      (setq end-param-path (vlax-curve-getendparam vla-path))
                      (setq deriv (vlax-curve-getfirstderiv vla-path end-param-path))
                      (setq ang (atan (cadr deriv) (car deriv)))
                      (setq curr-pt (polar end-pt-path ang over-dist))
                    )
                    (progn
                      (setq curr-pt (vlax-curve-getpointatdist vla-path wrap-dist))
                      (setq param (vlax-curve-getparamatdist vla-path wrap-dist))
                      (setq deriv (vlax-curve-getfirstderiv vla-path param))
                      (setq ang (atan (cadr deriv) (car deriv)))
                    )
                  )
                  
                  (setq pt-on-orig (vlax-curve-getClosestPointTo vla-pl curr-pt))
                  (setq orig-param (vlax-curve-getParamAtPoint vla-pl pt-on-orig))
                  (setq target-k (fix orig-param))
                  (if (>= target-k (1- (length chain-pts))) (setq target-k (- (length chain-pts) 2)))
                  (setq out-norm (+ ang (* boundary-orient (/ pi 2.0))))
                  (setq hpile-rot (+ out-norm (/ pi 2.0)))
                  (setq ins-pt (polar curr-pt out-norm (/ h 2.0)))

                  ;; [1] CIP 원형 작성
                  (entmake (list '(0 . "CIRCLE") (cons 8 "_CIP") (list 10 (car curr-pt) (cadr curr-pt) 0.0) (cons 40 (/ d 2.0))))

                  ;; [2] H-Pile 작성 및 앵커/브래킷 생성
                  (if (= (rem i interval) 0)
                    (progn
                      (entmake (list '(0 . "INSERT") (cons 2 hpile-block) '(8 . "_측면말뚝") (list 10 (car ins-pt) (cadr ins-pt) 0.0) '(41 . 1.0) '(42 . 1.0) '(43 . 1.0) (cons 50 hpile-rot)))
                      (setq *tsp-hpile-points* (append *tsp-hpile-points* (list (list (car ins-pt) (cadr ins-pt) 0.0))))
                      
                      ;; [2.1] 브래킷 및 해치 작도
                      (setq num-dia (if (= (type d) 'STR) (atof d) d))
                      (setq num-h (if (= (type h) 'STR) (atof h) h))
                      (setq num-b (if (= (type b) 'STR) (atof b) b))
                      (if (> num-dia num-h)
                        (progn
                          (setq p-start-center (polar curr-pt out-norm (/ num-h 2.0)))
                          (setq p-end-center (polar curr-pt out-norm (/ num-dia 2.0)))
                          (setq p1 (polar p-start-center (+ out-norm (/ pi 2.0)) (/ num-b 2.0)))
                          (setq p2 (polar p-end-center (+ out-norm (/ pi 2.0)) (/ num-b 2.0)))
                          (setq p3 (polar p-end-center (- out-norm (/ pi 2.0)) (/ num-b 2.0)))
                          (setq p4 (polar p-start-center (- out-norm (/ pi 2.0)) (/ num-b 2.0)))
                          (setq br-pl (draw-bracket-poly (list p1 p2 p3 p4) br-layer br-color))
                          (if br-pl
                            (progn
                              (setq err-catch (vl-catch-all-apply 'vla-addhatch (list mspace 0 "ANSI31" :vlax-true)))
                              (if (not (vl-catch-all-error-p err-catch))
                                (progn
                                  (setq hatch-obj err-catch)
                                  (setq sa (vlax-make-safearray 9 (cons 0 0)))
                                  (vlax-safearray-fill sa (list (vlax-ename->vla-object br-pl)))
                                  (vla-appendouterloop hatch-obj sa)
                                  (vla-evaluate hatch-obj)
                                  (vla-put-patternscale hatch-obj (if (= (getvar "MEASUREMENT") 0) 400.0 20.0))
                                  (vla-put-layer hatch-obj br-layer)
                                  (vla-put-color hatch-obj br-color)
                                )
                              )
                            )
                          )
                        )
                      )

                      ;; [2.2] 앵커 작도
                      ;; 껍데기 가드를 무력화(T)하여, 항상 내부로 진입한 뒤 세그먼트별로 앵커 여부를 동적 판별하도록 변경
                      (if T
                        (if prev-hpile-raw-dist
                          (progn
                            (if (= interval 2)
                              (setq anchor-raw-dist (+ prev-hpile-raw-dist (/ (- wrap-raw prev-hpile-raw-dist) 4.0)))
                              (setq anchor-raw-dist (/ (+ prev-hpile-raw-dist wrap-raw) 2.0))
                            )
                            (setq anchor-d-wrap anchor-raw-dist)
                            (if (and full-loop (> max-path-len 0.0))
                              (while (>= anchor-d-wrap max-path-len) (setq anchor-d-wrap (- anchor-d-wrap max-path-len)))
                            )
                            (if (> anchor-d-wrap max-path-len)
                              (progn
                                (setq over-dist (- anchor-d-wrap max-path-len))
                                (setq end-pt-path (vlax-curve-getpointatdist vla-path max-path-len))
                                (setq end-param-path (vlax-curve-getendparam vla-path))
                                (setq deriv (vlax-curve-getfirstderiv vla-path end-param-path))
                                (setq ang (atan (cadr deriv) (car deriv)))
                                (setq anchor-pt (polar end-pt-path ang over-dist))
                              )
                              (progn
                                (setq anchor-pt (vlax-curve-getpointatdist vla-path anchor-d-wrap))
                                (setq param (vlax-curve-getparamatdist vla-path anchor-d-wrap))
                                (setq deriv (vlax-curve-getfirstderiv vla-path param))
                                (setq ang (atan (cadr deriv) (car deriv)))
                              )
                            )
                            (setq anchor-out-norm (+ ang (* boundary-orient (/ pi 2.0))))

                            ;; 사보강재 간섭 체크
                            ;; CIP가 여러 세그먼트로 체인 연결되었을 때, 앵커가 속한 '현재 하위 세그먼트'를 정확히 추적하여 모서리 간섭 판별
                            (setq pt-on-orig-anch (vlax-curve-getClosestPointTo vla-pl anchor-pt))
                            (setq orig-param-anch (vlax-curve-getParamAtPoint vla-pl pt-on-orig-anch))
                            (setq target-k-anch (fix orig-param-anch))
                            (if (>= target-k-anch (1- (length chain-pts))) (setq target-k-anch (- (length chain-pts) 2)))
                            
                            (setq target-index-anch (+ seg-idx target-k-anch))
                            (if (and is-closed (>= target-index-anch max-segs)) (setq target-index-anch (rem target-index-anch max-segs)))
                            
                            ;; 앵커 데이터 동적 파싱 (체인으로 묶인 각 세그먼트의 고유 지보재 데이터 적용)
                            (setq max-anchor-L 0.0 max-anchor-ang 0.0 max-anchor-free 0.0 max-anchor-bond 0.0 has-anchor nil)
                            (setq cur-support-list (cdr (assoc 'SUPPORT-LIST (nth target-index-anch *segment-list*))))
                            (if cur-support-list
                              (foreach s-item cur-support-list
                                (if (wcmatch (car s-item) "*앵커*")
                                  (progn
                                    (setq cur-free (nth 5 s-item) cur-bond (nth 6 s-item) cur-ang (nth 4 s-item))
                                    (setq cur-L (+ cur-free cur-bond))
                                    (if (> cur-L max-anchor-L) 
                                      (setq max-anchor-L cur-L max-anchor-ang cur-ang max-anchor-free cur-free max-anchor-bond cur-bond has-anchor T)
                                    )
                                  )
                                )
                              )
                            )
                            
                            ;; 띠장(Wale) 제원 동적 파싱 (앵커 시작점 오프셋 계산용)
                            (setq cip-wale-spec (cdr (assoc 'WALE-SPEC (nth target-index-anch *segment-list*))))
                            (if (= cip-wale-spec "User-defined") 
                              (setq cip-wale-vals (cdr (assoc 'WALE-CUSTOM (nth target-index-anch *segment-list*)))) 
                              (setq cip-wale-vals (parse-h-spec cip-wale-spec))
                            )
                            (if (null cip-wale-vals) (setq cip-wale-vals '(300 300 10 15)))
                            (setq cip-wale-h (nth 0 cip-wale-vals))

                            (setq cur-brace (cdr (assoc 'CORNER-BRACE (nth target-index-anch *segment-list*))))
                            (setq next-seg-real-idx (if is-closed (rem (+ target-index-anch 1) n-verts) (+ target-index-anch 1)))
                            (setq next-brace nil)
                            (if (and next-seg-real-idx (< next-seg-real-idx (length *segment-list*)))
                              (setq next-brace (cdr (assoc 'CORNER-BRACE (nth next-seg-real-idx *segment-list*))))
                            )
                            
                            (setq cur-vertex-anch (nth target-k-anch chain-pts))
                            (setq next-vertex-anch (nth (1+ target-k-anch) chain-pts))
                            (setq dist-to-start (distance (list (car cur-vertex-anch) (cadr cur-vertex-anch)) (list (car pt-on-orig-anch) (cadr pt-on-orig-anch))))
                            (setq dist-to-end (distance (list (car next-vertex-anch) (cadr next-vertex-anch)) (list (car pt-on-orig-anch) (cadr pt-on-orig-anch))))
                            (setq brace-blocked nil)

                            ;; C.I.P 상향 띠장(Upgraded Wale) 구역을 포함한 사보강재/앵커 간섭 정밀 체크 (실제 dist-list 탐색 적용)
                            (setq c-upg-s (cdr (assoc 'UPGRADE-WALE (nth target-index-anch *segment-list*))))
                            (setq has-upg-s (and c-upg-s (= (car c-upg-s) "Y")))
                            (setq c-upg-e (cdr (assoc 'UPGRADE-WALE (nth next-seg-real-idx *segment-list*))))
                            (setq has-upg-e (and c-upg-e (= (car c-upg-e) "Y")))
                            (setq base-clear 500.0)
                            (setq min-limit-s base-clear min-limit-e base-clear)
                            (setq upg-center-s 0.0 upg-center-e 0.0)
                            (setq exact-L-start base-clear exact-L-end base-clear)
                            
                            (if (and cur-brace (= (car cur-brace) "Y") (cadr cur-brace))
                              (progn
                                (setq chk-last-b-row (last (cadr cur-brace)))
                                (setq chk-b-h (nth 0 (cadr chk-last-b-row)))
                                (setq chk-edge (if (wcmatch (strcase (nth 0 chk-last-b-row)) "2H*") (* chk-b-h 1.5) (/ chk-b-h 2.0)))
                                (setq min-limit-s (max base-clear (+ (* (nth 2 chk-last-b-row) 1000.0) chk-edge 150.0)))
                                (setq exact-L-start min-limit-s)
                              )
                            )
                            (if has-upg-s
                              (progn
                                (setq best-d 1e99 k 0)
                                (foreach d-val dist-list
                                  (if (= (rem k interval) 0)
                                    (progn
                                      (setq d-wrap d-val)
                                      (if (and full-loop (> max-path-len 0.0))
                                        (while (>= d-wrap max-path-len) (setq d-wrap (- d-wrap max-path-len))))
                                      (if (< d-wrap 0.0) (setq d-wrap 0.0))
                                      (if (> d-wrap max-path-len)
                                        (progn
                                          (setq end-pt-path (vlax-curve-getpointatdist vla-path max-path-len))
                                          (setq end-param-path (vlax-curve-getendparam vla-path))
                                          (setq deriv (vlax-curve-getfirstderiv vla-path end-param-path))
                                          (setq ang (atan (cadr deriv) (car deriv)))
                                          (setq p-temp (polar end-pt-path ang (- d-wrap max-path-len)))
                                        )
                                        (setq p-temp (vlax-curve-getpointatdist vla-path d-wrap))
                                      )
                                      (setq p-on-orig (vlax-curve-getClosestPointTo vla-pl p-temp))
                                      (setq p-param (vlax-curve-getParamAtPoint vla-pl p-on-orig))
                                      (if (and (>= p-param target-k-anch) (<= p-param (1+ target-k-anch)))
                                        (progn
                                          (setq d-dist (distance (list (car cur-vertex-anch) (cadr cur-vertex-anch)) (list (car p-on-orig) (cadr p-on-orig))))
                                          (if (> (+ d-dist 150.0) min-limit-s)
                                            (if (< d-dist best-d) (setq best-d d-dist))
                                          )
                                        )
                                      )
                                    )
                                  )
                                  (setq k (1+ k))
                                )
                                (if (< best-d 1e90)
                                  (progn
                                    (setq upg-center-s best-d)
                                    (setq exact-L-start (max exact-L-start (+ best-d 150.0)))
                                  )
                                )
                              )
                            )
                            
                            (if (and next-brace (= (car next-brace) "Y") (cadr next-brace))
                              (progn
                                (setq chk-last-b-row (last (cadr next-brace)))
                                (setq chk-b-h (nth 0 (cadr chk-last-b-row)))
                                (setq chk-edge (if (wcmatch (strcase (nth 0 chk-last-b-row)) "2H*") (* chk-b-h 1.5) (/ chk-b-h 2.0)))
                                (setq min-limit-e (max base-clear (+ (* (nth 2 chk-last-b-row) 1000.0) chk-edge 150.0)))
                                (setq exact-L-end min-limit-e)
                              )
                            )
                            (if has-upg-e
                              (progn
                                (setq best-d 1e99 k 0)
                                (foreach d-val dist-list
                                  (if (= (rem k interval) 0)
                                    (progn
                                      (setq d-wrap d-val)
                                      (if (and full-loop (> max-path-len 0.0))
                                        (while (>= d-wrap max-path-len) (setq d-wrap (- d-wrap max-path-len))))
                                      (if (< d-wrap 0.0) (setq d-wrap 0.0))
                                      (if (> d-wrap max-path-len)
                                        (progn
                                          (setq end-pt-path (vlax-curve-getpointatdist vla-path max-path-len))
                                          (setq end-param-path (vlax-curve-getendparam vla-path))
                                          (setq deriv (vlax-curve-getfirstderiv vla-path end-param-path))
                                          (setq ang (atan (cadr deriv) (car deriv)))
                                          (setq p-temp (polar end-pt-path ang (- d-wrap max-path-len)))
                                        )
                                        (setq p-temp (vlax-curve-getpointatdist vla-path d-wrap))
                                      )
                                      (setq p-on-orig (vlax-curve-getClosestPointTo vla-pl p-temp))
                                      (setq p-param (vlax-curve-getParamAtPoint vla-pl p-on-orig))
                                      (if (and (>= p-param target-k-anch) (<= p-param (1+ target-k-anch)))
                                        (progn
                                          (setq d-dist (distance (list (car next-vertex-anch) (cadr next-vertex-anch)) (list (car p-on-orig) (cadr p-on-orig))))
                                          (if (> (+ d-dist 150.0) min-limit-e)
                                            (if (< d-dist best-d) (setq best-d d-dist))
                                          )
                                        )
                                      )
                                    )
                                  )
                                  (setq k (1+ k))
                                )
                                (if (< best-d 1e90)
                                  (progn
                                    (setq upg-center-e best-d)
                                    (setq exact-L-end (max exact-L-end (+ best-d 150.0)))
                                  )
                                )
                              )
                            )
                            
                            (if (and next-brace (= (car next-brace) "Y") (cadr next-brace))
                              (progn
                                (setq chk-last-b-row (last (cadr next-brace)))
                                (setq min-limit-e (+ (* (nth 2 chk-last-b-row) 1000.0) (/ (nth 0 (cadr chk-last-b-row)) 2.0) 150.0))
                                (setq exact-L-end min-limit-e)
                              )
                            )
                            (if has-upg-e
                              (progn
                                (setq best-d 1e99 k 0)
                                (foreach d-val dist-list
                                  (if (= (rem k interval) 0)
                                    (progn
                                      (setq d-wrap d-val)
                                      (if (and full-loop (> max-path-len 0.0))
                                        (while (>= d-wrap max-path-len) (setq d-wrap (- d-wrap max-path-len))))
                                      (if (< d-wrap 0.0) (setq d-wrap 0.0))
                                      (if (> d-wrap max-path-len)
                                        (progn
                                          (setq end-pt-path (vlax-curve-getpointatdist vla-path max-path-len))
                                          (setq end-param-path (vlax-curve-getendparam vla-path))
                                          (setq deriv (vlax-curve-getfirstderiv vla-path end-param-path))
                                          (setq ang (atan (cadr deriv) (car deriv)))
                                          (setq p-temp (polar end-pt-path ang (- d-wrap max-path-len)))
                                        )
                                        (setq p-temp (vlax-curve-getpointatdist vla-path d-wrap))
                                      )
                                      (setq p-on-orig (vlax-curve-getClosestPointTo vla-pl p-temp))
                                      (setq p-param (vlax-curve-getParamAtPoint vla-pl p-on-orig))
                                      (if (and (>= p-param target-k-anch) (<= p-param (1+ target-k-anch)))
                                        (progn
                                          (setq d-dist (distance (list (car next-vertex-anch) (cadr next-vertex-anch)) (list (car p-on-orig) (cadr p-on-orig))))
                                          (if (> (+ d-dist 150.0) min-limit-e)
                                            (if (< d-dist best-d) (setq best-d d-dist))
                                          )
                                        )
                                      )
                                    )
                                  )
                                  (setq k (1+ k))
                                )
                                (if (< best-d 1e90)
                                  (progn
                                    (setq upg-center-e best-d)
                                    (setq exact-L-end (+ best-d 150.0))
                                  )
                                )
                              )
                            )
                            
                            ;; 세그먼트 전체 길이 계산
                            (setq sub-seg-len (distance (list (car cur-vertex-anch) (cadr cur-vertex-anch)) (list (car next-vertex-anch) (cadr next-vertex-anch))))
                            
                            ;; CTC 기준 전체 상향(Full Upgrade) 검사 - 띠장 로직과 완벽 동기화 (중심점 기준)
                            (setq check-L-s (if has-upg-s upg-center-s 0.0))
                            (setq check-L-e (if has-upg-e upg-center-e 0.0))
                            
                            (if (and (or (> check-L-s 0.0) (> check-L-e 0.0))
                                     (< (- sub-seg-len (+ check-L-s check-L-e)) (* cip-ctc interval 1.5)))
                              (setq exact-L-start sub-seg-len exact-L-end sub-seg-len)
                            )
                            
                            ;; 최종 간섭 판별 (상향 띠장 구간 내에는 앵커 배치 불가)
                            (if (or (<= dist-to-start exact-L-start) (<= dist-to-end exact-L-end))
                              (setq brace-blocked T)
                            )

                            ;; 해당 세그먼트에 앵커가 존재(has-anchor)할 때만 작도하도록 조건 추가
                            (if (and has-anchor (not brace-blocked))
                              (progn
                                (create-layer-if-not-exists "_앵커(Anchor)" "6")
                                (setq cos-val (cos (* max-anchor-ang (/ pi 180.0))))
                                (setq proj-free (* max-anchor-free 1000.0 cos-val) proj-bond (* max-anchor-bond 1000.0 cos-val) proj-prot (* 150.0 cos-val))
                                
                                (setq pt-base (polar anchor-pt anchor-out-norm (+ (/ d 2.0) cip-wale-h)))
                                
                                (setq pt-free-end (polar pt-base (+ anchor-out-norm pi) proj-free) pt-bond-end (polar pt-free-end (+ anchor-out-norm pi) proj-bond))
                                (setq pt-h1 (polar pt-base (+ anchor-out-norm (/ pi 2.0)) 100.0) pt-h2 (polar pt-base (- anchor-out-norm (/ pi 2.0)) 100.0))
                                (setq pt-h3 (polar pt-h2 anchor-out-norm 60.0) pt-h4 (polar pt-h1 anchor-out-norm 60.0))
                                
                                (entmake (list '(0 . "LWPOLYLINE") '(100 . "AcDbEntity") '(100 . "AcDbPolyline") (cons 8 "_앵커(Anchor)") (cons 62 6) '(90 . 4) '(70 . 1) (list 10 (car pt-h1) (cadr pt-h1)) (list 10 (car pt-h2) (cadr pt-h2)) (list 10 (car pt-h3) (cadr pt-h3)) (list 10 (car pt-h4) (cadr pt-h4))))
                                (setq pt-anchor-start (polar pt-base anchor-out-norm (+ 60.0 proj-prot)))
                                
                                (entmake (list '(0 . "LWPOLYLINE") '(100 . "AcDbEntity") '(100 . "AcDbPolyline") (cons 8 "_앵커(Anchor)") (cons 62 6) '(90 . 2) '(70 . 0) (list 10 (car pt-anchor-start) (cadr pt-anchor-start)) (list 10 (car pt-base) (cadr pt-base))))
                                (entmake (list '(0 . "LWPOLYLINE") '(100 . "AcDbEntity") '(100 . "AcDbPolyline") (cons 8 "_앵커(Anchor)") (cons 62 6) '(90 . 2) '(70 . 0) (list 10 (car pt-base) (cadr pt-base)) (list 10 (car pt-free-end) (cadr pt-free-end))))
                                (entmake (list '(0 . "LWPOLYLINE") '(100 . "AcDbEntity") '(100 . "AcDbPolyline") (cons 8 "_앵커(Anchor)") (cons 62 6) '(90 . 2) '(70 . 0) '(43 . 400.0) (list 10 (car pt-free-end) (cadr pt-free-end)) (list 10 (car pt-bond-end) (cadr pt-bond-end))))
                              )
                            )
                          )
                        )
                      )

                      ;; H-Pile 개수 카운팅
                      (setq target-index (+ seg-idx target-k))
                      (if (and is-closed (>= target-index (length *segment-list*))) (setq target-index 0))
                      (setq seg-hpile-count (nth target-index *tsp-segment-pile-counts*))
                      (if (null seg-hpile-count) (setq seg-hpile-count 0))
                      (if (and (= target-index 0) (= seg-hpile-count 1) (= i 0))
                        nil
                        (setq *tsp-segment-pile-counts* (update-list-item *tsp-segment-pile-counts* target-index (1+ seg-hpile-count)))
                      )
                      (setq *tsp-actual-drawn-hpiles* (1+ *tsp-actual-drawn-hpiles*))
                      
                      ;; [2.3] 현재 H-Pile 위치 저장 (다음 앵커 생성을 위함)
                      (setq prev-hpile-raw-dist wrap-raw)
                    )
                  )
                  
                  ;; [2.5] 그라우팅 작성
                  (if (= i 0) (setq first-cip-pt curr-pt))
                  (if prev-cip-pt (tsp-draw-grouting prev-cip-pt curr-pt d grouting-dia boundary-orient))
                  (setq prev-cip-pt curr-pt)
                )
                (progn
                  ;; 마지막 노드 폐합 마감 (그라우팅 연결)
                  (if prev-cip-pt (tsp-draw-grouting prev-cip-pt first-cip-pt d grouting-dia boundary-orient))
                )
              )
              (setq i (1+ i))
            )
            (vla-delete vla-path)
          )
        )
        (if temp-pl (entdel temp-pl))
        ;; 5. 복구 및 점프
        (setq *tsp-cip-dia* save-dia
              *tsp-cip-mode-idx* save-mode
              *tsp-cip-overlap* save-overlap
              *tsp-cip-equal-divide* save-equal-divide
              *tsp-cip-interval-idx* save-interval
              *tsp-cip-hpile-idx* save-hpile-idx
              *tsp-cip-grouting-idx* save-grouting)
        (setq seg-idx (1- j))
      )
    )
    (setq seg-idx (1+ seg-idx))
  )
  
  ;; 검증(Validation) 단계
  (setq total-counted-in-list 0 v-idx 0)
  (while (< v-idx (length *segment-list*))
    (if (= (cdr (assoc 'WALL-TYPE (nth v-idx *segment-list*))) "CIP")
      (setq total-counted-in-list (+ total-counted-in-list (nth v-idx *tsp-segment-pile-counts*)))
    )
    (setq v-idx (1+ v-idx))
  )
  
  (if (= total-counted-in-list *tsp-actual-drawn-hpiles*)
    (princ (strcat "\n[시스템 검증 성공] C.I.P 누적 캡슐 총합(" (itoa total-counted-in-list) ")과 실제 도면 생성 개수(" (itoa *tsp-actual-drawn-hpiles*) ")가 완벽히 일치합니다."))
    (princ (strcat "\n[시스템 검증 경고] C.I.P 개수 불일치 발생! 누적 총합: " (itoa total-counted-in-list) " / 실제 생성 개수: " (itoa *tsp-actual-drawn-hpiles*)))
  )
)


;;;;==========================================================================
;;;; defun tsp-find-next-dist-by-chord : 현재 점에서 목표 현의 길이(직선 거리)를 만족하는 곡선상의 다음 누적 거리를 이분법으로 탐색
;;;;==========================================================================
(defun tsp-find-next-dist-by-chord (curve-obj current-dist target-chord max-dist / 
                                    pt-current dist-low dist-high dist-mid 
                                    pt-mid current-chord tolerance iter max-iter pt-high)
  (setq pt-current (vlax-curve-getPointAtDist curve-obj current-dist))
  (setq dist-low current-dist)
  
  ;; 1차 검증: 남은 '경로 거리(Path)' 자체가 목표 간격보다 짧으면 탐색 불가 (폐합선 오류 방지)
  (if (< (- max-dist current-dist) target-chord)
    nil
    (progn
      ;; 상한선은 목표 직선거리의 1.5배 또는 전체 길이 중 작은 값으로 설정
      (setq dist-high (min (+ current-dist (* target-chord 1.5)) max-dist))
      
      ;; 상한선을 확장하는 안전장치 (곡률이 매우 심할 경우 대비)
      (while (and (< (distance pt-current (vlax-curve-getPointAtDist curve-obj dist-high)) target-chord)
                  (< dist-high max-dist))
        (setq dist-high (min (+ dist-high target-chord) max-dist))
      )
      
      (setq pt-high (vlax-curve-getPointAtDist curve-obj dist-high))
      
      ;; 최종 검증: max-dist까지 경로를 따라갔는데도 직선거리가 목표치보다 짧다면 도달 불가
      (if (and (= dist-high max-dist) (< (distance pt-current pt-high) target-chord))
        nil
        (progn
          (setq tolerance 0.01) ; 0.01mm 오차 허용
          (setq iter 0 max-iter 50)
          (setq dist-mid dist-low)
          
          ;; 이분법 정밀 탐색
          (while (and (< iter max-iter) (< tolerance (- dist-high dist-low)))
            (setq dist-mid (/ (+ dist-low dist-high) 2.0))
            (setq pt-mid (vlax-curve-getPointAtDist curve-obj dist-mid))
            (setq current-chord (distance pt-current pt-mid))
            
            (if (< current-chord target-chord)
              (setq dist-low dist-mid)
              (setq dist-high dist-mid)
            )
            (setq iter (1+ iter))
          )
          dist-mid
        )
      )
    )
  )
)



;;;;==========================================================================
;;;; defun tsp-make-segment-guideline : 세그먼트 구간 보조선 생성 (직접 좌표 계산으로 Offset 오류 원천 차단)
;;;;==========================================================================
(defun tsp-make-segment-guideline (pt1 pt2 dia boundary-orient / d seg-angle out-norm new-pt1 new-pt2 guide-ent)
  (setq d (/ dia 2.0))
  (setq seg-angle (angle pt1 pt2))
  (setq out-norm (+ seg-angle (* boundary-orient (/ pi 2.0))))
  
  ;; H-Pile(토류판)과 똑같이 바깥쪽을 향하도록 마이너스(-d) 방향으로 점 이동
  (setq new-pt1 (polar pt1 out-norm (- d)))
  (setq new-pt2 (polar pt2 out-norm (- d)))
  
  ;; 캐드 내장 OFFSET 명령어의 방향 플립(Flip) 버그에 의한 오검증 문제를 원천 차단하기 위해
  ;; 계산된 좌표로 보조 폴리선을 수학적으로 직접 강제 작도합니다.
  (entmake (list '(0 . "LWPOLYLINE") '(100 . "AcDbEntity") '(100 . "AcDbPolyline")
                 '(8 . "0") '(62 . 256) '(90 . 2) '(70 . 0)
                 (list 10 (car new-pt1) (cadr new-pt1))
                 (list 10 (car new-pt2) (cadr new-pt2))))
  (setq guide-ent (entlast))
  guide-ent
)
