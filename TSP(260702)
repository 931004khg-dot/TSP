  (defun anchor-input-dialog (existing-data default-name min-depth / a-result a-data mat-list-anchor sec-list-anchor res-name res-shape res-depth res-ang res-free res-bond res-mat res-sec init-shape shape-idx i)
    (setq mat-list-anchor '("SWPC7A" "SWPC7B")) (setq sec-list-anchor '()) (setq i 1)
    (repeat 15 (setq sec-list-anchor (append sec-list-anchor (list (strcat "Strand12.7×" (itoa i) "EA")))) (setq i (1+ i)))
    (if (new_dialog "tsp_support_anchor" dcl-id)
      (progn
        (start_list "a_shape") (mapcar 'add_list shape-list-anchor) (end_list)
        (start_list "a_mat") (mapcar 'add_list mat-list-anchor) (end_list)
        (start_list "a_sec") (mapcar 'add_list sec-list-anchor) (end_list)
        (if existing-data
          (progn
            (set_tile "a_name" (cadr existing-data))
            (setq init-shape (caddr existing-data)) (setq shape-idx (vl-position init-shape shape-list-anchor))
            (if shape-idx (set_tile "a_shape" (itoa shape-idx)) (set_tile "a_shape" "0"))
            (set_tile "a_depth" (rtos (cadddr existing-data) 2 2)) (set_tile "a_angle" (rtos (nth 4 existing-data) 2 1)) (set_tile "a_free" (rtos (nth 5 existing-data) 2 2)) (set_tile "a_bond" (rtos (nth 6 existing-data) 2 2))
            (set_tile "a_mat" "0") (set_tile "a_sec" "0")
          )
          (progn (set_tile "a_name" default-name) (set_tile "a_shape" "0") (set_tile "a_angle" "30") (set_tile "a_bond" "3") (set_tile "a_mat" "1") (set_tile "a_sec" "3"))
        )
        (action_tile "accept" "(progn (setq res-name (get_tile \"a_name\")) (setq res-shape (nth (atoi (get_tile \"a_shape\")) shape-list-anchor)) (setq res-depth (atof (get_tile \"a_depth\"))) (setq res-ang (atof (get_tile \"a_angle\"))) (setq res-free (atof (get_tile \"a_free\"))) (setq res-bond (atof (get_tile \"a_bond\"))) (setq res-mat (nth (atoi (get_tile \"a_mat\")) mat-list-anchor)) (setq res-sec (nth (atoi (get_tile \"a_sec\")) sec-list-anchor)) (cond ((or (= res-name \"\") (<= res-depth 0.0)) (alert \"이름과 설치깊이를 확인하세요.\")) ((< res-free 4.5) (alert \"자유장은 최소 4.5m 이상이어야 합니다.\")) ((> res-ang 40.0) (alert \"설치각도는 40도 이하여야 합니다.\")) ((<= res-depth min-depth) (alert \"설치 깊이는 이전 단계보다 깊어야 합니다!\")) (t (setq a-data (list \"앵커(Earth Anchor)\" res-name res-shape res-depth res-ang res-free res-bond res-mat res-sec)) (done_dialog 1))))")
        (action_tile "cancel" "(done_dialog 0)") (if (= (start_dialog) 1) a-data nil)
      )
    )
  )

;;;;==========================================================================
;;;; defun update-support-list : 지보재 리스트를 DCL에 출력
;;;;==========================================================================
  (defun update-support-list (/ s-type s-code disp-str free-len bond-len s-count s-spec formatted-spec)
  (start_list "support_list")
  (foreach item temp-supports
    (if (and (listp item) (> (length item) 0))
      (progn
        (setq s-type (car item))
        (cond
          ((wcmatch s-type "버팀보*") 
           (setq s-code "ST") 
           (setq s-count (nth 4 item))
           (setq s-spec (nth 6 item))
           (if (and s-count (> s-count 1))
             (if (wcmatch s-spec "2H *")
               (setq formatted-spec s-spec) 
               (setq formatted-spec (strcat (itoa s-count) s-spec)) 
             )
             (setq formatted-spec s-spec)
           )
           (setq disp-str (strcat (cadr item) "     " s-code "     " (rtos (cadddr item) 2 2) "m     " formatted-spec))
           (add_list disp-str)
          )
          ((wcmatch s-type "앵커*") 
           (setq s-code "EA") 
           (setq free-len (rtos (nth 5 item) 2 2)) 
           (setq bond-len (rtos (nth 6 item) 2 2)) 
           (setq disp-str (strcat (cadr item) "     " s-code "     " (rtos (cadddr item) 2 2) "m   (정착장 " bond-len "m 자유장 " free-len "m)"))
           (add_list disp-str)
          )
          ;; [추가/수정] 침묵하지 않고 명시적으로 오류를 표출하여 데이터 오염을 경고
          (t 
           (setq s-code "ERROR")
           (setq disp-str (strcat "!! [데이터 오류] 비정상 패킷: " (if (= (type s-type) 'STR) s-type "Unknown") " !!"))
           ;; 캐드 명령창에 디버깅용 로그 출력
           (princ (strcat "\n[경고: TSP] 지보재 리스트에 오염된 데이터가 감지되었습니다: " (vl-princ-to-string item)))
           (add_list disp-str)
          )
        )
      )
    )
  )
  (end_list)
)


  ;; ==========================================================================
  ;; 부모 대화상자(지보재 관리창) 메인 제어 루프
  ;; ==========================================================================
  (while loop-support
    (if restore-action
      (progn
        ;; 자식 창(버팀보 입력) 즉시 팝업 복원 (도면 작도 후)
        (setq min-depth 0.0)
        (if (and (= restore-type "MOD") (> restore-idx 0))
          (setq min-depth (cadddr (nth (1- restore-idx) temp-supports)))
        )
        (if (= restore-type "ADD")
           (setq min-depth (if temp-supports (cadddr (last temp-supports)) 0.0))
        )
        
        ;; 복원 데이터(restored-data)에 12번째 항목(s-brace-opt)을 정상적으로 포함시켜 상태 증발 방지
        (setq restored-data (list "RESTORE_SIGNAL"
                                  (nth 1 restore-data)
                                  (nth 2 restore-data)
                                  (nth 3 restore-data)
                                  (nth 4 restore-data)
                                  (nth 5 restore-data)
                                  (nth 6 restore-data)
                                  (nth 7 restore-data)
                                  manual-pts
                                  (nth 9 restore-data)
                                  (nth 10 restore-data)
                                  (nth 11 restore-data)))
        (setq new-data (strut-input-dialog restored-data nil min-depth))
          (cond
            ((and new-data (= (car new-data) "DRAW_SIGNAL"))
              (setq restore-data new-data)
              (setq result 4) ;; 다시 한 번 도면에 그리고 싶을 때
            )
            ((and new-data (wcmatch (car new-data) "*_POST"))
              ;; 수동 중간말뚝 제어 3중 검증 신호 전달
              (setq restore-data new-data)
              (setq tmp-id (if (assoc 'ID (nth restore-idx *segment-list*)) (cdr (assoc 'ID (nth restore-idx *segment-list*))) 0))
              (if (= (car new-data) "ADD_POST") (if (boundp 'tsp-manual-add-post) (tsp-manual-add-post tmp-id) (alert "수동 추가 함수 오류")))
              (if (= (car new-data) "DEL_POST") (if (boundp 'tsp-manual-delete-post) (tsp-manual-delete-post tmp-id) (alert "수동 삭제 함수 오류")))
              (if (= (car new-data) "RESET_POST") (if (boundp 'tsp-delete-manual-post-by-segment) (tsp-delete-manual-post-by-segment tmp-id) (alert "수동 초기화 함수 오류")))
              (setq result 4) ;; 창 다시 열기 (DRAW_SIGNAL과 동일한 취급)
            )
            (t
              (setq restore-action nil)
              (if new-data
                (progn
                  (foreach e manual-drawn-ents (if (entget e) (vl-catch-all-apply 'entdel (list e))))
                  (if (boundp 'temp-brace-ents) (foreach e temp-brace-ents (if (entget e) (vl-catch-all-apply 'entdel (list e)))))
                  (setq manual-drawn-ents '() temp-brace-ents '())
                  
                  (if (= restore-type "ADD")
                    (setq temp-supports (append temp-supports (list new-data)))
                    (progn
                      (setq i 0 new-list '())
                      (foreach item temp-supports
                        (if (= i restore-idx)
                          (setq new-list (append new-list (list new-data)))
                          (setq new-list (append new-list (list item)))
                        )
                        (setq i (1+ i))
                      )
                      (setq temp-supports new-list)
                    )
                  )
                )
                (progn
                  (foreach e manual-drawn-ents (if (entget e) (vl-catch-all-apply 'entdel (list e))))
                  (if (boundp 'temp-brace-ents) (foreach e temp-brace-ents (if (entget e) (vl-catch-all-apply 'entdel (list e)))))
                  (setq manual-drawn-ents '() temp-brace-ents '())
                )
              )
              
              (if (and (boundp '*tsp-current-seg-idx*) *tsp-current-seg-idx*)
                (progn
                  (setq *segment-list* (subst (subst (cons 'SUPPORT-LIST temp-supports) 
                                              (assoc 'SUPPORT-LIST (nth *tsp-current-seg-idx* *segment-list*)) 
                                              (nth *tsp-current-seg-idx* *segment-list*))
                                       (nth *tsp-current-seg-idx* *segment-list*)
                                       *segment-list*))
                  (if (boundp 'tsp-redraw-realtime-plan) (tsp-redraw-realtime-plan *tsp-boundary-ent* *tsp-boundary-orient*))
                )
              )
              (command "_.REGEN")
              
              (setq result 99) ;; 자식창 취소 시 부모창으로 복귀하도록 더미값 할당
            )
        )
      )
      (progn
        ;; 정상 부모 창 오픈
        (if (new_dialog "tsp_support" dcl-id)
          (progn
            (start_list "support_type_sel") (mapcar 'add_list support-types) (end_list) (set_tile "support_type_sel" "0")
            (update-support-list)
            
            (action_tile "btn_add" "(progn 
              (setq t-idx (atoi (get_tile \"support_type_sel\"))) 
              (setq t-str (nth t-idx support-types)) 
              (setq count 1) 
              (foreach item temp-supports (if (= (car item) t-str) (setq count (1+ count)))) 
              (if (wcmatch t-str \"버팀보*\") (setq def-name (strcat \"Strut_\" (itoa count)))) 
              (if (wcmatch t-str \"앵커*\") (setq def-name (strcat \"Anchor_\" (itoa count)))) 
              (setq last-depth (if temp-supports (cadddr (last temp-supports)) 0.0)) 
              (setq new-data nil) 
              (setq manual-drawn-ents '()) ;; 새로 입력 시 찌꺼기 추적 초기화
              
              (if (wcmatch t-str \"버팀보*\") 
                (setq new-data (strut-input-dialog nil def-name last-depth)) 
                (setq new-data (anchor-input-dialog nil def-name last-depth))) 
              
              (if (and new-data (= (car new-data) \"DRAW_SIGNAL\"))
                (progn (setq restore-data new-data restore-type \"ADD\" restore-action T) (done_dialog 4))
                (if new-data (progn (setq temp-supports (append temp-supports (list new-data))) (update-support-list)))
              )
            )")
            
            (action_tile "btn_modify" "(progn 
              (setq sel-idx-str (get_tile \"support_list\")) 
              (if (and sel-idx-str (/= sel-idx-str \"\")) 
                (progn 
                  (setq sel-idx (atoi sel-idx-str)) 
                  (setq existing-item (nth sel-idx temp-supports)) 
                  (setq ex-type (car existing-item)) 
                  (setq min-depth 0.0) 
                  (if (> sel-idx 0) (setq min-depth (cadddr (nth (1- sel-idx) temp-supports)))) 
                  (setq mod-data nil) 
                  (setq manual-drawn-ents '()) ;; 수정 시 찌꺼기 추적 초기화
                  
                  (if (wcmatch ex-type \"버팀보*\") 
                    (setq mod-data (strut-input-dialog existing-item nil min-depth)) 
                    (setq mod-data (anchor-input-dialog existing-item nil min-depth))) 
                  
                  (if (and mod-data (= (car mod-data) \"DRAW_SIGNAL\"))
                    (progn (setq restore-data mod-data restore-type \"MOD\" restore-idx sel-idx restore-action T) (done_dialog 4))
                    (if mod-data 
                      (progn 
                        (setq i 0 new-list '()) 
                        (foreach item temp-supports 
                          (if (= i sel-idx) 
                            (setq new-list (append new-list (list mod-data))) 
                            (setq new-list (append new-list (list item)))) 
                          (setq i (1+ i))) 
                        (setq temp-supports new-list) 
                        (update-support-list)
                      )
                    )
                  )
                ) 
                (alert \"수정할 항목을 선택하세요!\")
              )
            )")
            
            (action_tile "btn_delete" "(progn (setq sel-idx (atoi (get_tile \"support_list\"))) (if (and temp-supports (>= sel-idx 0) (< sel-idx (length temp-supports))) (progn (setq temp-supports (vl-remove (nth sel-idx temp-supports) temp-supports)) (update-support-list)) (alert \"삭제할 항목을 선택하세요!\")))")
            (action_tile "btn_clear" "(progn (setq temp-supports '()) (update-support-list))")
            (action_tile "accept" "(progn (setq *tsp-support-list* temp-supports) (done_dialog 1))")
            (action_tile "back" "(done_dialog 2)") 
            (action_tile "cancel" "(done_dialog 0)")
            
            (setq result (start_dialog))
          )
        )
      )
    )


   ;; [4 신호] 공통 도면 작도 처리 (순수 수학 연산, 동적 배열 및 화면 즉시 갱신)
    (if (= result 4)
      (progn
        ;; =====================================================================
        ;; 통합 모드: 도면 즉시 갱신 (다이얼로그에서 변경된 사항을 도면에 먼저 렌더링)
        (princ "\n[시스템] 미리보기 갱신...")
        
        ;; 기존 manual-pts 로드 및 안전 보존 (ESC 복구용 백업)
        (setq orig-manual-pts (if (> (length restore-data) 8) (nth 8 restore-data) '()))
        
        ;; 작도를 위해 화면을 깨끗하게 비우도록 manual-pts를 nil로 만든 preview-data 생성
        (setq real-type (if (wcmatch (nth 2 restore-data) "*Anchor*") "앵커(Earth Anchor)" "버팀보(Strut)"))
        (setq preview-data (list real-type (nth 1 restore-data) (nth 2 restore-data) (nth 3 restore-data) 
                                 (nth 4 restore-data) (nth 5 restore-data) (nth 6 restore-data) (nth 7 restore-data) 
                                 '() ;; 화면을 비우기 위해 빈 리스트 할당
                                 (nth 9 restore-data) (nth 10 restore-data) (nth 11 restore-data)))

        ;; 1. 현재 추가/수정 중인 데이터를 기존 임시 리스트에 병합 (비워진 데이터로)
        (setq preview-supports temp-supports)
        (if (= restore-type "ADD")
          (setq preview-supports (append preview-supports (list preview-data)))
          (progn
            (setq i 0 new-list '())
            (foreach item preview-supports
              (if (= i restore-idx)
                (setq new-list (append new-list (list preview-data)))
                (setq new-list (append new-list (list item)))
              )
              (setq i (1+ i))
            )
            (setq preview-supports new-list)
          )
        )
        
        ;; 2. 현재 편집 중인 세그먼트의 'SUPPORT-LIST'를 최신 미리보기 데이터로 덮어쓰기
        (if (and (boundp '*tsp-current-seg-idx*) *tsp-current-seg-idx*)
          (setq *segment-list* (subst (subst (cons 'SUPPORT-LIST preview-supports) 
                              (assoc 'SUPPORT-LIST (nth *tsp-current-seg-idx* *segment-list*)) 
                              (nth *tsp-current-seg-idx* *segment-list*))
                       (nth *tsp-current-seg-idx* *segment-list*)
                       *segment-list*))
        )
        
        ;; 3. 화면 갱신 수행 
        ;; 하위 함수 직접 호출을 차단하고, 청소 로직이 포함된 tsp-redraw-realtime-plan을 호출하여 보강재 잔류 방지
        (if (boundp 'tsp-redraw-realtime-plan)
          (tsp-redraw-realtime-plan *tsp-boundary-ent* *tsp-boundary-orient*)
          (create-hpile-set-on-boundary *tsp-boundary-ent* *tsp-boundary-orient*)
        )
        ;; =====================================================================

        ;; [C.T.C 간격 동기화] (인덱스 10번으로 수정)
        (setq ctc-input (if (and restore-data (> (length restore-data) 10) (nth 10 restore-data) (/= (nth 10 restore-data) "")) 
                          (atof (nth 10 restore-data)) 
                          5.0))
        (if (<= ctc-input 0.0) (setq ctc-input 5.0))
        (setq ctc-dist (* ctc-input 1000.0))

        ;; 작도 시작 기준(start-mode) 판별 (0:사용자 클릭, 1:세그먼트 중점, 2:간격 중심) - 인덱스 9번으로 수정
        (setq start-mode (if (> (length restore-data) 9) (nth 9 restore-data) "0"))

        (if (and (or (= start-mode "1") (= start-mode "2")) *tsp-current-seg-idx*)
          (progn
            ;; 전역변수에 저장된 현재 세그먼트의 중점 좌표를 WCS로 자동 도출하여 클릭 생략
            (setq p-start-v (cdr (assoc 'V-START (nth *tsp-current-seg-idx* *segment-list*))))
            (setq p-end-v (cdr (assoc 'V-END (nth *tsp-current-seg-idx* *segment-list*))))
            (setq p-start-wcs (trans p-start-v *tsp-boundary-ent* 0))
            (setq p-end-wcs (trans p-end-v *tsp-boundary-ent* 0))
            (setq pt-user (list (/ (+ (car p-start-wcs) (car p-end-wcs)) 2.0)
                                (/ (+ (cadr p-start-wcs) (cadr p-end-wcs)) 2.0)
                                0.0))
            (princ "\n[자동 시작] 선택된 세그먼트의 중점에서 배열 작도를 즉시 시작합니다.")
          )
          (progn
            ;; 옵션이 0(사용자 클릭)이거나 세그먼트 정보를 찾지 못했을 때는 기존처럼 클릭 요청
            (princ "\n[수동 작도] 버팀보(Strut)를 설치할 기준 벽체(경계선) 근처를 1번만 클릭하세요 (취소: ESC/우클릭): ")
            (setq pt-user (vl-catch-all-apply 'getpoint))
          )
        )
        
        (if (vl-catch-all-error-p pt-user)
          (progn
            (princ "\n[취소] ESC 입력 감지. 작도를 취소하고 입력창으로 돌아갑니다.")
            (setq restore-action T)
          )
          (if pt-user
            (progn
              ;; 흙막이 전체 정점 WCS 변환 (PIP 내부 판별용) - 성능을 위해 1회만 계산
              (setq poly-verts (mapcar '(lambda (x / v) 
                                          (setq v (trans (cdr (assoc 'V-START x)) *tsp-boundary-ent* 0))
                                          (list (car v) (cadr v) 0.0)
                                        ) 
                                        *segment-list*))

              ;; 세그먼트 경계 제한을 위한 점-세그먼트 인덱스 판별 함수
              (defun get-seg-idx-for-pt (pt / min-d idx i p1 p2 d)
                (setq min-d 1e99 idx 0 i 0)
                (foreach seg *segment-list*
                  (setq p1 (cdr (assoc 'V-START seg)))
                  (setq p2 (cdr (assoc 'V-END seg)))
                  (setq d (abs (- (+ (distance p1 pt) (distance pt p2)) (distance p1 p2))))
                  (if (< d min-d) (progn (setq min-d d idx i)))
                  (setq i (1+ i))
                )
                idx
              )

              ;;;; ----------------------------------------------------------------------
              ;;;; 내부 함수: draw-dynamic-strut
              ;;;; 기준점(bp)을 받아 벽체를 추적하고, 맞은편 레이저를 쏴서 즉시 작도하는 캡슐화 함수
              ;;;; ----------------------------------------------------------------------
              (defun draw-dynamic-strut (bp / res-ents min-dist seg-idx1 i best-seg1 p1 p2 d p-base-flat tang-ang norm-ang1 norm-ang2 p-ray1 p-ray2 pts sp1 sp2 sp1-flat sp2-flat int-pt1 int-pt2 valid-pts int-pt mid-pt p-opp seg-idx2 norm-ang offset1 offset2 pt1 pt2)
                (setq res-ents nil)
                
                ;; 현재 점(bp)이 속한 선분 파악
                (setq min-dist 1e99 seg-idx1 0 i 0 best-seg1 nil)
                (foreach seg *segment-list*
                  (setq p1 (cdr (assoc 'V-START seg)))
                  (setq p2 (cdr (assoc 'V-END seg)))
                  (setq d (abs (- (+ (distance p1 bp) (distance bp p2)) (distance p1 p2))))
                  (if (< d min-dist)
                    (progn (setq min-dist d seg-idx1 i best-seg1 seg))
                  )
                  (setq i (1+ i))
                )
                
                ;; 양방향 수직 레이저 발사
                (setq p-base-flat (list (car bp) (cadr bp) 0.0))
                (setq p1 (trans (cdr (assoc 'V-START best-seg1)) *tsp-boundary-ent* 0))
                (setq p2 (trans (cdr (assoc 'V-END best-seg1)) *tsp-boundary-ent* 0))
                (setq p1 (list (car p1) (cadr p1) 0.0))
                (setq p2 (list (car p2) (cadr p2) 0.0))
                
                (setq tang-ang (angle p1 p2))
                (setq norm-ang1 (+ tang-ang (/ pi 2.0)))
                (setq norm-ang2 (- tang-ang (/ pi 2.0)))
                
                (setq p-ray1 (polar p-base-flat norm-ang1 1e6))
                (setq p-ray2 (polar p-base-flat norm-ang2 1e6))
                
                (setq pts '() i 0)
                (foreach seg *segment-list*
                  (setq sp1 (trans (cdr (assoc 'V-START seg)) *tsp-boundary-ent* 0))
                  (setq sp2 (trans (cdr (assoc 'V-END seg)) *tsp-boundary-ent* 0))
                  (setq sp1-flat (list (car sp1) (cadr sp1) 0.0))
                  (setq sp2-flat (list (car sp2) (cadr sp2) 0.0))
                  
                  (setq int-pt1 (inters p-base-flat p-ray1 sp1-flat sp2-flat T))
                  (setq int-pt2 (inters p-base-flat p-ray2 sp1-flat sp2-flat T))
                  
                  (if (and int-pt1 (> (distance p-base-flat int-pt1) 10.0))
                    (setq pts (append pts (list (list int-pt1 i norm-ang1))))
                  )
                  (if (and int-pt2 (> (distance p-base-flat int-pt2) 10.0))
                    (setq pts (append pts (list (list int-pt2 i norm-ang2))))
                  )
                  (setq i (1+ i))
                )
                
                ;; 교차점 내부 검증 (PIP) 및 맞은편 벽체 도출
                (setq valid-pts '())
                (foreach pt-data pts
                  (setq int-pt (car pt-data))
                  (setq mid-pt (list (/ (+ (car p-base-flat) (car int-pt)) 2.0) (/ (+ (cadr p-base-flat) (cadr int-pt)) 2.0) 0.0))
                  (if (tsp-is-point-inside mid-pt poly-verts)
                    (setq valid-pts (append valid-pts (list pt-data)))
                  )
                )
                
                (if valid-pts
                  (progn
                    (setq valid-pts (vl-sort valid-pts '(lambda (a b) (< (distance p-base-flat (car a)) (distance p-base-flat (car b))))))
                    (setq p-opp (car (car valid-pts)))
                    (setq seg-idx2 (cadr (car valid-pts)))
                    (setq norm-ang (caddr (car valid-pts)))
                    
                    (setq offset1 (tsp-get-wale-offset (nth seg-idx1 *segment-list*)))
                    (setq offset2 (tsp-get-wale-offset (nth seg-idx2 *segment-list*)))
                    
                    (if (> (distance bp p-opp) (+ offset1 offset2))
                      (progn
                        (setq pt1 (polar bp norm-ang offset1))
                        (setq pt2 (polar p-opp (+ norm-ang pi) offset2))
                        
                        (if (wcmatch (nth 2 restore-data) "H형강")
                          (progn
                            ;; XDATA 및 옵션 전달을 위한 데이터 파싱
                            (setq sec-str (nth 6 restore-data))
                            (setq res-count (nth 4 restore-data))
                            (setq is-double (if (>= res-count 2) T nil))
                            (setq s-brace-opt (if (> (length restore-data) 11) (nth 11 restore-data) nil))
                            (setq target-seg-id (cdr (assoc 'ID (nth seg-idx1 *segment-list*))))
                            
                            ;; 배열 시 개별 보강재 작도 차단 (연속 보강재 일괄 작도를 위해)
                            (setq array-brace-opt s-brace-opt)
                            (if array-brace-opt (setq array-brace-opt (cons "0" (cdr array-brace-opt))))
                            
                            ;; --- 50m 자중 좌굴 한계 검사 및 취소(Cancel) 팝업 ---
                            (setq actual-strut-len (distance pt1 pt2))
                            (setq proceed-draw T)
                            (if (> actual-strut-len 50000.0)
                              (progn
                                (setq wsh (vlax-create-object "WScript.Shell"))
                                ;; 팝업 코드 33 = 1(확인/취소 버튼) + 32(물음표 아이콘)
                                (setq msg-res (vlax-invoke-method wsh 'Popup (strcat "경고: 버팀보 산정 길이(" (rtos (/ actual-strut-len 1000.0) 2 1) "m)가 자중 좌굴 한계(50m)를 초과합니다.\n\n안전성에 유의하여 작도를 계속 진행하시겠습니까?") 0 "TSP - 자중 좌굴 한계 초과" 33))
                                (vlax-release-object wsh)
                                (if (= msg-res 2) (setq proceed-draw nil)) ; 2는 사용자가 '취소'를 선택했음을 의미
                              )
                            )
                            
                            (if proceed-draw
                              (progn
                                ;; 확장된 매개변수를 적용하여 작도 함수 호출
                                (setq drawn-ents (tsp-draw-manual-strut pt1 pt2 sec-str (nth 7 restore-data) is-double array-brace-opt target-seg-id))
                                
                                ;; 작도된 객체 리스트와 시작점(pt1) 반환 및 보강재를 위한 실시간 제원 갱신
                                (if drawn-ents 
                                  (progn 
                                    (setq res-ents (list drawn-ents pt1))
                                    ;; 방금 작도한 버팀보의 각도와 길이를 갱신하여, 후속 보강재 작도 시 과거 데이터가 쓰이는 것을 차단
                                    (setq strut-ang (angle pt1 pt2))
                                    (setq strut-len (distance pt1 pt2))
                                  )
                                )
                              )
                              (princ (strcat "\n[작도 취소] 버팀보(길이: " (rtos (/ actual-strut-len 1000.0) 2 1) "m) 배치가 사용자에 의해 취소되었습니다."))
                            )
                          )
                          (princ "\n[알림] 강관 버팀보는 평면 작도가 지원되지 않습니다.")
                        )
                      )
                      (princ "\n[오류] 띠장 두께 합산값이 양쪽 벽체 간격보다 커서 설치 불가합니다.")
                    )
                  )
                  (princ "\n[경고] 반대편 벽체를 찾을 수 없는 구간입니다.")
                )
                res-ents ;; (작도된_객체_리스트 진짜_pt1) 형태로 반환
              )
              ;;;; ----------------------------------------------------------------------

              ;; 1. 기준점 보정 및 작도 시작 기준(Start Mode) 적용
              (setq p-base-click (vlax-curve-getClosestPointTo *tsp-boundary-ent* pt-user))
              (setq target-seg-idx (get-seg-idx-for-pt p-base-click)) ;; 첫 클릭 위치의 종속 세그먼트 인덱스 기록
              
              (setq start-mode (if (> (length restore-data) 9) (nth 9 restore-data) "0"))
              
              (if (or (= start-mode "1") (= start-mode "2"))
                (progn
                  ;; 모서리 시작/끝점을 통해 세그먼트 중점(Midpoint) 도출
                  (setq p-start-v   (cdr (assoc 'V-START (nth target-seg-idx *segment-list*))))
                  (setq p-end-v     (cdr (assoc 'V-END   (nth target-seg-idx *segment-list*))))
                  (setq p-start-wcs (trans p-start-v *tsp-boundary-ent* 0))
                  (setq p-end-wcs   (trans p-end-v   *tsp-boundary-ent* 0))
                  (setq mid-pt (list (/ (+ (car p-start-wcs) (car p-end-wcs)) 2.0)
                   (/ (+ (cadr p-start-wcs) (cadr p-end-wcs)) 2.0) 0.0))
                  (setq p-base (vlax-curve-getClosestPointTo *tsp-boundary-ent* mid-pt))
                )
                (setq p-base p-base-click)
              )
              
              ;; 기존 임시 객체 초기화 (중첩 방지)
              (foreach e manual-drawn-ents (if (entget e) (vl-catch-all-apply 'entdel (list e))))
              (setq manual-drawn-ents '())
              
              (setq is-curve-closed (vlax-curve-isClosed *tsp-boundary-ent*))
              (setq max-dist-curve (vlax-curve-getDistAtParam *tsp-boundary-ent* (vlax-curve-getEndParam *tsp-boundary-ent*)))
              (setq cur-dist (vlax-curve-getDistAtPoint *tsp-boundary-ent* p-base))
              
              ;; 2. 화면 좌/우 방향 동기화 
              (setq param-base (vlax-curve-getParamAtPoint *tsp-boundary-ent* p-base))
              (setq deriv (vlax-curve-getFirstDeriv *tsp-boundary-ent* param-base))
              (setq screen-ang (angle '(0 0 0) deriv))
              
              (setq dir-sign 1)
              (cond
                ((< (cos screen-ang) -1e-4) (setq dir-sign -1))
                ((and (< (abs (cos screen-ang)) 1e-4) (< (sin screen-ang) -1e-4)) (setq dir-sign -1))
              )

              ;; 모드별 초기 버팀보 작도 분기 및 초기 점(init-pts) 수집
              (setq init-ents '())
              (setq init-pts '())
              (if (= start-mode "2") ; 간격 중심 시작 (중앙 비우고 양쪽 배치)
                (progn
                  (setq dist-L (- cur-dist (* dir-sign (/ ctc-dist 2.0))))
                  (setq dist-R (+ cur-dist (* dir-sign (/ ctc-dist 2.0))))
                  
                  (if (< dist-L 0.0) (setq dist-L (if is-curve-closed (+ max-dist-curve dist-L) nil)))
                  (if (and dist-L (> dist-L max-dist-curve)) (setq dist-L (if is-curve-closed (- dist-L max-dist-curve) nil)))
                  
                  (if (> dist-R max-dist-curve) (setq dist-R (if is-curve-closed (- dist-R max-dist-curve) nil)))
                  (if (and dist-R (< dist-R 0.0)) (setq dist-R (if is-curve-closed (+ max-dist-curve dist-R) nil)))
                  
                  (setq ents-L '() ents-R '())
                  (if dist-L 
                    (progn
                      (setq p-L (vlax-curve-getPointAtDist *tsp-boundary-ent* dist-L))
                      (if (= (get-seg-idx-for-pt p-L) target-seg-idx) 
                        (progn
                          (setq res-L (draw-dynamic-strut p-L))
                          (if res-L (progn (setq ents-L (car res-L)) (setq init-pts (append init-pts (list (cadr res-L))))))
                        )
                      )
                    )
                  )
                  (if dist-R 
                    (progn
                      (setq p-R (vlax-curve-getPointAtDist *tsp-boundary-ent* dist-R))
                      (if (= (get-seg-idx-for-pt p-R) target-seg-idx) 
                        (progn
                          (setq res-R (draw-dynamic-strut p-R))
                          (if res-R (progn (setq ents-R (car res-R)) (setq init-pts (append init-pts (list (cadr res-R))))))
                        )
                      )
                    )
                  )
                  (setq init-ents (append ents-L ents-R))
                  (setq dist-A dist-L dist-D dist-R)
                )
                (progn ; 0: 클릭 위치, 1: 세그먼트 중점
                  (setq res-base (draw-dynamic-strut p-base))
                  (if res-base (progn (setq init-ents (car res-base)) (setq init-pts (list (cadr res-base)))))
                  (setq dist-A cur-dist dist-D cur-dist)
                )
              )
              
              (if init-ents
                (progn
                  (setq manual-drawn-ents (append manual-drawn-ents init-ents))
                  (command "_.REGEN")
                  (princ "\n[성공] 기준 위치 설정 및 초기 작도 완료.")
                  
                  (setq strut-history '())
                  (setq temp-brace-ents '())
                  
                  ;; 상위 제원 상태 박제
                  (setq main-sec-str (nth 6 restore-data))
                  (setq main-is-double (if (>= (nth 4 restore-data) 2) T nil))
                  (setq main-s-brace-opt (if (> (length restore-data) 11) (nth 11 restore-data) nil))
                  
                  (setq loop-grread T)
                  (setq return-to-dialog nil)
                  (setq commit-drawing nil)
                  
                  ;; 순수 좌표 집계 방식의 실시간 연속 보강재 오버레이 함수
                  (defun update-dynamic-braces ( / all-pts hist active-seg-id )
                    (foreach e temp-brace-ents (if (entget e) (vl-catch-all-apply 'entdel (list e))))
                    (setq temp-brace-ents '())
                    (if (and main-s-brace-opt (= (nth 0 main-s-brace-opt) "1"))
                      (progn
                        ;; XDATA에 의존하지 않고 grread 입력 배열 점들을 직접 리스트로 실시간 결합
                        (setq all-pts init-pts)
                        (foreach hist strut-history
                          (setq all-pts (append all-pts (caddr hist)))
                        )
                        ;; 현재 작업 중인 세그먼트 ID 추출 방어 로직 적용
      (setq active-seg-id (if (and target-seg-idx (nth target-seg-idx *segment-list*)) (cdr (assoc 'ID (nth target-seg-idx *segment-list*))) 0))
      
      ;; [안전 바인딩(Fallback) 보강] 실제 작도된 버팀보의 양끝단 좌표를 추적하여 실시간 길이를 mm단위로 도출
      (setq cur-strut-len strut-len)
      (if (and all-pts (> (length all-pts) 0) (listp (car all-pts)) (= (length (car all-pts)) 2))
        (setq cur-strut-len (distance (caar all-pts) (cadar all-pts)))
      )
      
      ;; 혹시라도 실시간 좌표 추출에 실패했을 경우를 대비한 최후의 방어막
      (if (or (null cur-strut-len) (= cur-strut-len 0.0))
        (setq cur-strut-len (if (and target-seg-idx (nth target-seg-idx *segment-list*))
                          (cdr (assoc 'LENGTH (nth target-seg-idx *segment-list*)))
                          0.0))
      )

      (if (null strut-ang)
        (setq strut-ang (if (and target-seg-idx (nth target-seg-idx *segment-list*))
                          (cdr (assoc 'ANGLE (nth target-seg-idx *segment-list*)))
                          0.0))
      )

      ;; 정밀 추적용 인자 리스트 구조 확장 호출 (실시간 갱신된 실제 길이 cur-strut-len 적용)
      (setq temp-brace-ents (tsp-draw-realtime-continuous-braces all-pts main-s-brace-opt main-sec-str main-is-double strut-ang cur-strut-len active-seg-id))
                      )
                    )
                  )
                  (update-dynamic-braces) ;; 최초 작도 시 배치 적용
                  
                  (princ "\n[배열 모드] A: 왼쪽 | D: 오른쪽 | W: 양측 동시 | S: 취소(Undo) | B: 입력창 복귀 | Enter/Space/우클릭: 완료")
                  
                  ;; 3. 동적 배열(grread) 루프 시작 (ESC 안전 방어 적용)
                  (while loop-grread
                    (setq gr (vl-catch-all-apply 'grread (list T 12 0)))
                    (if (vl-catch-all-error-p gr)
                      (progn
                        ;; ESC Pressed during grread
                        (foreach e manual-drawn-ents (if (entget e) (vl-catch-all-apply 'entdel (list e))))
                        (foreach e temp-brace-ents (if (entget e) (vl-catch-all-apply 'entdel (list e))))
                        (setq manual-drawn-ents '() temp-brace-ents '())
                        (setq loop-grread nil return-to-dialog T)
                        (princ "\n[취소] ESC 입력 감지. 작도를 취소하고 입력창으로 돌아갑니다.")
                      )
                      (progn
                        (setq code (car gr) val (cadr gr))
                        (cond
                          ((= code 2) ;; 키보드 입력
                           (cond
                             ;; [B 키] 입력창으로 돌아가기 (안전장치)
                             ((or (= val 66) (= val 98))
                              (foreach e manual-drawn-ents (if (entget e) (vl-catch-all-apply 'entdel (list e))))
                              (foreach e temp-brace-ents (if (entget e) (vl-catch-all-apply 'entdel (list e))))
                              (setq manual-drawn-ents '() temp-brace-ents '())
                              (setq loop-grread nil return-to-dialog T)
                              (princ "\n[취소] B키 입력 감지. 작도를 취소하고 입력창으로 돌아갑니다.")
                             )
                             ;; [A 키] 화면 왼쪽 복사
                             ((or (= val 65) (= val 97))
                              (setq next-dist (- dist-A (* dir-sign ctc-dist)))
                              (if (< next-dist 0.0) (setq next-dist (if is-curve-closed (+ max-dist-curve next-dist) nil)))
                              (if (and next-dist (> next-dist max-dist-curve)) (setq next-dist (if is-curve-closed (- next-dist max-dist-curve) nil)))
                              (if next-dist
                                (progn
                                  (setq new-p-base (vlax-curve-getPointAtDist *tsp-boundary-ent* next-dist))
                                  (if (/= (get-seg-idx-for-pt new-p-base) target-seg-idx)
                                    (princ "\n[알림] 현재 세그먼트 경계를 벗어나 작도를 중단합니다.")
                                    (progn
                                      (setq res-A (draw-dynamic-strut new-p-base))
                                      (if res-A
                                        (progn
                                          (setq new-ents (car res-A) real-pt1 (cadr res-A))
                                          (setq strut-history (cons (list 'A new-ents (list real-pt1) dist-A) strut-history))
                                          (setq dist-A next-dist manual-drawn-ents (append manual-drawn-ents new-ents))
                                          (update-dynamic-braces) ;; 실시간 보강재 갱신
                                          (princ (strcat "\n[추가] 좌측 C.T.C " (rtos ctc-input 2 2) "m 배열 완료."))
                                        )
                                      )
                                    )
                                  )
                                )
                                (princ "\n[알림] 경계선의 끝에 도달하여 더 이상 왼쪽으로 배열할 수 없습니다.")
                              )
                             )
                             ;; [D 키] 화면 오른쪽 복사
                             ((or (= val 68) (= val 100))
                              (setq next-dist (+ dist-D (* dir-sign ctc-dist)))
                              (if (> next-dist max-dist-curve) (setq next-dist (if is-curve-closed (- next-dist max-dist-curve) nil)))
                              (if (and next-dist (< next-dist 0.0)) (setq next-dist (if is-curve-closed (+ max-dist-curve next-dist) nil)))
                               (if next-dist
                                (progn
                                  (setq new-p-base (vlax-curve-getPointAtDist *tsp-boundary-ent* next-dist))
                                  (if (/= (get-seg-idx-for-pt new-p-base) target-seg-idx)
                                    (princ "\n[알림] 현재 세그먼트 경계를 벗어나 작도를 중단합니다.")
                                    (progn
                                      (setq res-D (draw-dynamic-strut new-p-base))
                                      (if res-D
                                        (progn
                                          (setq new-ents (car res-D) real-pt1 (cadr res-D))
                                          (setq strut-history (cons (list 'D new-ents (list real-pt1) dist-D) strut-history))
                                          (setq dist-D next-dist manual-drawn-ents (append manual-drawn-ents new-ents))
                                          (update-dynamic-braces) ;; 실시간 보강재 갱신
                                          (princ (strcat "\n[추가] 우측 C.T.C " (rtos ctc-input 2 2) "m 배열 완료."))
                                        )
                                      )
                                    )
                                  )
                                )
                                (princ "\n[알림] 경계선의 끝에 도달하여 더 이상 오른쪽으로 배열할 수 없습니다.")
                              )
                             )
                             ;; [W 키] 양쪽 동시 복사
                              ((or (= val 87) (= val 119))
                               (setq combined-ents '() cur-w-pts '() orig-dist-A dist-A orig-dist-D dist-D)
                               ;; 좌측 계산
                               (setq next-dist-L (- dist-A (* dir-sign ctc-dist)))
                               (if (< next-dist-L 0.0) (if is-curve-closed (setq next-dist-L (+ max-dist-curve next-dist-L)) (setq next-dist-L nil)))
                               (if (and next-dist-L (> next-dist-L max-dist-curve)) (setq next-dist-L (if is-curve-closed (- next-dist-L max-dist-curve) nil)))
                               (if next-dist-L
                                 (progn
                                   (setq new-p-base-L (vlax-curve-getPointAtDist *tsp-boundary-ent* next-dist-L))
                                   (if (/= (get-seg-idx-for-pt new-p-base-L) target-seg-idx)
                                     (princ "\n[알림] 좌측은 현재 세그먼트 경계를 벗어났습니다.")
                                     (progn
                                       (setq res-L (draw-dynamic-strut new-p-base-L))
                                       (if res-L (progn (setq ents-L (car res-L) real-pt1-L (cadr res-L)) (setq combined-ents (append combined-ents ents-L) dist-A next-dist-L cur-w-pts (append cur-w-pts (list real-pt1-L)))))
                                     )
                                   )
                                 )
                               )
                               ;; 우측 계산
                               (setq next-dist-R (+ dist-D (* dir-sign ctc-dist)))
                               (if (> next-dist-R max-dist-curve) (if is-curve-closed (setq next-dist-R (- next-dist-R max-dist-curve)) (setq next-dist-R nil)))
                               (if (and next-dist-R (< next-dist-R 0.0)) (setq next-dist-R (if is-curve-closed (+ max-dist-curve next-dist-R) nil)))
                               (if next-dist-R
                                 (progn
                                   (setq new-p-base-R (vlax-curve-getPointAtDist *tsp-boundary-ent* next-dist-R))
                                   (if (/= (get-seg-idx-for-pt new-p-base-R) target-seg-idx)
                                     (princ "\n[알림] 우측은 현재 세그먼트 경계를 벗어났습니다.")
                                     (progn
                                       (setq res-R (draw-dynamic-strut new-p-base-R))
                                       (if res-R (progn (setq ents-R (car res-R) real-pt1-R (cadr res-R)) (setq combined-ents (append combined-ents ents-R) dist-D next-dist-R cur-w-pts (append cur-w-pts (list real-pt1-R)))))
                                     )
                                   )
                                 )
                               )
                               (if combined-ents
                                 (progn
                                   (setq strut-history (cons (list 'W combined-ents cur-w-pts orig-dist-A orig-dist-D) strut-history))
                                   (setq manual-drawn-ents (append manual-drawn-ents combined-ents))
                                   (update-dynamic-braces) ;; 실시간 보강재 갱신
                                   (princ "\n[추가] 양측 동시 배열 작도 완료.")
                                 )
                                 (princ "\n[알림] 양쪽 모두 경계선 끝에 도달했습니다.")
                               )
                              )
                             ;; [M 키] 도면 거리 측정 (Measure)
                              ((or (= val 77) (= val 109))
                               (princ "\n[측정] 시작점을 클릭하세요 (객체 스냅 사용 가능): ")
                               (setq m-pt1 (getpoint))
                               (if m-pt1
                                 (progn
                                   (princ "\n[측정] 끝점을 클릭하세요: ")
                                   (setq m-pt2 (getpoint m-pt1))
                                   (if m-pt2
                                     (progn
                                       (setq m-dist (distance m-pt1 m-pt2))
                                       (alert (strcat "측정 거리: " (rtos m-dist 2 1) " mm (" (rtos (/ m-dist 1000.0) 2 3) " m)"))
                                       (princ (strcat "\n>> 측정 완료: " (rtos m-dist 2 1) " mm"))
                                     )
                                   )
                                 )
                                )
                               (princ "\n[배열 모드] A: 왼쪽 | D: 오른쪽 | W: 양측 동시 | S: 취소 | M: 거리 측정 | B: 복귀 | Enter/Space/우클릭: 완료")
                              )
                             ;; [S 키] 실행 취소 (Undo)
                             ((or (= val 83) (= val 115))
                              (if (> (length strut-history) 0)
                                (progn
                                  (setq last-action (car strut-history) act-type (car last-action) act-ents (cadr last-action))
                                  (foreach e act-ents (if (entget e) (vl-catch-all-apply 'entdel (list e))))
                                  ;; 취소된 객체를 리스트에서 제외하여 실시간 보강재 연산에서 제외시킴
                                  (foreach e act-ents (setq manual-drawn-ents (vl-remove e manual-drawn-ents)))
                                  (cond
                                    ((= act-type 'A) (setq dist-A (nth 3 last-action)))
                                    ((= act-type 'D) (setq dist-D (nth 3 last-action)))
                                    ((= act-type 'W) (setq dist-A (nth 3 last-action) dist-D (nth 4 last-action)))
                                  )
                                  (setq strut-history (cdr strut-history))
                                  (update-dynamic-braces) ;; 실시간 보강재 갱신 (줄어든 상태 반영)
                                  (princ "\n[취소] 가장 최근에 추가된 버팀보 배열을 취소(Undo)했습니다.")
                                )
                                (princ "\n[알림] 더 이상 취소할 배열 내역이 없습니다.")
                               )
                             )
                             ;; [Enter 또는 Space] 완료
                             ((or (= val 13) (= val 32))
                              (setq loop-grread nil commit-drawing T)
                              (setq manual-drawn-ents (append manual-drawn-ents temp-brace-ents)) ;; 확정 시 임시 보강재를 영구 리스트에 합병
                              (princ "\n[완료] 동적 배열 작업을 종료하고 다이얼로그로 복귀합니다.")
                             )
                           )
                          )
                          ;; [마우스 우클릭] 완료 처리 (grread 11, 25 코드 대응)
                          ((or (= code 11) (= code 25))
                           (setq loop-grread nil commit-drawing T)
                           (setq manual-drawn-ents (append manual-drawn-ents temp-brace-ents)) ;; 확정 시 임시 보강재를 영구 리스트에 합병
                           (princ "\n[완료] 동적 배열 작업을 종료하고 다이얼로그로 복귀합니다.")
                          )
                        )
                      )
                    )
                  ) ;; end while loop-grread
                  
                  ;; 루프 종료 후 데이터 처리 (완료 vs 취소)
                  (if commit-drawing
                    (progn
                      ;; 정상 완료: 점 데이터 취합 (순서대로 정렬)
                      (setq final-pts init-pts)
                      (foreach hist (reverse strut-history)
                        (setq final-pts (append final-pts (caddr hist)))
                      )
                      ;; 누적(append)하지 않고, 새로 작도한 점으로 완벽히 교체(Replace)
                      (setq manual-pts final-pts)
                      
                      ;; 교체된 점 데이터를 restore-data에 업데이트하여 다이얼로그로 복귀
                      (setq restore-data (list (nth 0 restore-data) (nth 1 restore-data) (nth 2 restore-data) (nth 3 restore-data) 
                                               (nth 4 restore-data) (nth 5 restore-data) (nth 6 restore-data) (nth 7 restore-data) 
                                               manual-pts ;; 새로운 점으로 덮어쓰기
                                               (nth 9 restore-data) (nth 10 restore-data) (nth 11 restore-data)))
                      (setq restore-action T)
                    )
                    (if return-to-dialog
                      (progn
                        ;; 취소(ESC) 시 날아갔던 데이터를 원래 상태로 롤백(Rollback)
                        (setq manual-pts orig-manual-pts)
                        (setq restore-data (list (nth 0 restore-data) (nth 1 restore-data) (nth 2 restore-data) (nth 3 restore-data) 
                                                 (nth 4 restore-data) (nth 5 restore-data) (nth 6 restore-data) (nth 7 restore-data) 
                                                 orig-manual-pts ;; 백업해둔 원래 점으로 복구
                                                 (nth 9 restore-data) (nth 10 restore-data) (nth 11 restore-data)))
                        (setq restore-action T)
                      )
                    )
                  )
                )
                (progn
                  (princ "\n[오류] 기준 위치에 버팀보를 작도할 수 없는 구역입니다.")
                  (setq restore-action T)
                )
              )
            )
            (progn 
              (princ "\n[알림] 기준점 입력이 취소되었습니다. 창으로 돌아갑니다.") 
              (setq manual-pts nil)
              (setq restore-action T)
            )
          )
        )
       )
      )
    
    (if (or (= result 1) (= result 2) (= result 0))
      (setq loop-support nil)
    )
  )
  
  (unload_dialog dcl-id)
  result
)


;;;;==========================================================================
;;;; defun tsp-is-point-inside : 점이 다각형(폴리라인) 내부에 있는지 판별 (Ray-casting 알고리즘)
;;;;==========================================================================
(defun tsp-is-point-inside (pt verts / c i j p1 p2 pt-x pt-y)
  (setq c nil)
  (setq pt-x (car pt) pt-y (cadr pt))
  (setq i 0 j (1- (length verts)))
  (while (< i (length verts))
    (setq p1 (nth i verts) p2 (nth j verts))
    (if (and (not (equal (cadr p1) (cadr p2) 1e-6))
             (or (and (<= (cadr p1) pt-y) (> (cadr p2) pt-y))
                 (and (<= (cadr p2) pt-y) (> (cadr p1) pt-y))))
      (if (< pt-x (+ (car p1) (* (/ (- (car p2) (car p1)) (- (cadr p2) (cadr p1))) (- pt-y (cadr p1)))))
        (setq c (not c))
      )
    )
    (setq j i i (1+ i))
  )
  c
)


;;;;==========================================================================
;;;; defun tsp-draw-manual-strut : 수동 버팀보 평면 객체 작도 (N등분/2H/말뚝 통합)
;;;;==========================================================================
(defun tsp-draw-manual-strut
  (pt1 pt2 sec-str jack-type is-double s-brace-opt seg-id
   / boundary-handle start-ent clean-sec-str strut-vals
     b tw h tf half-b half-tw strut-ang pt-dir jack-len plate-thick
     strut-offsets s-off sub-idx pt-jack-end pt-beam-start pt-beam-end
     pl1-p1 pl1-p2 pl1-p3 pl1-p4 pl2-p1 pl2-p2 pl2-p3 pl2-p4
     p1-out p2-out p3-out p4-out p1-in p2-in p3-in p4-in
     pt-jack-ins jack-block-name jack-rot strut-xdata strut-len
     total-L L-max num-div interval offsets spatial-idx is-valid-post
     invert-val p-center post-rot y_scale p-ins post-block new-ents nxt
     cur-pt1 cur-pt2 b-width stiff-enable slender-limit is-manual
     manual-interval post-enable post-layout post-invert post-side
     i strut-sys-half-width margin brace-len p-brace-1 p-brace-2
     post-half-h lateral-dist)

  ;; 작도 시작 전 마지막 객체를 기억
  (setq start-ent (entlast))
  (setq boundary-handle (tsp-get-entity-handle *tsp-boundary-ent*))

  ;; 1. 제원 파싱 및 레이어 생성 (2H 텍스트 제거 후 순수 규격 파싱)
  (setq clean-sec-str sec-str)
  (if (wcmatch clean-sec-str "2H *")
    (setq clean-sec-str (vl-string-subst "" "2H " clean-sec-str))
  )

  (setq strut-vals (parse-h-spec clean-sec-str))
  (if (null strut-vals)
    (setq strut-vals '(300 300 10 15))
  )

  (setq h (nth 0 strut-vals)
        b (nth 1 strut-vals)
        tw (nth 2 strut-vals)
        tf (nth 3 strut-vals))

  (setq half-b (/ b 2.0)
        half-tw (/ tw 2.0))

  (create-layer-if-not-exists "_버팀보(Strut)" "3")
  (create-layer-if-not-exists "_중간말뚝(Post pile)" "3")
  (create-layer-if-not-exists "_보강재(Brace)" "7")

  (if (not (tblsearch "LTYPE" "DASHED"))
    (vl-catch-all-apply
      'vla-load
      (list
        (vla-get-linetypes (vla-get-activedocument (vlax-get-acad-object)))
        "DASHED"
        (if (= (getvar "MEASUREMENT") 1) "acadiso.lin" "acad.lin")
      )
    )
  )

  (create-strut-jack-block)
  (create-strut-screw-jack-block)

  ;; 2. 각도, 방향 및 오프셋(2H) 설정
  (setq strut-ang (angle pt1 pt2))
  (setq pt-dir (+ strut-ang (/ pi 2.0)))
  (setq strut-len (distance pt1 pt2))

  ;; 2H 맞버팀대 여부에 따른 작도 오프셋 (기본 0.0, 2H는 폭(b)만큼 이격)
  (setq b-width b)
  (setq strut-offsets (if is-double (list b-width (- b-width)) (list 0.0)))

  ;; 전체 버팀보 시스템의 중심 기준 절반 폭
  ;; 1H는 b/2, 2H는 b이격 + b/2 = 1.5b
  (setq strut-sys-half-width (if is-double (* b 1.5) (/ b 2.0)))

  ;; XDATA 공통 생성 (세그먼트 식별 및 수동 제어용 정보 박제)
  (if (not (tblsearch "APPID" "TSP_STRUT_SPEC"))
    (regapp "TSP_STRUT_SPEC")
  )

  (setq strut-xdata
    (list
      -3
      (list
        "TSP_STRUT_SPEC"
        (cons 1070 seg-id)
        (cons 1040 (float (* strut-sys-half-width 2.0))) ;; XDATA 식별용 가상 폭(RECT 검증용)
        (cons 1010 pt1)
        (cons 1010 pt2)
        (cons 1040 (float h))
        (cons 1040 (float tw))
        (cons 1040 (float tf))
        (cons 1000 "MANUAL_STRUT")
        (cons 1000 boundary-handle)
        (cons 1040 (float b))
      )
    )
  )

  ;; 3. 메인 부재(Flange, Web) 및 잭(Jack) 반복 작도 (1H or 2H)
  (setq sub-idx 0)

  (foreach s-off strut-offsets
    (setq cur-pt1 (polar pt1 pt-dir s-off))
    (setq cur-pt2 (polar pt2 pt-dir s-off))

    (setq jack-len 583.0
          plate-thick 14.0)

    ;; 함수: tsp-draw-manual-strut 내부 마감판 좌표 산출 및 교체 영역
    ;; 맞버팀대의 경우 잭 위치를 지그재그로 교차 배치
    (if (and is-double (= sub-idx 1))
      (progn
        (setq pt-jack-end (polar cur-pt2 (+ strut-ang pi) jack-len))
        (setq pt-beam-start (polar cur-pt1 strut-ang plate-thick))
        (setq pt-beam-end (polar pt-jack-end (+ strut-ang pi) plate-thick))
        (setq pt-jack-ins cur-pt2)
        (setq jack-rot (+ strut-ang pi))

        ;; 마감판 1 좌표 산출 (cur-pt1 ~ pt-beam-start 구간)
        (setq pl1-p1 (polar cur-pt1 pt-dir half-b)
              pl1-p2 (polar pt-beam-start pt-dir half-b))
        (setq pl1-p3 (polar pt-beam-start (- pt-dir pi) half-b)
              pl1-p4 (polar cur-pt1 (- pt-dir pi) half-b))

        ;; 마감판 2 좌표 산출 (pt-beam-end ~ pt-jack-end 구간)
        (setq pl2-p1 (polar pt-beam-end pt-dir half-b)
              pl2-p2 (polar pt-jack-end pt-dir half-b))
        (setq pl2-p3 (polar pt-jack-end (- pt-dir pi) half-b)
              pl2-p4 (polar pt-beam-end (- pt-dir pi) half-b))
      )
      (progn
        (setq pt-jack-end (polar cur-pt1 strut-ang jack-len))
        (setq pt-beam-start (polar pt-jack-end strut-ang plate-thick))
        (setq pt-beam-end (polar cur-pt2 (+ strut-ang pi) plate-thick))
        (setq pt-jack-ins cur-pt1)
        (setq jack-rot strut-ang)

        ;; 마감판 1 좌표 산출 (pt-jack-end ~ pt-beam-start 구간)
        (setq pl1-p1 (polar pt-jack-end pt-dir half-b)
              pl1-p2 (polar pt-beam-start pt-dir half-b))
        (setq pl1-p3 (polar pt-beam-start (- pt-dir pi) half-b)
              pl1-p4 (polar pt-jack-end (- pt-dir pi) half-b))

        ;; 마감판 2 좌표 산출 (pt-beam-end ~ cur-pt2 구간)
        (setq pl2-p1 (polar pt-beam-end pt-dir half-b)
              pl2-p2 (polar cur-pt2 pt-dir half-b))
        (setq pl2-p3 (polar cur-pt2 (- pt-dir pi) half-b)
              pl2-p4 (polar pt-beam-end (- pt-dir pi) half-b))
      )
    )

    ;; 외곽선(Flange) 작도
    (setq p1-out (polar pt-beam-start pt-dir half-b)
          p2-out (polar pt-beam-end pt-dir half-b))
    (setq p3-out (polar pt-beam-start (- pt-dir pi) half-b)
          p4-out (polar pt-beam-end (- pt-dir pi) half-b))

    (entmake
      (append
        (list
          '(0 . "LWPOLYLINE")
          '(100 . "AcDbEntity")
          '(100 . "AcDbPolyline")
          '(8 . "_버팀보(Strut)")
          '(62 . 3)
          '(90 . 4)
          '(70 . 1)
          (list 10 (car p1-out) (cadr p1-out))
          (list 10 (car p2-out) (cadr p2-out))
          (list 10 (car p4-out) (cadr p4-out))
          (list 10 (car p3-out) (cadr p3-out)))
        (list strut-xdata)
      )
    )

    ;; 양 끝단 마감판(End Plate) 1 및 2 생성
    (entmake
      (append
        (list
          '(0 . "LWPOLYLINE")
          '(100 . "AcDbEntity")
          '(100 . "AcDbPolyline")
          '(8 . "_버팀보(Strut)")
          '(62 . 3)
          '(90 . 4)
          '(70 . 1)
          (list 10 (car pl1-p1) (cadr pl1-p1))
          (list 10 (car pl1-p2) (cadr pl1-p2))
          (list 10 (car pl1-p3) (cadr pl1-p3))
          (list 10 (car pl1-p4) (cadr pl1-p4)))
        (list strut-xdata)
      )
    )

    (entmake
      (append
        (list
          '(0 . "LWPOLYLINE")
          '(100 . "AcDbEntity")
          '(100 . "AcDbPolyline")
          '(8 . "_버팀보(Strut)")
          '(62 . 3)
          '(90 . 4)
          '(70 . 1)
          (list 10 (car pl2-p1) (cadr pl2-p1))
          (list 10 (car pl2-p2) (cadr pl2-p2))
          (list 10 (car pl2-p3) (cadr pl2-p3))
          (list 10 (car pl2-p4) (cadr pl2-p4)))
        (list strut-xdata)
      )
    )

    ;; 점선(Web)
    (setq p1-in (polar pt-beam-start pt-dir half-tw)
          p2-in (polar pt-beam-end pt-dir half-tw))
    (setq p3-in (polar pt-beam-start (- pt-dir pi) half-tw)
          p4-in (polar pt-beam-end (- pt-dir pi) half-tw))

    (entmake
      (append
        (list
          '(0 . "LWPOLYLINE")
          '(100 . "AcDbEntity")
          '(100 . "AcDbPolyline")
          '(8 . "_버팀보(Strut)")
          '(62 . 1)
          '(6 . "DASHED")
          (cons 48
                (* (if (and (boundp '*tsp-scale-plan*) *tsp-scale-plan*)
                     *tsp-scale-plan*
                     600.0)
                   (/ 500.0 600.0)
                   (if (= (getvar "MEASUREMENT") 1) (/ 1.0 25.0) 1.0)))
          '(90 . 2)
          '(70 . 0)
          (list 10 (car p1-in) (cadr p1-in))
          (list 10 (car p2-in) (cadr p2-in)))
        (list strut-xdata)
      )
    )

    (entmake
      (append
        (list
          '(0 . "LWPOLYLINE")
          '(100 . "AcDbEntity")
          '(100 . "AcDbPolyline")
          '(8 . "_버팀보(Strut)")
          '(62 . 1)
          '(6 . "DASHED")
          (cons 48
                (* (if (and (boundp '*tsp-scale-plan*) *tsp-scale-plan*)
                     *tsp-scale-plan*
                     600.0)
                   (/ 500.0 600.0)
                   (if (= (getvar "MEASUREMENT") 1) (/ 1.0 25.0) 1.0)))
          '(90 . 2)
          '(70 . 0)
          (list 10 (car p3-in) (cadr p3-in))
          (list 10 (car p4-in) (cadr p4-in)))
        (list strut-xdata)
      )
    )

    ;; 잭(Jack) 삽입
    (if (or (equal jack-type "스크류잭") (equal jack-type "1"))
      (setq jack-block-name "스크류잭")
      (setq jack-block-name "유압잭")
    )

    (entmake
      (list
        '(0 . "INSERT")
        (cons 2 jack-block-name)
        (cons 8 (if (equal jack-block-name "스크류잭") "_스크류잭" "_유압잭"))
        '(62 . 2)
        (cons 10 pt-jack-ins)
        '(41 . 1.0)
        '(42 . 1.0)
        '(43 . 1.0)
        (cons 50 jack-rot))
    )

    (setq sub-idx (1+ sub-idx))
  )

  ;; 4. 보강재(Brace) 및 중간말뚝 N등분 배치 및 작도 로직
  (if s-brace-opt
    (progn
      (setq stiff-enable   (nth 0 s-brace-opt)
            slender-limit (nth 1 s-brace-opt)
            is-manual     (nth 2 s-brace-opt)
            manual-interval (nth 3 s-brace-opt))

      (setq margin (atof (nth 4 s-brace-opt)))
      (setq post-enable (nth 5 s-brace-opt)
            post-layout (nth 6 s-brace-opt)
            post-invert (nth 7 s-brace-opt)
            post-side   (nth 8 s-brace-opt))

      (setq total-L (/ strut-len 1000.0))
      (setq L-max (tsp-calc-unsupported-length strut-vals (if (= slender-limit "0") 100.0 120.0)))

      (setq offsets '())

      ;; 세장비를 초과하거나 수동 간격이 켜져있을 때만 등분 계산 수행
      ;; 작도될 때마다 현재 버팀보의 실제 길이를 전역 변수에 저장하여 DCL로 전달
      (setq *tsp-last-strut-len* strut-len)

      (if (or (> total-L L-max) (= is-manual "1"))
        (progn
          (if (= is-manual "1")
            (progn
              (setq interval (* (atof manual-interval) 1000.0))
              (if (> interval 0.01)
                (progn
                  (setq num-div (fix (/ strut-len interval))
                        i 1)
                  (while (<= i num-div)
                    (setq offsets (append offsets (list (* i interval))))
                    (setq i (1+ i))
                  )
                )
              )
            )
            (progn
              (setq num-div (fix (+ (/ total-L L-max) 0.9999))
                    interval (/ strut-len num-div)
                    i 1)

              ;; 자동 계산된 간격 값을 전역 변수에 저장하여 DCL 입력칸에 자동 표기
              (setq *tsp-last-calc-interval* (/ interval 1000.0))

              (while (< i num-div)
                (setq offsets (append offsets (list (* i interval))))
                (setq i (1+ i))
              )
            )
          )
        )
      )

      (if (> (length offsets) 0)
        (progn
          (setq spatial-idx 0)
          (setq post-block (create-post-pile-block h b tw tf))

          ;; 보강재 선 길이 산출 (절반 폭 + 여유장)
          (setq brace-len (+ strut-sys-half-width margin))

          (foreach off offsets
            (setq p-center (polar pt1 strut-ang off))

            ;; 수직 보강재(Brace) H형강 풀스펙(외곽선+점선) 작도
            ;; 메인 버팀보 기준 분할 작도 (Trim 효과 및 2H 중앙 간극 처리 적용)
            (if (= stiff-enable "1")
              (progn
                (setq p-brace-1 (polar p-center (+ strut-ang (/ pi 2.0)) brace-len))
                (setq p-brace-2 (polar p-center (- strut-ang (/ pi 2.0)) brace-len))

                ;; 메인 버팀보에 가려지는 영역을 제외한 시작점(Inner) 산출
                (setq p-brace-1-inner (polar p-center (+ strut-ang (/ pi 2.0)) strut-sys-half-width))
                (setq p-brace-2-inner (polar p-center (- strut-ang (/ pi 2.0)) strut-sys-half-width))

                ;; 1. 외곽선(Flange)
                ;; 방향 1 (p-brace-1 측)
                (setq f1-1 (polar p-brace-1 strut-ang half-b))
                (setq f1-2 (polar p-brace-1-inner strut-ang half-b))
                (setq f1-3 (polar p-brace-1-inner (+ strut-ang pi) half-b))
                (setq f1-4 (polar p-brace-1 (+ strut-ang pi) half-b))

                (entmake
                  (append
                    (list
                      '(0 . "LWPOLYLINE")
                      '(100 . "AcDbEntity")
                      '(100 . "AcDbPolyline")
                      '(8 . "_보강재(Brace)")
                      '(62 . 256)
                      '(90 . 4)
                      '(70 . 1)
                      (list 10 (car f1-1) (cadr f1-1))
                      (list 10 (car f1-2) (cadr f1-2))
                      (list 10 (car f1-3) (cadr f1-3))
                      (list 10 (car f1-4) (cadr f1-4)))
                    (list strut-xdata)
                  )
                )

                ;; 방향 2 (p-brace-2 측)
                (setq f2-1 (polar p-brace-2-inner strut-ang half-b))
                (setq f2-2 (polar p-brace-2 strut-ang half-b))
                (setq f2-3 (polar p-brace-2 (+ strut-ang pi) half-b))
                (setq f2-4 (polar p-brace-2-inner (+ strut-ang pi) half-b))

                (entmake
                  (append
                    (list
                      '(0 . "LWPOLYLINE")
                      '(100 . "AcDbEntity")
                      '(100 . "AcDbPolyline")
                      '(8 . "_보강재(Brace)")
                      '(62 . 256)
                      '(90 . 4)
                      '(70 . 1)
                      (list 10 (car f2-1) (cadr f2-1))
                      (list 10 (car f2-2) (cadr f2-2))
                      (list 10 (car f2-3) (cadr f2-3))
                      (list 10 (car f2-4) (cadr f2-4)))
                    (list strut-xdata)
                  )
                )

                ;; 2. 웹(Web) 점선
                ;; 방향 1
                (setq w1-1 (polar p-brace-1 strut-ang half-tw))
                (setq w1-2 (polar p-brace-1-inner strut-ang half-tw))
                (setq w1-3 (polar p-brace-1 (+ strut-ang pi) half-tw))
                (setq w1-4 (polar p-brace-1-inner (+ strut-ang pi) half-tw))

                (entmake
                  (append
                    (list
                      '(0 . "LWPOLYLINE")
                      '(100 . "AcDbEntity")
                      '(100 . "AcDbPolyline")
                      '(8 . "_보강재(Brace)")
                      '(62 . 1)
                      '(6 . "DASHED")
                      (cons 48
                            (* (if (and (boundp '*tsp-scale-plan*) *tsp-scale-plan*)
                                 *tsp-scale-plan*
                                 600.0)
                               (/ 500.0 600.0)))
                      '(90 . 2)
                      '(70 . 0)
                      (list 10 (car w1-1) (cadr w1-1))
                      (list 10 (car w1-2) (cadr w1-2)))
                    (list strut-xdata)
                  )
                )

                (entmake
                  (append
                    (list
                      '(0 . "LWPOLYLINE")
                      '(100 . "AcDbEntity")
                      '(100 . "AcDbPolyline")
                      '(8 . "_보강재(Brace)")
                      '(62 . 1)
                      '(6 . "DASHED")
                      (cons 48
                            (* (if (and (boundp '*tsp-scale-plan*) *tsp-scale-plan*)
                                 *tsp-scale-plan*
                                 600.0)
                               (/ 500.0 600.0)))
                      '(90 . 2)
                      '(70 . 0)
                      (list 10 (car w1-3) (cadr w1-3))
                      (list 10 (car w1-4) (cadr w1-4)))
                    (list strut-xdata)
                  )
                )

                ;; 방향 2
                (setq w2-1 (polar p-brace-2-inner strut-ang half-tw))
                (setq w2-2 (polar p-brace-2 strut-ang half-tw))
                (setq w2-3 (polar p-brace-2-inner (+ strut-ang pi) half-tw))
                (setq w2-4 (polar p-brace-2 (+ strut-ang pi) half-tw))

                (entmake
                  (append
                    (list
                      '(0 . "LWPOLYLINE")
                      '(100 . "AcDbEntity")
                      '(100 . "AcDbPolyline")
                      '(8 . "_보강재(Brace)")
                      '(62 . 1)
                      '(6 . "DASHED")
                      (cons 48
                            (* (if (and (boundp '*tsp-scale-plan*) *tsp-scale-plan*)
                                 *tsp-scale-plan*
                                 600.0)
                               (/ 500.0 600.0)))
                      '(90 . 2)
                      '(70 . 0)
                      (list 10 (car w2-1) (cadr w2-1))
                      (list 10 (car w2-2) (cadr w2-2)))
                    (list strut-xdata)
                  )
                )

                (entmake
                  (append
                    (list
                      '(0 . "LWPOLYLINE")
                      '(100 . "AcDbEntity")
                      '(100 . "AcDbPolyline")
                      '(8 . "_보강재(Brace)")
                      '(62 . 1)
                      '(6 . "DASHED")
                      (cons 48
                            (* (if (and (boundp '*tsp-scale-plan*) *tsp-scale-plan*)
                                 *tsp-scale-plan*
                                 600.0)
                               (/ 500.0 600.0)))
                      '(90 . 2)
                      '(70 . 0)
                      (list 10 (car w2-3) (cadr w2-3))
                      (list 10 (car w2-4) (cadr w2-4)))
                    (list strut-xdata)
                  )
                )

                ;; 3. 맞버팀대(2H)일 경우 중앙 간극(Gap)에 중간 보강재 추가 작도
                (if is-double
                  (progn
                    (setq p-mid-1 (polar p-center (+ strut-ang (/ pi 2.0)) half-b))
                    (setq p-mid-2 (polar p-center (- strut-ang (/ pi 2.0)) half-b))

                    ;; 중앙 간극 외곽선(Flange)
                    (setq fm-1 (polar p-mid-1 strut-ang half-b))
                    (setq fm-2 (polar p-mid-2 strut-ang half-b))
                    (setq fm-3 (polar p-mid-2 (+ strut-ang pi) half-b))
                    (setq fm-4 (polar p-mid-1 (+ strut-ang pi) half-b))

                    (entmake
                      (append
                        (list
                          '(0 . "LWPOLYLINE")
                          '(100 . "AcDbEntity")
                          '(100 . "AcDbPolyline")
                          '(8 . "_보강재(Brace)")
                          '(62 . 256)
                          '(90 . 4)
                          '(70 . 1)
                          (list 10 (car fm-1) (cadr fm-1))
                          (list 10 (car fm-2) (cadr fm-2))
                          (list 10 (car fm-3) (cadr fm-3))
                          (list 10 (car fm-4) (cadr fm-4)))
                        (list strut-xdata)
                      )
                    )

                    ;; 중앙 간극 웹(Web) 점선
                    (setq wm-1 (polar p-mid-1 strut-ang half-tw))
                    (setq wm-2 (polar p-mid-2 strut-ang half-tw))
                    (setq wm-3 (polar p-mid-1 (+ strut-ang pi) half-tw))
                    (setq wm-4 (polar p-mid-2 (+ strut-ang pi) half-tw))

                    (entmake
                      (append
                        (list
                          '(0 . "LWPOLYLINE")
                          '(100 . "AcDbEntity")
                          '(100 . "AcDbPolyline")
                          '(8 . "_보강재(Brace)")
                          '(62 . 1)
                          '(6 . "DASHED")
                          (cons 48
                                (* (if (and (boundp '*tsp-scale-plan*) *tsp-scale-plan*)
                                     *tsp-scale-plan*
                                     600.0)
                                   (/ 500.0 600.0)))
                          '(90 . 2)
                          '(70 . 0)
                          (list 10 (car wm-1) (cadr wm-1))
                          (list 10 (car wm-2) (cadr wm-2)))
                        (list strut-xdata)
                      )
                    )

                    (entmake
                      (append
                        (list
                          '(0 . "LWPOLYLINE")
                          '(100 . "AcDbEntity")
                          '(100 . "AcDbPolyline")
                          '(8 . "_보강재(Brace)")
                          '(62 . 1)
                          '(6 . "DASHED")
                          (cons 48
                                (* (if (and (boundp '*tsp-scale-plan*) *tsp-scale-plan*)
                                     *tsp-scale-plan*
                                     600.0)
                                   (/ 500.0 600.0)))
                          '(90 . 2)
                          '(70 . 0)
                          (list 10 (car wm-3) (cadr wm-3))
                          (list 10 (car wm-4) (cadr wm-4)))
                        (list strut-xdata)
                      )
                    )
                  )
                )
              )
            )

            ;; 중간말뚝 교차(지그재그) 배치 검사
            (setq is-valid-post T)
            (if (and (= post-enable "1") (= post-layout "1"))
              (progn
                (setq invert-val (if (= post-invert "1") 1 0))
                (if (/= (rem (+ spatial-idx invert-val) 2) 0)
                  (setq is-valid-post nil)
                )
              )
            )

            ;; 중간말뚝 작도 및 파고드는 현상(Overlap) 보정
            (if (and (= post-enable "1") is-valid-post)
              (progn
                ;; [1단계] 기본 형태인 왼쪽(L) 기준으로 1H/2H 고유 좌표 및 회전각 산출
                (if is-double
                  (progn
                    ;; 2H: 왼쪽 측면 밀착
                    (setq pt-post-ins (polar p-center (- pt-dir (/ pi 2.0)) half-b))
                    (setq post-rot (+ pt-dir pi))
                  )
                  (progn
                    ;; 1H: 왼쪽 보강재 외곽선과 수동 버팀보 내측면의 교차점을 통한 역산
                    (setq stiff-left-p1 (polar p-center (- pt-dir (/ pi 2.0)) half-b))
                    (setq stiff-left-p2 (polar (polar p-center pt-dir 100.0) (- pt-dir (/ pi 2.0)) half-b))
                    (setq cs-norm1 (+ strut-ang (/ pi 2.0)))
                    (setq cs-norm2 (- strut-ang (/ pi 2.0)))
                    (setq cp1 (polar p-center cs-norm1 strut-sys-half-width))
                    (setq cp2 (polar p-center cs-norm2 strut-sys-half-width))
                    (setq cs-inner-pt (if (< (distance cp1 p-center) (distance cp2 p-center)) cp1 cp2))
                    (setq cs-inner-p2 (polar cs-inner-pt strut-ang 100.0))
                    (setq pt-target (inters stiff-left-p1 stiff-left-p2 cs-inner-pt cs_inner-p2 nil))
                    (setq post-rot (+ strut-ang (/ pi 2.0)))
                    (if pt-target
                      (setq pt-post-ins (polar pt-target post-rot (/ h 2.0)))
                      (setq pt-post-ins p-center) ;; 교차점 도출 실패 시 보험용
                    )
                  )
                )

                ;; [2단계] 스케일 설정
                (setq y_scale 1.0)

                ;; [3단계] 사용자 옵션 오른쪽(R) 선택 시에만 기하학적 대칭 적용
                (if (= post-side "R")
                  (progn
                    (setq post-rot (- (* 2.0 pt-dir) post-rot))
                    (setq dist-to-ins (distance p-center pt-post-ins))
                    (setq ang-to-ins (angle p-center pt-post-ins))
                    (setq mirror-ang (- (* 2.0 pt-dir) ang-to-ins))
                    (setq pt-post-ins (polar p-center mirror-ang dist-to-ins))
                    (setq y_scale -1.0)
                  )
                )

                (entmake
                  (list
                    '(0 . "INSERT")
                    (cons 2 post-block)
                    (cons 8 "_중간말뚝(Post pile)")
                    (cons 62 256)
                    (cons 10 pt-post-ins)
                    '(41 . 1.0)
                    (cons 42 y_scale)
                    '(43 . 1.0)
                    (cons 50 post-rot)))
              )
            )

            (setq spatial-idx (1+ spatial-idx))
          )
        )
      )
    )
  )

  ;; 5. 방금 새로 그려진 객체들의 ID를 수집하여 반환
  (setq new-ents '())
  (setq nxt start-ent)

  (while (setq nxt (entnext nxt))
    (setq new-ents (append new-ents (list nxt)))
  )

  (princ "\n[성공] 버팀보 작도 및 중간말뚝 배치가 완료되었습니다.")
  new-ents
)



;;;;==========================================================================
;;;; defun tsp-draw-realtime-continuous-braces : 순수 좌표 추적 기반 연속 보강재 실시간 분할 작도 함수
;;;;==========================================================================
(defun tsp-draw-realtime-continuous-braces (pts-list s-brace-opt sec-str is-double strut-ang strut-len seg-id / boundary-handle stiff-enable slender-limit is-manual manual-interval margin strut-vals h b tw tf half-b half-tw strut-sys-half-width brace-xdata brace-ents total-L L-max offsets interval num-div i draw-segs num-pts idx cur-pt p-center p-left p-right p-start p-mid-left p-mid-right next-pt p-next-center p-next-left p-end pA pB f1-1 f1-2 f2-1 f2-2 w1-1 w1-2 w2-1 w2-2)
  (setq stiff-enable (nth 0 s-brace-opt) slender-limit (nth 1 s-brace-opt) is-manual (nth 2 s-brace-opt) manual-interval (nth 3 s-brace-opt) margin (atof (nth 4 s-brace-opt)))
  (if (/= stiff-enable "1") (exit))
  (setq boundary-handle (tsp-get-entity-handle *tsp-boundary-ent*))

  (create-layer-if-not-exists "_보강재(Brace)" "7")
  (if (not (tblsearch "LTYPE" "DASHED")) (vl-catch-all-apply 'vla-load (list (vla-get-linetypes (vla-get-activedocument (vlax-get-acad-object))) "DASHED" (if (= (getvar "MEASUREMENT") 1) "acadiso.lin" "acad.lin"))))

  ;; 1. 제원 파싱 및 단면 치수 정의
  (setq strut-vals (parse-h-spec (if (wcmatch sec-str "2H *") (vl-string-subst "" "2H " sec-str) sec-str)))
  (if (null strut-vals) (setq strut-vals '(300 300 10 15)))
  (setq h (float (nth 0 strut-vals)) b (float (nth 1 strut-vals)) tw (float (nth 2 strut-vals)) tf (float (nth 3 strut-vals)))
  (setq half-b (/ b 2.0) half-tw (/ tw 2.0))
  (setq strut-sys-half-width (if is-double (* b 1.5) (/ b 2.0)))

  ;; ARX 크래시 방지를 위해 LISP 전용 APPID 부여 (0.0 좌표 벡터 계산/분모 오류 완벽 차단)
  (if (not (tblsearch "APPID" "TSP_LISP_BRACE")) (regapp "TSP_LISP_BRACE"))
  (setq brace-xdata 
    (list -3 
      (list "TSP_LISP_BRACE" 
        (cons 1070 seg-id) 
        (cons 1040 0.0) 
        (cons 1010 '(0.0 0.0 0.0)) 
        (cons 1010 '(0.0 0.0 0.0))
        (cons 1040 (float h))
        (cons 1040 (float tw))
        (cons 1040 (float tf))
        (cons 1000 "CONT_BRACE")
        (cons 1000 boundary-handle)
      )
    )
  )

  (setq brace-ents '())
  (if (> (length pts-list) 0)
    (progn
      ;; 2. 실시간 입력된 순수 좌표들을 배열 축 방향으로 기하학적 정렬
      (setq pts-list (vl-sort pts-list
        '(lambda (p1 p2)
           (< (tsp-project-dist (car pts-list) (+ strut-ang (/ pi 2.0)) p1)
              (tsp-project-dist (car pts-list) (+ strut-ang (/ pi 2.0)) p2))
         )
      ))

      ;; 3. 세장비 한계에 따른 등분선 오프셋 산출
      (setq total-L (/ strut-len 1000.0))
      (setq L-max (tsp-calc-unsupported-length strut-vals (if (= slender-limit "0") 100.0 120.0)))
      (setq offsets '())

      (if (or (> total-L L-max) (= is-manual "1"))
        (if (= is-manual "1")
          (progn
            (setq interval (* (atof manual-interval) 1000.0))
            (if (> interval 0.01)
              (progn
                (setq num-div (fix (/ strut-len interval)) i 1)
                (while (<= i num-div)
                  (setq offsets (append offsets (list (* i interval))))
                  (setq i (1+ i))
                )
              )
            )
          )
          (progn
            (setq num-div (fix (+ (/ total-L L-max) 0.9999)) interval (/ strut-len num-div) i 1)
            (while (< i num-div)
              (setq offsets (append offsets (list (* i interval))))
              (setq i (1+ i))
            )
          )
        )
      )

      ;; 4. 등분 분할선마다 전체 버팀보 배열을 관통하는 최적화 선분 수집
      (foreach off offsets
        (setq draw-segs '())
        (setq num-pts (length pts-list))
        (setq idx 0)

        (while (< idx num-pts)
          (setq cur-pt (nth idx pts-list))
          (setq p-center (polar cur-pt strut-ang off))
          (setq p-left (polar p-center (- strut-ang (/ pi 2.0)) strut-sys-half-width))
          (setq p-right (polar p-center (+ strut-ang (/ pi 2.0)) strut-sys-half-width))

          ;; 4-1. [수정] 오직 전체 배열의 맨 첫 번째(idx=0) 왼쪽 끝에만 여유장 구간 배치
          (if (= idx 0)
            (progn
              (setq p-start (polar p-left (- strut-ang (/ pi 2.0)) margin))
              (setq draw-segs (append draw-segs (list (cons p-start p-left))))
            )
          )

          ;; 4-2. 맞버팀대(2H) 내부 중앙 간극 공간 자동 트림 복원
          (if is-double
            (progn
              (setq p-mid-left (polar p-center (- strut-ang (/ pi 2.0)) half-b))
              (setq p-mid-right (polar p-center (+ strut-ang (/ pi 2.0)) half-b))
              (setq draw-segs (append draw-segs (list (cons p-mid-left p-mid-right))))
            )
          )

          ;; 4-3. 현재 버팀보 우측 경계면에서 다음 버팀보 좌측 경계면까지 연속 띠장선 연결
          (if (< idx (1- num-pts))
            (progn
              (setq next-pt (nth (1+ idx) pts-list))
              (setq p-next-center (polar next-pt strut-ang off))
              (setq p-next-left (polar p-next-center (- strut-ang (/ pi 2.0)) strut-sys-half-width))
              (setq draw-segs (append draw-segs (list (cons p-right p-next-left))))
            )
          )

          ;; 4-4. [수정] 오직 전체 배열의 맨 마지막 우측 끝에만 여유장 구간 배치
          (if (= idx (1- num-pts))
            (progn
              (setq p-end (polar p-right (+ strut-ang (/ pi 2.0)) margin))
              (setq draw-segs (append draw-segs (list (cons p-right p-end))))
            )
          )

          (setq idx (1+ idx))
        )

        ;; 5. 가상 트림이 완료된 빈 공간 세그먼트들에만 물리 객체 작도 (XDATA 결합)
        (foreach seg draw-segs
          (setq pA (car seg) pB (cdr seg))
          (if (> (distance pA pB) 0.1)
            (progn
              ;; 플랜지 외곽선 사각형 생성 및 XDATA 결합
              (setq f1-1 (polar pA strut-ang half-b) f1-2 (polar pB strut-ang half-b))
              (setq f2-1 (polar pA (+ strut-ang pi) half-b) f2-2 (polar pB (+ strut-ang pi) half-b))
              (entmake (append (list '(0 . "LWPOLYLINE") '(100 . "AcDbEntity") '(100 . "AcDbPolyline") '(8 . "_보강재(Brace)") '(62 . 256) '(90 . 4) '(70 . 1)
                             (list 10 (car f1-1) (cadr f1-1)) (list 10 (car f1-2) (cadr f1-2)) (list 10 (car f2-2) (cadr f2-2)) (list 10 (car f2-1) (cadr f2-1)))
                             (list brace-xdata)))
              (setq brace-ents (append brace-ents (list (entlast))))
              (setq w1-1 (polar pA strut-ang half-tw) w1-2 (polar pB strut-ang half-tw))
              (setq w2-1 (polar pA (+ strut-ang pi) half-tw) w2-2 (polar pB (+ strut-ang pi) half-tw))
              (entmake (append (list '(0 . "LWPOLYLINE") '(100 . "AcDbEntity") '(100 . "AcDbPolyline") '(8 . "_보강재(Brace)") '(62 . 1) '(6 . "DASHED") 
                                     (cons 48 (* (if (and (boundp '*tsp-scale-plan*) *tsp-scale-plan*) *tsp-scale-plan* 600.0) (/ 500.0 600.0) (if (= (getvar "MEASUREMENT") 1) (/ 1.0 25.0) 1.0)))
                                     '(90 . 2) '(70 . 0)
                             (list 10 (car w1-1) (cadr w1-1)) (list 10 (car w1-2) (cadr w1-2)))
                             (list brace-xdata)))
              (setq brace-ents (append brace-ents (list (entlast))))
              (entmake (append (list '(0 . "LWPOLYLINE") '(100 . "AcDbEntity") '(100 . "AcDbPolyline") '(8 . "_보강재(Brace)") '(62 . 1) '(6 . "DASHED") 
                                     (cons 48 (* (if (and (boundp '*tsp-scale-plan*) *tsp-scale-plan*) *tsp-scale-plan* 600.0) (/ 500.0 600.0) (if (= (getvar "MEASUREMENT") 1) (/ 1.0 25.0) 1.0)))
                                     '(90 . 2) '(70 . 0)
                             (list 10 (car w2-1) (cadr w2-1)) (list 10 (car w2-2) (cadr w2-2)))
                             (list brace-xdata)))
              (setq brace-ents (append brace-ents (list (entlast))))
            )
          )
        )
      )
    )
  )
  brace-ents
)


;;;;==========================================================================
;;;; defun tsp-manual-add-post : 중간말뚝 수동추가
;;;;==========================================================================
(defun tsp-manual-add-post (active-seg-id / old-osmode pt p-center chk_p1 chk_p2 ss-cross p1_box p2_box ss i ent ent-data p1 p2 min-dist line-ang perp-dist best-p1 best-p2 stiff-dir sum-x sum-y count centroid vec_dir vec_c2p cross_z dot_z rot ins_pt post-block added-list session-ents last-act loop custom-h custom-b custom-tw custom-tf target-seg-id ss-all-struts valid-strut-found j e-data xdata x-vals t-p1 t-p2 t-p3 post-data-record check-id first-run pure-b cur-layer s-p1 s-p2 s-width s-ang d-proj d-perp y_scale)
  (setq old-osmode (getvar "OSMODE"))
  (setvar "OSMODE" 32)
  
  (if active-seg-id
    (princ (strcat "\n[안내] Seg-" (itoa active-seg-id) " 수동 추가 작업을 시작합니다."))
    (princ "\n[안내] 중간말뚝 수동 추가 작업을 시작합니다. (원하는 버팀보 영역을 클릭하세요)")
  )
  (setq session-ents '() loop T first-run T)
  
  (while loop
    (initget "Undo")
    (setq pt (vl-catch-all-apply 'getpoint (list "\n[수동 추가] 중간말뚝을 생성할 교차점 클릭 [명령취소(U)] <종료: Enter/ESC>: ")))
    
    (cond
      ((vl-catch-all-error-p pt)
       (setq loop nil)
       (princ "\n[취소] 사용자가 ESC를 눌러 추가 작업을 중단했습니다.")
      )
      ((= pt "Undo")
       (setq first-run nil)
       (if session-ents
         (progn
           (setq last-act (car session-ents))
           (setq session-ents (cdr session-ents))
           (if (= (type last-act) 'ENAME) (if (entget last-act) (entdel last-act)))
           
           (if *tsp-use-temp-posts*
             (if *tsp-temp-added-posts*
               (setq *tsp-temp-added-posts* (reverse (cdr (reverse *tsp-temp-added-posts*))))
             )
             (progn
               (setq added-list (vlax-ldata-get "TSP_DICT" "ADDED_POSTS"))
               (if added-list
                 (progn
                   (setq added-list (reverse (cdr (reverse added-list))))
                   (vlax-ldata-put "TSP_DICT" "ADDED_POSTS" added-list)
                 )
               )
             )
           )
           (setq *tsp-data-dirty* T)
           (if (and (boundp '*tsp-boundary-ent*) *tsp-boundary-ent* (boundp '*tsp-boundary-orient*) *tsp-boundary-orient*)
             (tsp-redraw-realtime-plan *tsp-boundary-ent* *tsp-boundary-orient*)
             (command "_.REGEN")
           )
           (princ "\n[실행] 직전에 추가한 중간말뚝을 취소(Undo)했습니다.")
         )
         (princ "\n[알림] 취소할 작업 내역이 없습니다.")
       )
      )
      ((not pt)
       (if first-run
         (setq first-run nil)
         (setq loop nil)
       )
      )
      ((listp pt)
       (setq first-run nil)
       (setq p-center (list (car pt) (cadr pt) 0.0))
       
       (setq custom-h 300.0 custom-b 300.0 custom-tw 10.0 custom-tf 15.0 target-seg-id nil)
       (setq ss-all-struts (ssget "X" '((0 . "LWPOLYLINE") (8 . "_사보강재(Corner_Strut),_버팀보(Strut)"))))
       (setq valid-strut-found nil)
       
       (if ss-all-struts
         (progn
           (setq j 0)
           (while (and (< j (sslength ss-all-struts)) (not valid-strut-found))
             (setq e-data (entget (ssname ss-all-struts j) '("TSP_STRUT_SPEC")))
             (setq cur-layer (cdr (assoc 8 e-data)))
             (setq xdata (assoc -3 e-data))
             (if xdata
               (progn
                 (setq x-vals (cdr (car (cdr xdata))))
                 (if (>= (length x-vals) 8)
                   (progn
                     (setq check-id (cdr (nth 0 x-vals)))
                     ;; active-seg-id가 nil이면 ID 검사 패스 (클릭한 영역의 ID를 자동 채택)
                     (if (or (null active-seg-id) (= check-id active-seg-id))
                       (progn
                         (if (= cur-layer "_사보강재(Corner_Strut)")
                           (progn
                             (setq t-p1 (cdr (nth 5 x-vals)))
                             (setq t-p2 (cdr (nth 6 x-vals)))
                             (setq t-p3 (cdr (nth 7 x-vals)))
                             (if (tsp-is-point-in-triangle p-center t-p1 t-p2 t-p3)
                               (progn
                                 (setq valid-strut-found T target-seg-id check-id)
                                 (setq custom-h (cdr (nth 1 x-vals)) custom-b (cdr (nth 2 x-vals)) custom-tw (cdr (nth 3 x-vals)) custom-tf (cdr (nth 4 x-vals)))
                               )
                             )
                           )
                           (progn
                             (setq s-p1 (cdr (nth 2 x-vals)))
                             (setq s-p2 (cdr (nth 3 x-vals)))
                             (setq s-width (cdr (nth 1 x-vals)))
                             (setq s-ang (angle s-p1 s-p2))
                             
                             (setq d-proj (tsp-project-dist s-p1 s-ang p-center))
                             (setq d-perp (abs (- (* (- (car p-center) (car s-p1)) (sin s-ang)) (* (- (cadr p-center) (cadr s-p1)) (cos s-ang)))))
                             
                             (if (and (>= d-proj -10.0) (<= d-proj (+ (distance s-p1 s-p2) 10.0)) (<= d-perp (+ s-width 100.0)))
                               (progn
                                 (setq valid-strut-found T target-seg-id check-id)
                                 (setq pure-b (if (> (length x-vals) 9) (cdr (nth 9 x-vals)) (cdr (nth 4 x-vals))))
                                 (setq custom-h (cdr (nth 4 x-vals)) custom-b pure-b custom-tw (cdr (nth 5 x-vals)) custom-tf (cdr (nth 6 x-vals)))
                               )
                             )
                           )
                         )
                       )
                     )
                   )
                 )
               )
             )
             (setq j (1+ j))
           )
         )
       )

       (if (not valid-strut-found)
         (princ (strcat "\n[오류] 현재 설정 중인 [Seg-" (itoa active-seg-id) "]의 사보강재 영역이 아닙니다. 지정된 구역 내부를 클릭해주세요."))
         (progn
           (setq chk_p1 (list (- (car p-center) 2.0) (- (cadr p-center) 2.0)))
           (setq chk_p2 (list (+ (car p-center) 2.0) (+ (cadr p-center) 2.0)))
           (setq ss-cross (ssget "C" chk_p1 chk_p2 '((0 . "*LINE"))))
           
           (if (and ss-cross (>= (sslength ss-cross) 2))
             (progn
               (setq min-dist 1e99 best-p1 nil best-p2 nil sum-x 0.0 sum-y 0.0 count 0)
               (setq p1_box (list (- (car p-center) 500.0) (- (cadr p-center) 500.0)))
               (setq p2_box (list (+ (car p-center) 500.0) (+ (cadr p-center) 500.0)))
               (setq ss (ssget "C" p1_box p2_box '((0 . "LWPOLYLINE") (8 . "_보강재(Brace),_버팀보(Strut)"))))
               
               (if ss
                 (progn
                   (setq i 0)
                   (while (< i (sslength ss))
                     (setq ent (ssname ss i))
                     (setq ent-data (entget ent))
                     (setq p1 nil p2 nil)
                     (foreach item ent-data
                       (if (= (car item) 10)
                         (progn
                           (if (null p1) (setq p1 (cdr item)) (setq p2 (cdr item)))
                           (setq sum-x (+ sum-x (car (cdr item))))
                           (setq sum-y (+ sum-y (cadr (cdr item))))
                           (setq count (1+ count))
                         )
                       )
                     )
                     (if (and p1 p2)
                       (progn
                         (setq p1 (list (car p1) (cadr p1) 0.0))
                         (setq p2 (list (car p2) (cadr p2) 0.0))
                         (setq line-ang (angle p1 p2))
                         (setq perp-dist (abs (- (* (- (car p-center) (car p1)) (sin line-ang)) (* (- (cadr p-center) (cadr p1)) (cos line-ang)))))
                         (if (< perp-dist min-dist)
                           (progn
                             (setq min-dist perp-dist)
                             (setq best-p1 p1 best-p2 p2)
                           )
                         )
                       )
                     )
                     (setq i (1+ i))
                   )
                   
                   (if (and best-p1 best-p2 (> count 0) (< min-dist 10.0))
                     (progn
                       (setq centroid (list (/ sum-x count) (/ sum-y count) 0.0))
                       (setq stiff-dir (angle best-p1 best-p2))
                       (setq vec_dir (list (cos stiff-dir) (sin stiff-dir)))
                       (setq vec_c2p (list (- (car p-center) (car centroid)) (- (cadr p-center) (cadr centroid))))
                       
                       (setq cross_z (- (* (car vec_dir) (cadr vec_c2p)) (* (cadr vec_dir) (car vec_c2p))))
                       (setq dot_z (+ (* (car vec_dir) (car vec_c2p)) (* (cadr vec_dir) (cadr vec_c2p))))
                       
                       (if (>= dot_z 0.0) (setq rot stiff-dir) (setq rot (+ stiff-dir pi)))
                       (if (< (* cross_z dot_z) 0.0) (setq y_scale -1.0) (setq y_scale 1.0))
                       
                       (setq ins_pt (polar p-center rot (/ custom-h 2.0)))
                       (setq post-block (create-post-pile-block custom-h custom-b custom-tw custom-tf))
                       
                       (setq post-data-record (list ins_pt rot y_scale custom-h custom-b custom-tw custom-tf target-seg-id))
                       
                       (if *tsp-use-temp-posts*
                         (setq *tsp-temp-added-posts* (append *tsp-temp-added-posts* (list post-data-record)))
                         (progn
                           (setq added-list (vlax-ldata-get "TSP_DICT" "ADDED_POSTS"))
                           (if (not added-list) (setq added-list '()))
                           (setq added-list (append added-list (list post-data-record)))
                           (vlax-ldata-put "TSP_DICT" "ADDED_POSTS" added-list)
                         )
                       )
                       
                       (setq *tsp-data-dirty* T)
                       
                       (if (and (boundp '*tsp-boundary-ent*) *tsp-boundary-ent* (boundp '*tsp-boundary-orient*) *tsp-boundary-orient*)
                         (progn
                           (tsp-redraw-realtime-plan *tsp-boundary-ent* *tsp-boundary-orient*)
                           (setq session-ents (cons 'REDRAW session-ents))
                         )
                         (progn
                           ;; [수정] ARX XDATA 규격 충돌 및 크래시 방지를 위해 전용 APPID 사용
                           (if (not (tblsearch "APPID" "TSP_LISP_POST")) (regapp "TSP_LISP_POST"))
                           (entmake (list '(0 . "INSERT") (cons 2 post-block) (cons 8 "_중간말뚝(Post pile)") (cons 62 256) (cons 10 ins_pt) '(41 . 1.0) (cons 42 y_scale) '(43 . 1.0) (cons 50 rot)
                                          (list -3 (list "TSP_LISP_POST" (cons 1000 "MANUAL_POST")))
                                    ))
                           (setq session-ents (cons (entlast) session-ents))
                         )
                       )
                       (princ "\n[완료] 중간말뚝 추가 완료.")
                     )
                     (princ "\n[오류] 클릭한 교차점에 보강재(Brace)가 지나가지 않습니다.")
                   )
                 )
                 (princ "\n[오류] 반경 내에 보강재(Brace) 객체가 없습니다.")
               )
             )
             (princ "\n[오류] 두 선이 만나는 정확한 '교차점'이 아닙니다. 스냅을 이용해 다시 클릭하세요.")
           )
         )
       )
      )
    )
  )
  
  (setvar "OSMODE" old-osmode)
  (princ "\n[종료] 수동 추가 완료.")
  (princ)
)

;;;;==========================================================================
;;;; defun tsp-sanitize-support-list : 지보재 리스트 내 오염 데이터 제거 및 ARX 크래시 방지용 강제 복원
;;;;==========================================================================
(defun tsp-sanitize-support-list (sup-list / clean-list item-type new-item opt)
  (setq clean-list '())
  (if sup-list
    (foreach item sup-list
      (if (and (listp item) (> (length item) 0))
        (progn
          (setq item-type (car item))
          ;; ADD_POST 등 제어 문자열이 포함된 패킷은 제외하고 정상 데이터만 필터링
          (if (and item-type (= (type item-type) 'STR) (not (wcmatch item-type "*_POST")))
            (progn
              (setq new-item item)
              ;; [ARX 크래시 핵심 방어] 버팀보 데이터 중 보강재 옵션(11번째 인덱스)이 과거 버그로 인해 문자열로 오염된 경우 리스트로 강제 복원
              (if (wcmatch item-type "버팀보*")
                (if (> (length item) 11)
                  (progn
                    (setq opt (nth 11 item))
                    (if (= (type opt) 'STR)
                      (progn
                        ;; 문자열 상태의 옵션("(\"1\" \"0\"...)")을 진짜 리스트로 파싱
                        (setq opt (read opt))
                        ;; 안전한 리스트로 파싱된 데이터를 원래 위치에 끼워넣어 정상 레코드로 재조립
                        (setq new-item (list (nth 0 item) (nth 1 item) (nth 2 item) (nth 3 item) (nth 4 item) (nth 5 item) (nth 6 item) (nth 7 item) (nth 8 item) (nth 9 item) (nth 10 item) opt))
                      )
                    )
                  )
                )
              )
              (setq clean-list (append clean-list (list new-item)))
            )
          )
        )
      )
    )
  )
  clean-list
)

;;;;==========================================================================
;;;; defun tsp-manual-delete-post : 다중 영역/드래그 선택 및 연속 삭제
;;;;==========================================================================
(defun tsp-manual-delete-post (active-seg-id / ss i ent ent-data blk-name pt-orig ins-pt p1 p2 ss-dup j dup-ent dup-data del-count loop valid-triangles ss-struts e-data xdata x-vals t-p1 t-p2 t-p3 is-inside tri skipped-count check-id)
  (princ (strcat "\n[안내] Seg-" (itoa active-seg-id) " 수동 삭제 작업을 시작합니다."))
  (setq loop T)
  
  ;; 1. 현재 타겟 세그먼트와 일치하는 모든 사보강재(삼각형) 및 버팀보(사각형) 영역을 수집
  (setq valid-triangles '())
  (setq ss-struts (ssget "X" '((0 . "LWPOLYLINE") (8 . "_사보강재(Corner_Strut),_버팀보(Strut)"))))
  (if ss-struts
    (progn
      (setq j 0)
      (while (< j (sslength ss-struts))
        (setq e-data (entget (ssname ss-struts j) '("TSP_STRUT_SPEC")))
        (setq cur-layer (cdr (assoc 8 e-data)))
        (setq xdata (assoc -3 e-data))
        (if xdata
          (progn
            (setq x-vals (cdr (car (cdr xdata))))
            (if (= (length x-vals) 8)
              (progn
                (setq check-id (cdr (nth 0 x-vals)))
                ;; ID가 일치하는 구역만 유효 구역으로 수집
                (if (= check-id active-seg-id)
                  (if (= cur-layer "_사보강재(Corner_Strut)")
                    (progn
                      ;; 사보강재 데이터 수집
                      (setq t-p1 (cdr (nth 5 x-vals)))
                      (setq t-p2 (cdr (nth 6 x-vals)))
                      (setq t-p3 (cdr (nth 7 x-vals)))
                      (setq valid-triangles (append valid-triangles (list (list "TRI" t-p1 t-p2 t-p3))))
                    )
                    (progn
                      ;; 버팀보 데이터 수집
                      (setq s-p1 (cdr (nth 2 x-vals)))
                      (setq s-p2 (cdr (nth 3 x-vals)))
                      (setq s-width (cdr (nth 1 x-vals)))
                      (setq valid-triangles (append valid-triangles (list (list "RECT" s-p1 s-p2 s-width))))
                    )
                  )
                )
              )
            )
          )
        )
        (setq j (1+ j))
      )
    )
  )

  (while loop
    (princ (strcat "\n[수동 삭제] Seg-" (itoa active-seg-id) " 구역 내의 객체를 선택하세요 (다중 선택/드래그 가능, 종료: Enter/ESC): "))
    (setq ss (vl-catch-all-apply 'ssget (list '((0 . "INSERT") (8 . "_중간말뚝(Post pile)")))))
    
    (cond
      ((vl-catch-all-error-p ss)
       (setq loop nil)
       (princ "\n[취소] 사용자가 ESC를 눌러 삭제 작업을 중단했습니다.")
      )
      ((not ss)
       (setq loop nil)
      )
      ((= (type ss) 'PICKSET)
       (setq i 0 del-count 0 skipped-count 0)
       (while (< i (sslength ss))
         (setq ent (ssname ss i))
         (if (entget ent)
           (progn
             (setq ent-data (entget ent))
             (setq blk-name (cdr (assoc 2 ent-data)))
             
             (if (wcmatch (strcase blk-name) "_POST_PILE*")
               (progn
                 (setq pt-orig (cdr (assoc 10 ent-data)))
                 (setq ins-pt (list (car pt-orig) (cadr pt-orig) 0.0))
                 
                 ;; 선택된 객체가 타겟 세그먼트의 유효 영역 내부에 있는지 확인 (다중 모양 대응)
                 (setq is-inside nil)
                 (foreach tri valid-triangles
                   (if (= (car tri) "TRI")
                     (if (tsp-is-point-in-triangle ins-pt (nth 1 tri) (nth 2 tri) (nth 3 tri)) (setq is-inside T))
                     (progn
                       (setq s-p1 (nth 1 tri) s-p2 (nth 2 tri) s-width (nth 3 tri))
                       (setq s-ang (angle s-p1 s-p2))
                       (setq d-proj (tsp-project-dist s-p1 s-ang ins-pt))
                       (setq d-perp (abs (- (* (- (car ins-pt) (car s-p1)) (sin s-ang)) (* (- (cadr ins-pt) (cadr s-p1)) (cos s-ang)))))
                       (if (and (>= d-proj -10.0) (<= d-proj (+ (distance s-p1 s-p2) 10.0)) (<= d-perp (+ s-width 100.0)))
                         (setq is-inside T)
                       )
                     )
                   )
                 )
                 
                 (if is-inside
                   (progn
                     (if *tsp-use-temp-posts*
                       (setq *tsp-temp-deleted-posts* (append *tsp-temp-deleted-posts* (list ins-pt)))
                       (progn
                         (setq *tsp-deleted-post-points* (vlax-ldata-get "TSP_DICT" "DELETED_POSTS"))
                         (if (not *tsp-deleted-post-points*) (setq *tsp-deleted-post-points* '()))
                         (setq *tsp-deleted-post-points* (append *tsp-deleted-post-points* (list ins-pt)))
                         (vlax-ldata-put "TSP_DICT" "DELETED_POSTS" *tsp-deleted-post-points*)
                       )
                     )
                     
                     (setq p1 (list (- (car ins-pt) 5.0) (- (cadr ins-pt) 5.0)))
                     (setq p2 (list (+ (car ins-pt) 5.0) (+ (cadr ins-pt) 5.0)))
                     (setq ss-dup (ssget "C" p1 p2 '((0 . "INSERT"))))
                     (if ss-dup
                       (progn
                         (setq j 0)
                         (while (< j (sslength ss-dup))
                           (setq dup-ent (ssname ss-dup j))
                           (if (entget dup-ent)
                             (progn
                               (setq dup-data (entget dup-ent))
                               (if (and (= (strcase (cdr (assoc 8 dup-data))) (strcase "_중간말뚝(Post pile)"))
                                        (wcmatch (strcase (cdr (assoc 2 dup-data))) "_POST_PILE*"))
                                 (entdel dup-ent)
                               )
                             )
                           )
                           (setq j (1+ j))
                         )
                       )
                     )
                     
                     (if (entget ent) (entdel ent))
                     (setq del-count (1+ del-count))
                   )
                   (setq skipped-count (1+ skipped-count))
                 )
               )
             )
           )
         )
         (setq i (1+ i))
       )
       
       (setq *tsp-data-dirty* T)
       (command "_.REGEN")
       
       (if (> del-count 0) (princ (strcat "\n[완료] " (itoa del-count) "개의 중간말뚝이 삭제되었습니다.")))
       (if (> skipped-count 0) (princ (strcat "\n[오류 차단] 해당 구역 외부의 객체 " (itoa skipped-count) "개는 보호되어 삭제되지 않았습니다.")))
      )
    )
  )
  (princ "\n[종료] 삭제 완료.")
  (princ)
)


;;;;==========================================================================
;;;; defun tsp-reset-post-manual : 중간말뚝 수동 삭제 및 추가 기록 모두 초기화 및 도면 객체 청소
;;;;==========================================================================
(defun tsp-reset-post-manual ( / ss i )
  ;; 1. 도면에 영구적으로 박제된(Bake) 중간말뚝 블록 객체를 모두 찾아 물리적 삭제
  (setq ss (ssget "X" '((0 . "INSERT") (8 . "_중간말뚝(Post pile)"))))
  (if ss
    (progn
      (setq i 0)
      (while (< i (sslength ss))
        (entdel (ssname ss i))
        (setq i (1+ i))
      )
    )
  )

  ;; 2. 메모리 및 LDATA 기록 완전 삭제
  (if *tsp-use-temp-posts*
    (progn
      (setq *tsp-temp-added-posts* '())
      (setq *tsp-temp-deleted-posts* '())
    )
    (progn
      ;; 빈 리스트를 덮어쓰지 않고 LDATA 딕셔너리에서 항목 자체를 완전히 삭제
      (vlax-ldata-delete "TSP_DICT" "ADDED_POSTS")
      (vlax-ldata-delete "TSP_DICT" "DELETED_POSTS")
    )
  )
  (setq *tsp-data-dirty* T)
  
  ;; 3. 화면 갱신 (기존 말뚝이 모두 지워진 상태에서 자동 배치 설정된 말뚝들만 새로 깔끔하게 그려짐)
  (if (and (boundp '*tsp-boundary-ent*) *tsp-boundary-ent* (boundp '*tsp-boundary-orient*) *tsp-boundary-orient*)
    (progn
      (tsp-redraw-realtime-plan *tsp-boundary-ent* *tsp-boundary-orient*)
      (princ "\n중간말뚝 추가/삭제 기록 초기화 및 객체 청소 완료")
    )
    (princ "\n 중간말뚝 추가/삭제 기록 초기화 및 객체 청소 완료")
  )
  (princ)
)


