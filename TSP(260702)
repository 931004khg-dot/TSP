;;;;==========================================================================
(defun tsp-draw-closed-poly (pts layer color / lst p)
  (setq lst (list '(0 . "LWPOLYLINE") '(100 . "AcDbEntity") '(100 . "AcDbPolyline") (cons 8 layer) (cons 62 color) (cons 90 (length pts)) '(70 . 1)))
