        (setq br-p4 (list (car br-p1) (- ins-y (/ wale-b 2.0))))
        (command "_.pline" br-p1 br-p2 br-p3 br-p4 "_c")
        (command "_.hatch" "ANSI31" (if (= (getvar "MEASUREMENT") 0) 400.0 20.0) 90 (entlast) "")

        ;; 단일 띠장 및 보걸이 삽입
        (setq wale-rot-angle (* -0.5 pi wale-dir))
        (draw-wale-section pt-ins wale-rot-angle wale-layer-name wale-h wale-b wale-tw wale-tf 150.0 bracket-width)
        
        ;; 버팀보 본체 작도 로직
        (setq s-jack-type (nth 7 s-item))
