;;;;==========================================================================
;;;; defun tsp-split-string-by-comma : 문자열을 쉼표 단위로 분할하여 리스트 반환
;;;;==========================================================================
(defun tsp-split-string-by-comma (str / pos lst)
  (setq lst nil)
  (while (setq pos (vl-string-search "," str))
    (setq lst (append lst (list (substr str 1 pos))))
    (setq str (substr str (+ pos 2)))
  )
  (append lst (list str))
)

;;;;==========================================================================
;;;; defun tsp-select-project-for-export : 내보낼 프로젝트를 DCL에서 선택
;;;;==========================================================================
(defun tsp-select-project-for-export (/ dict proj-list dcl-id dcl-path dcl-file selected-proj idx)
  (setq dict (dictsearch (namedobjdict) "TSP_DATA_DICT"))
  (if (not dict)
    (progn (alert "도면에 저장된 프로젝트 데이터가 없습니다.") nil)
    (progn
      (setq proj-list nil)
      (foreach item dict
        (if (= (car item) 3)
          (setq proj-list (append proj-list (list (cdr item))))
        )
      )
      (if (= (length proj-list) 0)
        (progn (alert "저장된 프로젝트가 없습니다.") nil)
        (progn
          (setq dcl-path (strcat (getvar "TEMPPREFIX") "tsp_export.dcl"))
          (setq dcl-file (open dcl-path "w"))
          (write-line "tsp_export_dlg : dialog { label = \"내보낼 프로젝트 선택\";" dcl-file)
          (write-line "  : list_box { key = \"proj_list\"; height = 10; width = 40; }" dcl-file)
          (write-line "  : row { : button { key = \"accept\"; label = \"확인(Export)\"; is_default = true; } : button { key = \"cancel\"; label = \"취소\"; is_cancel = true; } }" dcl-file)
          (write-line "}" dcl-file)
          (close dcl-file)

          (setq dcl-id (load_dialog dcl-path))
          (if (new_dialog "tsp_export_dlg" dcl-id)
            (progn
              (start_list "proj_list")
              (mapcar 'add_list proj-list)
              (end_list)
              (setq selected-proj nil)
              (action_tile "proj_list" "(setq idx (atoi $value))")
              (action_tile "accept" "(if idx (setq selected-proj (nth idx proj-list))) (done_dialog 1)")
              (action_tile "cancel" "(done_dialog 0)")
              (start_dialog)
              (unload_dialog dcl-id)
              selected-proj
            )
            (progn (alert "DCL 로드 실패") nil)
          )
        )
      )
    )
  )
)


;;;;==========================================================================
;;;; defun tsp-export-to-csv : 선택된 프로젝트를 CSV 파일로 출력
;;;;==========================================================================
(defun tsp-export-to-csv (/ proj-name file-path file-desc seg-str data-pack)
  (setq proj-name (tsp-select-project-for-export))
  (if proj-name
    (progn
      ;; 도면 검증 로직이 포함된 tsp-load-project-data 대신, 딕셔너리에서 원본 데이터를 직접 추출 (Bypass)
      (setq data-pack (vlax-ldata-get "TSP_DATA_DICT" proj-name))
      (if (not data-pack)
        (alert "프로젝트 데이터를 읽을 수 없습니다.")
        (progn
          ;; 내보내기에 필요한 데이터만 전역 변수 메모리로 세팅
          (setq *segment-list* (nth 0 data-pack))
          (setq *tsp-current-project-name* proj-name)
          (setq *tsp-scale-section* (nth 13 data-pack))
          (setq *tsp-scale-plan* (nth 14 data-pack))
          (setq *tsp-soil-layers* (nth 9 data-pack))

          (setq file-path (getfiled "EXCEL(CSV)로 내보내기" (strcat proj-name ".csv") "csv" 1))
          (if file-path
            (progn
              (setq file-desc (open file-path "w"))
              
              ;; 글로벌 데이터 기록
              (write-line (strcat "#GLOBAL,PROJECT_NAME," *tsp-current-project-name* ",SCALE_S," (itoa *tsp-scale-section*) ",SCALE_P," (itoa *tsp-scale-plan*)) file-desc)
              
              ;; 프로젝트 전역 설정(Global Settings) 100% 백업용 RAW 데이터 기록
              (write-line (strcat "#GLOBAL_RAW," (vl-prin1-to-string data-pack)) file-desc)
              
              ;; 지반 지층 정보 기록
              (foreach soil *tsp-soil-layers*
                (write-line (strcat "#SOIL," (vl-prin1-to-string soil)) file-desc)
              )
              
              ;; 세그먼트 데이터 기록 (13번째 열에 원본 리스트 통째로 직렬화하여 백업)
              (write-line "#HEADER,ID,TYPE,V-START,V-END,ANGLE,LENGTH,WALL-SPEC,CTC,MAX-DEPTH,SUPPORT-LIST,CORNER-BRACE,RAW-DATA" file-desc)
              (foreach seg *segment-list*
                (setq seg-str (strcat "SEGMENT,"
                  (if (cdr (assoc 'ID seg)) (itoa (cdr (assoc 'ID seg))) "0") ","
                  
                  ;; 1. 최신 이름표(WALL-TYPE)가 있는지 먼저 확인
                  (cond
                    ((and (cdr (assoc 'WALL-TYPE seg)) (/= (cdr (assoc 'WALL-TYPE seg)) "")) (cdr (assoc 'WALL-TYPE seg)))
                    ((= (cdr (assoc 'HPILE-OR-CIP seg)) 0) "HPILE")
                    ((= (cdr (assoc 'HPILE-OR-CIP seg)) 1) "CIP")
                    (t "HPILE")
                  ) ","
                  
                  ;; 좌표(V-START, V-END) 및 형태(ANGLE, LENGTH)의 정밀도를 소수점 12자리로 극대화
                  (if (cdr (assoc 'V-START seg)) 
                    (strcat "(" (rtos (car (cdr (assoc 'V-START seg))) 2 12) " " (rtos (cadr (cdr (assoc 'V-START seg))) 2 12) " " (rtos (if (caddr (cdr (assoc 'V-START seg))) (caddr (cdr (assoc 'V-START seg))) 0.0) 2 12) ")") 
                    "nil"
                  ) ","
                  (if (cdr (assoc 'V-END seg)) 
                    (strcat "(" (rtos (car (cdr (assoc 'V-END seg))) 2 12) " " (rtos (cadr (cdr (assoc 'V-END seg))) 2 12) " " (rtos (if (caddr (cdr (assoc 'V-END seg))) (caddr (cdr (assoc 'V-END seg))) 0.0) 2 12) ")") 
                    "nil"
                  ) ","
                  (if (cdr (assoc 'ANGLE seg)) (rtos (cdr (assoc 'ANGLE seg)) 2 12) "0.000000000000") ","
                  (if (cdr (assoc 'LENGTH seg)) (rtos (cdr (assoc 'LENGTH seg)) 2 12) "0.000000000000") ","
                  
                  ;; 의도적으로 비워둔 구간에서 WALL-SPEC 등이 nil일 때 strcat이 터지는 것을 방지하는 안전장치 추가
                  (if (cdr (assoc 'WALL-SPEC seg)) (cdr (assoc 'WALL-SPEC seg)) "") ","
                  (if (cdr (assoc 'CTC seg)) (rtos (cdr (assoc 'CTC seg)) 2 3) "") ","
                  (if (cdr (assoc 'MAX-DEPTH seg)) (rtos (cdr (assoc 'MAX-DEPTH seg)) 2 3) "") ","
                  
                  (vl-prin1-to-string (cdr (assoc 'SUPPORT-LIST seg))) ","
                  (vl-prin1-to-string (cdr (assoc 'CORNER-BRACE seg))) ","
                  (vl-prin1-to-string seg)
                ))
                (write-line seg-str file-desc)
              )
              (close file-desc)
              (alert (strcat "[" proj-name "] 데이터가 성공적으로 내보내기 되었습니다.\n파일을 확인해 주세요."))
            )
          )
        )
      )
    )
  )
  (princ)
)


;;;;==========================================================================
;;;; defun tsp-rebuild-boundary : V-START 데이터로 폴리라인 자동 생성
;;;;==========================================================================
(defun tsp-rebuild-boundary (/ pt-list ent)
  (setq pt-list nil)
  (foreach seg *segment-list*
    (setq pt-list (append pt-list (list (cdr (assoc 'V-START seg)))))
  )
  (entmake
    (append
      (list '(0 . "LWPOLYLINE") '(100 . "AcDbEntity") '(100 . "AcDbPolyline")
            (cons 90 (length pt-list))
            '(70 . 1) ; 닫힌 폴리라인 설정
      )
      (mapcar '(lambda (pt) (cons 10 pt)) pt-list)
    )
  )
  (setq ent (entlast))
  (vla-put-Color (vlax-ename->vla-object ent) 1) ; 시인성을 위해 빨간색 지정
  ent
)

;;;;==========================================================================
;;;; defun tsp-import-from-csv : CSV 데이터를 읽어 도면 및 딕셔너리에 복원
;;;;==========================================================================
(defun tsp-import-from-csv (/ file-path file-desc line-str data-lst new-seg-list seg-data new-boundary new-orient ins-opt ins-pt base-pt delta-x delta-y shifted-seg-list old-start old-end new-start new-end raw-globals name-opt new-name pt new-pt rec)
  (setq file-path (getfiled "EXCEL(CSV)에서 불러오기" "" "csv" 0))
  (if file-path
    (progn
      (setq file-desc (open file-path "r"))
      (setq new-seg-list nil)
      (setq *tsp-soil-layers* nil)
      
      (while (setq line-str (read-line file-desc))
        (setq data-lst (tsp-split-string-by-comma line-str))
        (cond
          ((= (nth 0 data-lst) "#GLOBAL")
           (setq *tsp-current-project-name* (nth 2 data-lst))
           (setq *tsp-scale-section* (atoi (nth 4 data-lst)))
           (setq *tsp-scale-plan* (atoi (nth 6 data-lst)))
          )
          ;; 딕셔너리에 들어있던 글로벌 전역 설정 100% 복원
          ((= (nth 0 data-lst) "#GLOBAL_RAW")
           (setq raw-globals (read (nth 1 data-lst)))
           (if raw-globals
             (progn
               (setq *tsp-hpile-spec* (nth 1 raw-globals))
               (setq *tsp-hpile-custom* (nth 2 raw-globals))
               (setq *tsp-wale-spec* (nth 3 raw-globals))
               (setq *tsp-wale-custom* (nth 4 raw-globals))
               (setq *tsp-ctc* (nth 5 raw-globals))
               (setq *tsp-timber-thickness* (nth 6 raw-globals))
               (setq *tsp-max-excavation-depth* (nth 7 raw-globals))
               (setq *tsp-embedment-depth* (nth 8 raw-globals))
               ;; (nth 9)는 #SOIL에서 별도 처리하므로 생략
               (setq *tsp-water-chk* (nth 10 raw-globals))
               (setq *tsp-water-depth* (nth 11 raw-globals))
               (setq *tsp-support-list* (tsp-sanitize-support-list (nth 12 raw-globals)))
               ;; 구버전 프로젝트 호환성 방어 로직
               (if (> (length raw-globals) 15)
                 (progn
                   (setq *tsp-deleted-post-points* (nth 15 raw-globals))
                   (setq *tsp-added-post-points* (nth 16 raw-globals))
                   (vlax-ldata-put "TSP_DICT" "DELETED_POSTS" *tsp-deleted-post-points*)
                   (vlax-ldata-put "TSP_DICT" "ADDED_POSTS" *tsp-added-post-points*)
                 )
                 (progn
                   (setq *tsp-deleted-post-points* '())
                   (setq *tsp-added-post-points* '())
                   (if (vlax-ldata-get "TSP_DICT" "DELETED_POSTS") (vlax-ldata-delete "TSP_DICT" "DELETED_POSTS"))
                   (if (vlax-ldata-get "TSP_DICT" "ADDED_POSTS") (vlax-ldata-delete "TSP_DICT" "ADDED_POSTS"))
                 )
               )
             )
           )
          )
          ((= (nth 0 data-lst) "#SOIL")
           (setq *tsp-soil-layers* (append *tsp-soil-layers* (list (read (nth 1 data-lst)))))
          )
          ((= (nth 0 data-lst) "SEGMENT")
           ;; 1. 13번째 열(RAW-DATA)을 먼저 읽어 뼈대(CIP 및 지반 데이터 등)를 100% 복원
           (setq seg-data (read (nth 12 data-lst)))
           
           ;; 2. 엑셀에서 수정되었을 수 있는 나머지 공통 열의 값으로 데이터 덮어쓰기
           (setq seg-data (subst (cons 'ID (atoi (nth 1 data-lst))) (assoc 'ID seg-data) seg-data))
           (setq seg-data (subst (cons 'NAME (strcat "Seg-" (nth 1 data-lst))) (assoc 'NAME seg-data) seg-data))
           
           ;; 구버전 변수(HPILE-OR-CIP)를 최신 구조인 WALL-TYPE 문자열로 덮어쓰기. 
           ;; 구버전 파일이라 WALL-TYPE 이름표 자체가 없다면 리스트 맨 뒤에 안전하게 추가(append)
           (if (assoc 'WALL-TYPE seg-data)
             (setq seg-data (subst (cons 'WALL-TYPE (nth 2 data-lst)) (assoc 'WALL-TYPE seg-data) seg-data))
             (setq seg-data (append seg-data (list (cons 'WALL-TYPE (nth 2 data-lst)))))
           )
           
           (setq seg-data (subst (cons 'V-START (read (nth 3 data-lst))) (assoc 'V-START seg-data) seg-data))
           (setq seg-data (subst (cons 'V-END (read (nth 4 data-lst))) (assoc 'V-END seg-data) seg-data))
           (setq seg-data (subst (cons 'ANGLE (atof (nth 5 data-lst))) (assoc 'ANGLE seg-data) seg-data))
           (setq seg-data (subst (cons 'LENGTH (atof (nth 6 data-lst))) (assoc 'LENGTH seg-data) seg-data))
           
           ;; 빈칸("")으로 내보낸 데이터를 읽을 때 0이나 0.0이 아닌 원래의 nil 상태로 안전하게 복원
           (setq seg-data (subst (cons 'WALL-SPEC (if (= (nth 7 data-lst) "") nil (nth 7 data-lst))) (assoc 'WALL-SPEC seg-data) seg-data))
           (setq seg-data (subst (cons 'CTC (if (= (nth 8 data-lst) "") nil (atof (nth 8 data-lst)))) (assoc 'CTC seg-data) seg-data))
           (setq seg-data (subst (cons 'MAX-DEPTH (if (= (nth 9 data-lst) "") nil (atof (nth 9 data-lst)))) (assoc 'MAX-DEPTH seg-data) seg-data))
           
           (setq clean-support (tsp-sanitize-support-list (read (nth 10 data-lst))))
           (setq seg-data (subst (cons 'SUPPORT-LIST clean-support) (assoc 'SUPPORT-LIST seg-data) seg-data))
           (setq seg-data (subst (cons 'CORNER-BRACE (read (nth 11 data-lst))) (assoc 'CORNER-BRACE seg-data) seg-data))

           (setq new-seg-list (append new-seg-list (list seg-data)))
          )
        )
      )
      (close file-desc)
      
      (setq *tsp-realtime-entities* nil)
      
      ;; 프로젝트명 중복 시 덮어쓰기 또는 새 이름 지정
      (if (vlax-ldata-get "TSP_DATA_DICT" *tsp-current-project-name*)
        (progn
          (initget "Overwrite New")
          (setq name-opt (getkword (strcat "\n프로젝트 [" *tsp-current-project-name* "] 가 이미 도면 내에 존재합니다. 덮어쓰시겠습니까? [덮어쓰기(O)/새이름(N)] <N>: ")))
          (if (or (not name-opt) (= name-opt "New"))
            (progn
              (setq new-name (getstring T "\n새로운 프로젝트 이름을 입력하세요 (빈칸 입력시 자동생성): "))
              (if (or (not new-name) (= new-name ""))
                (setq *tsp-current-project-name* (tsp-generate-default-project-name))
                (setq *tsp-current-project-name* new-name)
              )
            )
          )
        )
      )
      
      (initget "Origin New")
      (setq ins-opt (getkword "\n불러올 도면의 삽입 방식을 선택하세요 [원래위치(O)/새위치(N)] <N>: "))
      (if (not ins-opt) (setq ins-opt "New"))
      
      (if (= ins-opt "New")
        (progn
          (setq ins-pt (getpoint "\n1번 세그먼트의 시작점이 될 위치를 클릭하세요: "))
          (if ins-pt
            (progn
              (setq ins-pt (trans ins-pt 1 0)) ; WCS 변환
              ;; 첫 번째 세그먼트의 V-START와 클릭한 점 사이의 변위 벡터(거리 및 방향) 계산
              (setq base-pt (cdr (assoc 'V-START (nth 0 new-seg-list))))
              (setq delta-x (- (car ins-pt) (car base-pt)))
              (setq delta-y (- (cadr ins-pt) (cadr base-pt)))
              
              ;; 모든 세그먼트의 V-START, V-END 및 버팀보 수동 좌표(manual-pts)에 변위 벡터를 일괄 적용
                    (setq shifted-seg-list nil)
                    (foreach seg new-seg-list
                      (setq old-start (cdr (assoc 'V-START seg)))
                      (setq old-end (cdr (assoc 'V-END seg)))
                      (setq new-start (list (+ (car old-start) delta-x) (+ (cadr old-start) delta-y) (caddr old-start)))
                      (setq new-end (list (+ (car old-end) delta-x) (+ (cadr old-end) delta-y) (caddr old-end)))
                      (setq seg (subst (cons 'V-START new-start) (assoc 'V-START seg) seg))
                      (setq seg (subst (cons 'V-END new-end) (assoc 'V-END seg) seg))
                      
                      ;; [추가] SUPPORT-LIST 내의 버팀보 수동 배치 절대좌표(manual-pts) 변위 보정
                      (setq old-support (cdr (assoc 'SUPPORT-LIST seg)))
                      (if old-support
                        (progn
                          (setq new-support nil)
                          (foreach s-item old-support
                            (if (wcmatch (car s-item) "버팀보*")
                              (progn
                                (setq s-manual-pts (if (> (length s-item) 8) (nth 8 s-item) nil))
                                (if s-manual-pts
                                  (progn
                                    (setq new-manual-pts (mapcar '(lambda (pt) (list (+ (car pt) delta-x) (+ (cadr pt) delta-y) (caddr pt))) s-manual-pts))
                                    (setq new-s-item '())
                                    (setq idx 0)
                                    (foreach val s-item
                                      (if (= idx 8)
                                        (setq new-s-item (append new-s-item (list new-manual-pts)))
                                        (setq new-s-item (append new-s-item (list val)))
                                      )
                                      (setq idx (1+ idx))
                                    )
                                    (setq s-item new-s-item)
                                  )
                                )
                              )
                            )
                            (setq new-support (append new-support (list s-item)))
                          )
                          (setq seg (subst (cons 'SUPPORT-LIST new-support) (assoc 'SUPPORT-LIST seg) seg))
                        )
                      )
                      (setq shifted-seg-list (append shifted-seg-list (list seg)))
                    )
                    (setq new-seg-list shifted-seg-list)
                    
                    ;; [추가] 글로벌 SUPPORT-LIST 변수도 동일하게 변위 보정 처리
                    (if *tsp-support-list*
                      (progn
                        (setq new-global-support nil)
                        (foreach s-item *tsp-support-list*
                          (if (wcmatch (car s-item) "버팀보*")
                            (progn
                              (setq s-manual-pts (if (> (length s-item) 8) (nth 8 s-item) nil))
                              (if s-manual-pts
                                (progn
                                  (setq new-manual-pts (mapcar '(lambda (pt) (list (+ (car pt) delta-x) (+ (cadr pt) delta-y) (caddr pt))) s-manual-pts))
                                  (setq new-s-item '())
                                  (setq idx 0)
                                  (foreach val s-item
                                    (if (= idx 8)
                                      (setq new-s-item (append new-s-item (list new-manual-pts)))
                                      (setq new-s-item (append new-s-item (list val)))
                                    )
                                    (setq idx (1+ idx))
                                  )
                                  (setq s-item new-s-item)
                                )
                              )
                            )
                          )
                          (setq new-global-support (append new-global-support (list s-item)))
                        )
                        (setq *tsp-support-list* new-global-support)
                      )
                    )
              
              ;; 수동으로 추가/삭제된 중간말뚝의 절대좌표도 새 위치에 맞게 변위(Shift) 일괄 적용
              (if *tsp-deleted-post-points*
                (setq *tsp-deleted-post-points* (mapcar '(lambda (pt) (list (+ (car pt) delta-x) (+ (cadr pt) delta-y) 0.0)) *tsp-deleted-post-points*)
                )
              )
              (if *tsp-added-post-points*
                (setq *tsp-added-post-points*
                  (mapcar '(lambda (rec) (cons (list (+ (car (car rec)) delta-x) (+ (cadr (car rec)) delta-y) 0.0) (cdr rec))) *tsp-added-post-points*)
                )
              )
              
              ;; 보정된 말뚝 데이터를 도면 딕셔너리에 즉각 업데이트하여 새 위치 기준으로 작도되게 함
              (vlax-ldata-put "TSP_DICT" "DELETED_POSTS" *tsp-deleted-post-points*)
              (vlax-ldata-put "TSP_DICT" "ADDED_POSTS" *tsp-added-post-points*)
            )
            (princ "\n[알림] 삽입점이 지정되지 않아 원래 위치에 생성합니다.")
          )
        )
      )
      
     ;; 전역 리스트 복원
      (setq *segment-list* new-seg-list)
      
      ;; 경계선 생성 및 방향 계산
      (setq new-boundary (tsp-rebuild-boundary))
      (setq new-orient (determine-boundary-orientation new-boundary))
      
      ;; 생성된 경계선의 레이어 생성 및 색상 강제 지정 로직
      (if (not (tblsearch "LAYER" "_경계선(Boundary)"))
        (entmake (list (cons 0 "LAYER") (cons 100 "AcDbSymbolTableRecord") (cons 100 "AcDbLayerTableRecord") (cons 2 "_경계선(Boundary)") (cons 70 0) (cons 62 4)))
      )
      (setq bnd-data (entget new-boundary))
      (setq bnd-data (subst (cons 8 "_경계선(Boundary)") (assoc 8 bnd-data) bnd-data))
      (if (assoc 62 bnd-data)
        (setq bnd-data (subst (cons 62 4) (assoc 62 bnd-data) bnd-data))
        (setq bnd-data (append bnd-data (list (cons 62 4))))
      )
      (entmod bnd-data)
      
      (vlax-ldata-put new-boundary "TSP_START_PT" (cdr (assoc 'V-START (nth 0 new-seg-list))))
      
      ;; 도면 딕셔너리에 즉시 세이브
      (tsp-save-project-data *tsp-current-project-name*)
      
      ;; 불러온 데이터로 백그라운드 평면도 강제 작도
      (tsp-redraw-realtime-plan new-boundary new-orient)
      
      ;; 합류(RUN)를 위한 전역 변수 세팅
      (setq *tsp-imported-ent* new-boundary)
      (setq *tsp-imported-orient* new-orient)
      (setq *is-imported-data* T)
      
      (alert (strcat "데이터 복원이 완료되었습니다.\n프로젝트명: " *tsp-current-project-name* "\n확인을 누르시면 즉시 [세그먼트 설정창]으로 진입합니다."))
    )
    (setq *is-imported-data* nil) ; 취소 시를 대비한 안전장치
  )
  *is-imported-data* ; T를 반환하여 메인 명령어가 RUN으로 넘어감
)


;;;;==========================================================================
;;;; defun tsp-select-project-for-load : 불러올 프로젝트를 DCL에서 선택 (도면 내부용)
;;;;==========================================================================
(defun tsp-select-project-for-load (/ dict proj-list dcl-id dcl-path dcl-file selected-proj idx item)
  (setq dict (dictsearch (namedobjdict) "TSP_DATA_DICT"))
  ;; 예외 처리: 도면에 딕셔너리가 아예 없는 경우
  (if (not dict)
    (progn (alert "현재 도면에 저장된 프로젝트 데이터가 없습니다.\n(저장된 이력이 없습니다.)") nil)
    (progn
      (setq proj-list nil)
      (foreach item dict
        (if (= (car item) 3)
          (setq proj-list (append proj-list (list (cdr item))))
        )
      )
      ;; 예외 처리: 딕셔너리는 있으나 내용물이 비어있는 경우
      (if (= (length proj-list) 0)
        (progn (alert "도면 내에 저장된 프로젝트가 없습니다.") nil)
        (progn
          (setq dcl-path (strcat (getvar "TEMPPREFIX") "tsp_load_dwg.dcl"))
          (setq dcl-file (open dcl-path "w"))
          (write-line "tsp_load_dwg_dlg : dialog { label = \"도면 내 프로젝트 불러오기\";" dcl-file)
          (write-line "  : list_box { key = \"proj_list\"; height = 10; width = 40; }" dcl-file)
          (write-line "  : row { : button { key = \"accept\"; label = \"불러오기(Load)\"; is_default = true; } : button { key = \"cancel\"; label = \"취소\"; is_cancel = true; } }" dcl-file)
          (write-line "}" dcl-file)
          (close dcl-file)

          (setq dcl-id (load_dialog dcl-path))
          (if (new_dialog "tsp_load_dwg_dlg" dcl-id)
            (progn
              (start_list "proj_list")
              (mapcar 'add_list proj-list)
              (end_list)
              (setq selected-proj nil)
              (action_tile "proj_list" "(setq idx (atoi $value))")
              (action_tile "accept" "(if idx (setq selected-proj (nth idx proj-list))) (done_dialog 1)")
              (action_tile "cancel" "(done_dialog 0)")
              (start_dialog)
              (unload_dialog dcl-id)
              selected-proj
            )
            (progn (alert "DCL 로드 실패") nil)
          )
        )
      )
    )
  )
)

;;;;==========================================================================
;;;; defun tsp-import-from-drawing : 도면 내부 딕셔너리에서 데이터를 읽어 복원
;;;;==========================================================================
(defun tsp-import-from-drawing (/ proj-name data-pack new-seg-list ins-opt ins-pt base-pt delta-x delta-y shifted-seg-list old-start old-end new-start new-end new-boundary new-orient bnd-data s-item s-manual-pts new-manual-pts new-s-item idx new-support old-support new-global-support seg val pt rec)
  (setq proj-name (tsp-select-project-for-load))
  (if proj-name
    (progn
      (setq data-pack (vlax-ldata-get "TSP_DATA_DICT" proj-name))
      (if (not data-pack)
        (progn (alert "선택한 프로젝트 데이터를 읽을 수 없습니다.") nil)
        (progn
          ;; 1. 전역 변수로 데이터 언패킹 (깊은 복사)
          (setq *tsp-current-project-name* proj-name)
          (setq new-seg-list (nth 0 data-pack))
          (setq *tsp-hpile-spec* (nth 1 data-pack))
          (setq *tsp-hpile-custom* (nth 2 data-pack))
          (setq *tsp-wale-spec* (nth 3 data-pack))
          (setq *tsp-wale-custom* (nth 4 data-pack))
          (setq *tsp-ctc* (nth 5 data-pack))
          (setq *tsp-timber-thickness* (nth 6 data-pack))
          (setq *tsp-max-excavation-depth* (nth 7 data-pack))
          (setq *tsp-embedment-depth* (nth 8 data-pack))
          (setq *tsp-soil-layers* (nth 9 data-pack))
          (setq *tsp-water-chk* (nth 10 data-pack))
          (setq *tsp-water-depth* (nth 11 data-pack))
          (setq *tsp-support-list* (tsp-sanitize-support-list (nth 12 data-pack)))
          (setq *tsp-scale-section* (nth 13 data-pack))
          (setq *tsp-scale-plan* (nth 14 data-pack))
          
          ;; 하위 버전 호환성 방어 로직 (15, 16 인덱스 존재 여부 파악)
          (if (> (length data-pack) 15)
            (progn
              (setq *tsp-deleted-post-points* (nth 15 data-pack))
              (setq *tsp-added-post-points* (nth 16 data-pack))
            )
            (progn
              (setq *tsp-deleted-post-points* '())
              (setq *tsp-added-post-points* '())
            )
          )

          ;; 2. 삽입점 지정 및 좌표 보정 방식 선택
          (initget "Origin New")
          (setq ins-opt (getkword "\n불러올 도면의 삽입 방식을 선택하세요 [원래위치(O)/새위치(N)] <N>: "))
          (if (not ins-opt) (setq ins-opt "New"))
          
          (if (= ins-opt "New")
            (progn
              (setq ins-pt (getpoint "\n1번 세그먼트의 시작점이 될 위치를 클릭하세요: "))
              (if ins-pt
                (progn
                  (setq ins-pt (trans ins-pt 1 0)) ;; WCS 변환
                  (setq base-pt (cdr (assoc 'V-START (nth 0 new-seg-list))))
                  (setq delta-x (- (car ins-pt) (car base-pt)))
                  (setq delta-y (- (cadr ins-pt) (cadr base-pt)))
                  
                  ;; 2-1. 세그먼트 양 끝단 좌표 및 수동 버팀보 Shift 일괄 적용
                  (setq shifted-seg-list nil)
                  (foreach seg new-seg-list
                    (setq old-start (cdr (assoc 'V-START seg)))
                    (setq old-end (cdr (assoc 'V-END seg)))
                    (setq new-start (list (+ (car old-start) delta-x) (+ (cadr old-start) delta-y) (if (caddr old-start) (caddr old-start) 0.0)))
                    (setq new-end (list (+ (car old-end) delta-x) (+ (cadr old-end) delta-y) (if (caddr old-end) (caddr old-end) 0.0)))
                    
                    (setq seg (subst (cons 'V-START new-start) (assoc 'V-START seg) seg))
                    (setq seg (subst (cons 'V-END new-end) (assoc 'V-END seg) seg))
                    
                    ;; 세그먼트 내 버팀보 좌표 보정
                    (setq old-support (tsp-sanitize-support-list (cdr (assoc 'SUPPORT-LIST seg))))
                    (if old-support
                      (progn
                        (setq new-support nil)
                        (foreach s-item old-support
                          (if (wcmatch (car s-item) "버팀보*")
                            (progn
                              (setq s-manual-pts (if (> (length s-item) 8) (nth 8 s-item) nil))
                              (if s-manual-pts
                                (progn
                                  (setq new-manual-pts (mapcar '(lambda (pt) (list (+ (car pt) delta-x) (+ (cadr pt) delta-y) (if (caddr pt) (caddr pt) 0.0))) s-manual-pts))
                                  (setq new-s-item '())
                                  (setq idx 0)
                                  (foreach val s-item
                                    (if (= idx 8)
                                      (setq new-s-item (append new-s-item (list new-manual-pts)))
                                      (setq new-s-item (append new-s-item (list val)))
                                    )
                                    (setq idx (1+ idx))
                                  )
                                  (setq s-item new-s-item)
                                )
                              )
                            )
                          )
                          (setq new-support (append new-support (list s-item)))
                        )
                        (setq seg (subst (cons 'SUPPORT-LIST new-support) (assoc 'SUPPORT-LIST seg) seg))
                      )
                    )
                    (setq shifted-seg-list (append shifted-seg-list (list seg)))
                  )
                  (setq new-seg-list shifted-seg-list)
                  
                  ;; 2-2. 글로벌 버팀보 좌표 Shift 적용
                  (if *tsp-support-list*
                    (progn
                      (setq new-global-support nil)
                      (foreach s-item *tsp-support-list*
                        (if (wcmatch (car s-item) "버팀보*")
                          (progn
                            (setq s-manual-pts (if (> (length s-item) 8) (nth 8 s-item) nil))
                            (if s-manual-pts
                              (progn
                                (setq new-manual-pts (mapcar '(lambda (pt) (list (+ (car pt) delta-x) (+ (cadr pt) delta-y) (if (caddr pt) (caddr pt) 0.0))) s-manual-pts))
                                (setq new-s-item '())
                                (setq idx 0)
                                (foreach val s-item
                                  (if (= idx 8)
                                    (setq new-s-item (append new-s-item (list new-manual-pts)))
                                    (setq new-s-item (append new-s-item (list val)))
                                  )
                                  (setq idx (1+ idx))
                                )
                                (setq s-item new-s-item)
                              )
                            )
                          )
                        )
                        (setq new-global-support (append new-global-support (list s-item)))
                      )
                      (setq *tsp-support-list* new-global-support)
                    )
                  )
                  
                  ;; 2-3. 삭제/추가된 말뚝 좌표 Shift 일괄 보정
                  (if *tsp-deleted-post-points*
                    (setq *tsp-deleted-post-points* (mapcar '(lambda (pt) (list (+ (car pt) delta-x) (+ (cadr pt) delta-y) 0.0)) *tsp-deleted-post-points*))
                  )
                  (if *tsp-added-post-points*
                    (setq *tsp-added-post-points* (mapcar '(lambda (rec) (cons (list (+ (car (car rec)) delta-x) (+ (cadr (car rec)) delta-y) 0.0) (cdr rec))) *tsp-added-post-points*))
                  )
                )
                (princ "\n[알림] 삽입점이 지정되지 않아 기존 절대좌표 원래 위치에 생성합니다.")
              )
            )
          )

          ;; 3. 전역 리스트 복원 및 딕셔너리 안전장치 저장
          (setq *segment-list* new-seg-list)
          (vlax-ldata-put "TSP_DICT" "DELETED_POSTS" *tsp-deleted-post-points*)
          (vlax-ldata-put "TSP_DICT" "ADDED_POSTS" *tsp-added-post-points*)
          
          ;; 4. 폴리라인 재작도 (백그라운드 복원)
          (setq new-boundary (tsp-rebuild-boundary))
          (setq new-orient (determine-boundary-orientation new-boundary))
          
          ;; 레이어 생성 및 색상 강제 지정
          (if (not (tblsearch "LAYER" "_경계선(Boundary)"))
            (entmake (list (cons 0 "LAYER") (cons 100 "AcDbSymbolTableRecord") (cons 100 "AcDbLayerTableRecord") (cons 2 "_경계선(Boundary)") (cons 70 0) (cons 62 4)))
          )
          (setq bnd-data (entget new-boundary))
          (setq bnd-data (subst (cons 8 "_경계선(Boundary)") (assoc 8 bnd-data) bnd-data))
          (if (assoc 62 bnd-data)
            (setq bnd-data (subst (cons 62 4) (assoc 62 bnd-data) bnd-data))
            (setq bnd-data (append bnd-data (list (cons 62 4))))
          )
          (entmod bnd-data)
          
          (vlax-ldata-put new-boundary "TSP_START_PT" (cdr (assoc 'V-START (nth 0 new-seg-list))))
          
          ;; RUN 상태 진입을 위한 플래그 처리
          (setq *tsp-imported-ent* new-boundary)
          (setq *tsp-imported-orient* new-orient)
          (setq *is-imported-data* T)
          
          (alert (strcat "프로젝트 [" proj-name "] 복원이 완료되었습니다.\n확인을 누르시면 즉시 [세그먼트 설정창]으로 진입합니다."))
        )
      )
    )
    (setq *is-imported-data* nil) ; 취소 시 안전하게 nil 반환
  )
  *is-imported-data* ; T를 반환하면 메인 메뉴에서 RUN 상태로 전환됨
)


;;;;==========================================================================
;;; Command: TSP
;;; Description: 가시설 평면/단면 통합 작도 메인 명령어 (Export/Import 기능 통합)
;;;;==========================================================================
(defun C:TSP (/ old-layer old-err dcl-path boundary-ent boundary-orient step status sel loop-program loop-draw seg-data section-draw-flag opt soil-src valid-sources idx s-data src-num src-idx perform-draw input-valid default-src save-chk loop-save saved-list user-start-pt vertices poly-orient start-idx dist-start dist-end saved-start-pt use-saved last-ent handle group-name dict group-exists has-brace-y ans g-brace i new-list missing-brace-list b-data curr-len prev-idx prev-data prev-len limits new-brace abort-draw rem-count res ans2 mseg midx check-data draw-seg draw-cor proceed-draw choice-res ans-cor brace-res selected-idx dcl-id user-choice)
  (setvar "cmdecho" 0)
  
  (setq old-layer (getvar "CLAYER"))
  
  (setq old-err *error*)
  (defun *error* (msg)
    (if old-layer (setvar "CLAYER" old-layer))
    (setvar "cmdecho" 1)
    (if (and msg (not (wcmatch (strcase msg) "*BREAK*,*CANCEL*,*QUIT*")))
      (princ (strcat "\n오류 발생: " msg))
      (princ "\n명령이 취소되었습니다.")
    )
    (setq *error* old-err)
    (princ)
  )

  (princ "\n========================================")
  (princ "\nTSP - Temporary Structure Plan")
  (princ "\n========================================\n")
  (setq *tsp-wall-type* "HPILE")
  (setq dcl-path (create-tsp-dcl))
  
  ;; 사용자의 선택에 따른 분기 (가상 상태 머신 적용)
  (setq *is-imported-data* nil)
  (setq next-step "MAIN_MENU") ; 시작 상태를 메인 메뉴로 설정
  
  (while next-step
    (cond
      ((= next-step "MAIN_MENU")
        ;; [메인 메뉴 호출 로직] - 상태 머신 내부로 이동하여 루프 가능하도록 수정
        (setq dcl-id (load_dialog dcl-path))
        (if (not (new_dialog "tsp_main_menu" dcl-id))
          (progn (alert "메인 메뉴 DCL 로드 실패") (exit))
        )
        (setq user-choice "CANCEL")
        (action_tile "btn_run" "(setq user-choice \"RUN\") (done_dialog 1)")
        (action_tile "btn_export" "(setq user-choice \"EXPORT\") (done_dialog 2)")
        (action_tile "btn_import" "(setq user-choice \"IMPORT\") (done_dialog 3)")
        (action_tile "btn_load_dwg" "(setq user-choice \"LOAD_DWG\") (done_dialog 4)")
        (action_tile "cancel" "(setq user-choice \"CANCEL\") (done_dialog 0)")
        (start_dialog)
        (unload_dialog dcl-id)
        (setq next-step user-choice)
      )
      ((= next-step "EXPORT")
       (tsp-export-to-csv)
       (setq next-step "MAIN_MENU") 
      )
      ((= next-step "IMPORT")
       (if (tsp-import-from-csv)
         (setq next-step "RUN") 
         (setq next-step "MAIN_MENU") 
       )
      )
      ((= next-step "LOAD_DWG")
       (if (tsp-import-from-drawing)
         (setq next-step "RUN") 
         (setq next-step "MAIN_MENU") 
       )
      )
      ((= next-step "RUN")
        (setq next-step nil)
        ;; ----- 기존 도면 작업 루프 원본 유지 -----
      (setq step 0)
      (setq loop-program T)
      (setq *tsp-data-dirty* nil)
      (setq *tsp-realtime-entities* '())
      
      (setq status (scale-dialog-callback dcl-path))
      
      (cond
        ((= status 0) ; 취소
          (setq loop-program nil)
        )
        ((= status 4) ; 이전(Back)
          (setq loop-program nil)
          (setq next-step "MAIN_MENU") ; 메인 메뉴로 돌아가도록 루프 상태 변경
        )
        (t ; 확인(1)
          (setq loop-program T)
        )
      )
      
      (setq *tsp-data-dirty* nil)
      (if loop-program
        (progn
          (if *is-imported-data*
            (progn
              (setq boundary-ent *tsp-imported-ent*)
              (princ "\n[시스템] 불러온 데이터를 기반으로 도면 작업을 이어서 진행합니다.")
            )
            (progn
              (setq boundary-ent nil)
              (while (not boundary-ent)
                (initget "Exit")
                (setq sel (entsel "\n'STEP 1' 전체 구간의 경계선(Polyline)을 선택하세요 [종료(Exit)]: "))
                (cond
                  ((= sel "Exit") (princ "\n명령을 종료합니다.") (setq boundary-ent "CANCEL"))
                  ((/= sel nil) (setq boundary-ent (car sel)))
                  ((= sel nil) (princ "\n선택되지 않았습니다. 다시 선택해주세요."))
                  ((= (getvar "ERRNO") 7) (princ "\n빈 공간입니다. 다시 선택하세요.") (setvar "ERRNO" 0))
                  (t (princ "\n선택 취소됨.") (setq boundary-ent "CANCEL"))
                )
              )
            )
          )
          (if (and boundary-ent (/= boundary-ent "CANCEL"))
            (progn
              (if *is-imported-data*
                (progn
                  (setq boundary-orient *tsp-imported-orient*)
                  (setq *tsp-boundary-ent* boundary-ent)
                  (setq *tsp-boundary-orient* boundary-orient)
                )
                (progn
                  (tsp-fix-mirrored-polyline boundary-ent)
                  (setq boundary-orient (determine-boundary-orientation boundary-ent))
                  (setq *tsp-boundary-ent* boundary-ent)
                  (setq *tsp-boundary-orient* boundary-orient)
                )
              )
              
              (if boundary-orient
                (progn
                  (setq vertices (extract-vertices boundary-ent))
                  (tsp-zoom-to-right-half vertices)
                  
                  (if (not *is-imported-data*)
                    (progn
                      (setq saved-start-pt (vlax-ldata-get boundary-ent "TSP_START_PT"))
                      (setq saved-start-idx (vlax-ldata-get boundary-ent "TSP_START_IDX"))
                      (setq user-start-pt nil)
                      (setq use-saved nil)
                      
                      ;; [추가] 복사된 객체 감지: 저장된 절대좌표가 현재 객체에서 멀리 떨어져 있다면 복사본으로 판별
                      (setq is-copied-ent nil)
                      (if saved-start-pt
                        (progn
                          (setq temp-idx (tsp-get-closest-vertex-index vertices saved-start-pt))
                          (if (> (distance (nth temp-idx vertices) saved-start-pt) 10.0)
                            (setq is-copied-ent T)
                          )
                        )
                      )
                      
                      (if saved-start-pt
                        (if (and is-copied-ent (not saved-start-idx))
                          (progn
                            ;; 인덱스 데이터가 없는 구버전 도면을 복사했을 경우의 안전장치
                            (princ "\n[시스템] 복사된 경계선이 감지되었습니다. 이전 절대좌표 방식으로는 시작점이 틀어지므로 새로 지정해야 합니다.")
                            (setq use-saved nil)
                          )
                          (progn
                            (initget "Yes No")
                            (if (= (getkword "\n 이전에 사용된 시작점이 있습니다. 그대로 사용하시겠습니까? [Yes(Y)/No(N)] <Y>: ") "No")
                              (setq use-saved nil)
                              (setq use-saved T)
                            )
                          )
                        )
                      )
                      
                      (if use-saved
                        (progn
                          (setq user-start-pt saved-start-pt)
                          (if (and is-copied-ent saved-start-idx)
                            (princ "\n[시스템] 복사된 객체입니다. 저장된 기하학적 인덱스(Index)를 사용하여 시작점 순서를 완벽히 유지합니다.")
                          )
                        )
                        (progn
                          (reset-globals-to-defaults)
                          (setq *segment-list* nil)
                          (setq *tsp-current-project-name* "")
                          (princ "\n[시스템] 새로운 시작점이 지정되어 기존 세그먼트 설정 및 프로젝트 이름이 초기화됩니다.")
                          (setq user-start-pt (getpoint "\n세그먼트 시작점(No.1)이 될 위치를 클릭하세요: "))
                          (if user-start-pt
                            (progn
                              (setq user-start-pt (trans user-start-pt 1 0))
                              (vlax-ldata-put boundary-ent "TSP_START_PT" user-start-pt)
                            )
                          )
                        )
                      )
                      
                      (if (is-closed-polyline boundary-ent)
                        (progn
                           (setq poly-orient (get-polygon-orientation vertices))
                           (if (= poly-orient 1)
                             (progn
                               (setq vertices (reverse vertices))
                               (setq boundary-orient (- boundary-orient))
                               (setq *tsp-boundary-orient* boundary-orient)
                             )
                           )
                           (if user-start-pt
                             (progn
                               ;; 복사본이면서 인덱스가 존재하면 절대좌표 연산을 무시하고 인덱스를 강제 적용
                               (if (and use-saved is-copied-ent saved-start-idx)
                                 (setq start-idx saved-start-idx)
                                 (setq start-idx (tsp-get-closest-vertex-index vertices user-start-pt))
                               )
                               (setq vertices (tsp-shift-vertex-list vertices start-idx))
                               ;; 다음 복사를 완벽히 대비해 인덱스 번호를 무조건 갱신 및 저장
                               (vlax-ldata-put boundary-ent "TSP_START_IDX" start-idx)
                             )
                           )
                        )
                        (progn
                           (if user-start-pt
                             (progn
                               (setq dist-start (distance (car vertices) user-start-pt))
                               (setq dist-end (distance (last vertices) user-start-pt))
                               (if (< dist-end dist-start)
                                 (progn
                                   (setq vertices (reverse vertices))
                                   (setq boundary-orient (- boundary-orient))
                                   (setq *tsp-boundary-orient* boundary-orient)
                                 )
                               )
                             )
                           )
                        )
                      )
                      (init-segment-data boundary-ent boundary-orient vertices)
                    )
                  )
                  (setq handle (tsp-get-entity-handle boundary-ent))
                  (setq group-name (strcat "TSP_GRP_" handle))
                  (setq dict (dictsearch (namedobjdict) "ACAD_GROUP"))
                  (setq group-exists (if (and dict (dictsearch (cdr (assoc -1 dict)) group-name)) T nil))
                  (if (not group-exists)
                    (progn
                      (setq last-ent (entlast))
                      (draw-segment-numbers boundary-ent boundary-orient vertices)
                      (tsp-group-last-entities last-ent boundary-ent)
                    )
                    (princ "\n[알림] 기존 평면도를 유지한 상태로 설정창에 진입합니다.")
                  )
                  (tsp-redraw-realtime-plan boundary-ent boundary-orient)
                  (setq loop-draw T)
                  (while loop-draw
                    (setq status (manager-dialog-callback dcl-path))
                    (cond
                      ((= status 0)
                        (setq loop-draw nil)
                        (if *tsp-data-dirty*
                          (progn
                            (initget "Yes No")
                            (setq save-chk (getkword (strcat "\n변경된 내용을 저장하시겠습니까? (프로젝트: " *tsp-current-project-name* ") [Yes(Y)/No(N)] <Y>: ")))
                            (if (null save-chk) (setq save-chk "Yes"))
                            (if (= save-chk "Yes")
                              (tsp-save-project-data *tsp-current-project-name*)
                              (princ "\n[알림] 저장하지 않고 종료합니다.")
                            )
                          )
                          (princ "\n[알림] 변경된 내용이 없어 종료합니다.")
                        )
                        (princ "\nTSP 명령을 종료합니다.")
                      )
                      ((= status 5)
                       (setq check-data (nth selected-idx *segment-list*))
                       (setq b-data (cdr (assoc 'CORNER-BRACE check-data)))
                       (setq draw-seg T draw-cor nil)
                       (setq proceed-draw T)
                       (if (and b-data (= (car b-data) "Y"))
                         (progn
                           (setq choice-res (section-choice-dialog-callback dcl-path))
                           (if choice-res
                             (progn
                               (setq draw-seg (car choice-res) draw-cor (cadr choice-res))
                               (if draw-cor
                                 (progn
                                   (if (null (cadr b-data))
                                     (progn
                                       (initget "Input Skip Return")
                                       (setq ans-cor (getkword "\n선택한 모서리에 사보강재(Corner Strut) 정보가 없습니다. 작업선택 [입력(Input)/생략(Skip)/되돌리기(Return)] <Input>: "))
                                       (if (null ans-cor) (setq ans-cor "Input"))
                                       (cond
                                         ((= ans-cor "Input")
                                          (setq limits (tsp-calculate-brace-limit selected-idx))
                                          (setq brace-res (brace-dialog-callback dcl-path check-data limits 0))
                                          (if (and (listp brace-res) (or (= (car brace-res) "COMP") (= (car brace-res) "NEXT")))
                                            (progn
                                              (setq new-brace (cadr brace-res))
                                              (setq check-data (subst (cons 'CORNER-BRACE new-brace) (assoc 'CORNER-BRACE check-data) check-data))
                                              (setq check-data (subst (cons 'UPGRADE-WALE (caddr brace-res)) (assoc 'UPGRADE-WALE check-data) check-data))
                                              (setq *segment-list* (update-list-item *segment-list* selected-idx check-data))
                                              (setq b-data new-brace)
                                              (if (and new-brace (cadr new-brace) (> (length (cadr new-brace)) 0))
                                                (alert "모서리 단면도 작도는 아직 작업중입니다.")
                                                (princ "\n사보강재(Corner Strut) 정보가 입력되지 않았습니다.")
                                              )
                                            )
                                            (princ "\n입력이 취소되었습니다.")
                                          )
                                         )
                                         ((= ans-cor "Skip")
                                          (princ "\n모서리 단면도 생성을 생략합니다.")
                                         )
                                         ((= ans-cor "Return")
                                          (setq proceed-draw nil draw-seg nil)
                                         )
                                       )
                                     )
                                     (alert "모서리 단면도 작도는 아직 작업중입니다.")
                                   )
                                 )
                               )
                             )
                             (setq proceed-draw nil draw-seg nil)
                           )
                         )
                       )
                       (if (and proceed-draw draw-seg)
                         (progn
                           (setq perform-draw T)
                           (if (or (not *tsp-target-draw-flag*) (null *tsp-soil-layers*) (= *tsp-soil-layers* '()))
                             (progn
                               (initget "Input Copy Skip Return")
                               (setq opt (getkword "\n선택한 세그먼트에 지반 정보가 없거나 '단면생성 N'입니다. 작업 선택 [입력(Input)/복사(Copy)/생략(Skip)/되돌리기(Return)] <Skip>: "))
                               (cond
                                 ((= opt "Input") (if (= (soil-dialog-callback dcl-path) 1) (princ "\n지반 정보 입력 완료.") (progn (princ "\n입력이 취소되었습니다.") (setq perform-draw nil))))
                                 ((= opt "Copy")
                                  (setq valid-sources '() idx 0)
                                  (foreach seg *segment-list* (setq s-data (cdr (assoc 'SOIL-DATA seg))) (if (and s-data (/= s-data '())) (setq valid-sources (append valid-sources (list (1+ idx))))) (setq idx (1+ idx)))
                                  (if valid-sources
                                    (progn
                                      (princ (strcat "\n복사 가능한 세그먼트 번호: " (vl-princ-to-string valid-sources)))
                                      (setq input-valid nil default-src (car valid-sources))
                                      (while (not input-valid)
                                        (setq src-num (getint (strcat "\n지반 정보를 가져올 세그먼트 번호를 입력하세요 [기본값: " (itoa default-src) "]: ")))
                                        (if (null src-num) (setq src-num default-src))
                                        (if (vl-position src-num valid-sources)
                                          (progn (setq input-valid T src-idx (1- src-num)) (setq *tsp-soil-layers* (cdr (assoc 'SOIL-DATA (nth src-idx *segment-list*)))) (princ (strcat "\n" (itoa src-num) "번 세그먼트의 지반 정보를 적용했습니다.")))
                                          (princ "\n잘못된 번호입니다.")
                                        )
                                      )
                                    )
                                    (progn (alert "지반 정보가 입력된 세그먼트가 하나도 없습니다.") (setq perform-draw nil))
                                  )
                                 )
                                 ((= opt "Return") (setq perform-draw nil))
                                 (t (princ "\n지반 정보 없이 구조물 단면만 그립니다."))
                               )
                             )
                           )
                           (if perform-draw
                             (progn
                               (if (draw-section-ground-line dcl-path selected-idx)
                                 (princ "\n단면도 작도 완료.")
                                 (progn
                                   (princ "\n단면도 작도 취소됨.")
                                   (setq proceed-draw nil)
                                 )
                               )
                             )
                           )
                         )
                       )
                       (if proceed-draw
                         (progn
                           (initget "Yes No")
                           (setq choice-res (vl-catch-all-apply 'getkword (list "\n설정창으로 돌아가시겠습니까? [Yes(Y)/No(N)] <Y>: ")))
                           (if (vl-catch-all-error-p choice-res)
                             (setq loop-draw nil)
                             (if (= choice-res "No") (setq loop-draw nil))
                           )
                         )
                       )
                      )
                      ((= status 6)
                       (setq abort-draw nil)
                       (setq missing-brace-list '())
                       (setq i 0)
                       (while (< i (length *segment-list*))
                         (setq seg-data (nth i *segment-list*))
                         (setq b-data (cdr (assoc 'CORNER-BRACE seg-data)))
                         (if (and b-data (= (car b-data) "Y") (null (cadr b-data)))
                           (setq missing-brace-list (append missing-brace-list (list i)))
                         )
                         (setq i (1+ i))
                       )
                       (if (> (length missing-brace-list) 0)
                         (progn
                           (initget "Yes No")
                           (setq ans (getkword (strcat "\n사보강재(Corner Strut) 설정이 누락된 모서리가 " (itoa (length missing-brace-list)) "곳 있습니다. 추가하시겠습니까? [Yes(Y)/No(N)] <Y>: ")))
                           (if (or (null ans) (= ans "Yes"))
                             (progn
                               (while (and (> (length missing-brace-list) 0) (not abort-draw))
                                 (setq idx (car missing-brace-list))
                                 (setq missing-brace-list (cdr missing-brace-list))
                                 (setq seg-data (nth idx *segment-list*))
                                 (setq limits (tsp-calculate-brace-limit idx))
                                 (setq rem-count (1+ (length missing-brace-list)))
                                 (setq res (brace-dialog-callback dcl-path seg-data limits rem-count))
                                 (cond
                                   ((and (listp res) (= (car res) "NEXT"))
                                    (setq new-brace (cadr res))
                                    (if (and new-brace (cadr new-brace) (> (length (cadr new-brace)) 0))
                                      (progn
                                        (setq seg-data (subst (cons 'CORNER-BRACE new-brace) (assoc 'CORNER-BRACE seg-data) seg-data))
                                        (setq seg-data (subst (cons 'UPGRADE-WALE (caddr res)) (assoc 'UPGRADE-WALE seg-data) seg-data))
                                        (setq *segment-list* (update-list-item *segment-list* idx seg-data))
                                      )
                                      (progn
                                        (princ (strcat "\n[" (itoa (cdr (assoc 'ID seg-data))) "번 모서리] 데이터가 비어있어 순서를 맨 뒤로 미룹니다."))
                                        (setq missing-brace-list (append missing-brace-list (list idx)))
                                      )
                                    )
                                   )
                                   ((and (listp res) (= (car res) "COMP"))
                                    (setq new-brace (cadr res))
                                    (if (and new-brace (cadr new-brace) (> (length (cadr new-brace)) 0))
                                      (progn
                                        (setq seg-data (subst (cons 'CORNER-BRACE new-brace) (assoc 'CORNER-BRACE seg-data) seg-data))
                                        (setq seg-data (subst (cons 'UPGRADE-WALE (caddr res)) (assoc 'UPGRADE-WALE seg-data) seg-data))
                                        (setq *segment-list* (update-list-item *segment-list* idx seg-data))
                                      )
                                      (progn
                                        (princ (strcat "\n[" (itoa (cdr (assoc 'ID seg-data))) "번 모서리] 데이터가 비어있습니다. 해당 사보강재(Corner Strut) 설정을 건너뜁니다."))
                                        (setq seg-data (subst (cons 'CORNER-BRACE (list "N" nil)) (assoc 'CORNER-BRACE seg-data) seg-data))
                                        (setq *segment-list* (update-list-item *segment-list* idx seg-data))
                                      )
                                    )
                                    (if (> (length missing-brace-list) 0)
                                      (progn
                                        (initget "Yes No")
                                        (setq ans2 (getkword (strcat "\n아직 사보강재(Corner Strut)가 입력되지 않은 세그먼트가 " (itoa (length missing-brace-list)) "곳 남았습니다. 이대로 설정을 완전히 종료하시겠습니까? (Yes:완료 / No:마저입력) [Yes/No] <No>: ")))
                                        (if (= ans2 "Yes")
                                          (progn
                                            (foreach midx missing-brace-list
                                              (setq mseg (nth midx *segment-list*))
                                              (setq mseg (subst (cons 'CORNER-BRACE (list "N" nil)) (assoc 'CORNER-BRACE mseg) mseg))
                                              (setq *segment-list* (update-list-item *segment-list* midx mseg))
                                            )
                                            (setq missing-brace-list '())
                                          )
                                        )
                                      )
                                    )
                                   )
                                   (t
                                     (princ "\n입력이 취소되었습니다. 평면도 생성을 중단합니다.")
                                     (setq abort-draw T)
                                   )
                                 )
                               )
                             )
                             (progn
                               (princ "\n사보강재(Corner Strut) 추가를 건너뜁니다. 해당 모서리는 사보강재(Corner Strut) 없이 작도됩니다.")
                               (foreach idx missing-brace-list
                                 (setq seg-data (nth idx *segment-list*))
                                 (setq seg-data (subst (cons 'CORNER-BRACE (list "N" nil)) (assoc 'CORNER-BRACE seg-data) seg-data))
                                 (setq *segment-list* (update-list-item *segment-list* idx seg-data))
                               )
                             )
                           )
                         )
                       )
                       (if (not abort-draw)
                         (progn
                           (princ "\n모든 데이터가 확인되었습니다. 최종 평면도를 갱신합니다.")
                           (if (and *tsp-boundary-ent* *tsp-boundary-orient*)
                             (tsp-redraw-realtime-plan *tsp-boundary-ent* *tsp-boundary-orient*)
                           )
                         )
                       )
                       (if (not abort-draw)
                         (if *tsp-cancel-flag*
                           (setq *tsp-cancel-flag* nil)
                           (progn
                             (initget "Yes No")
                             (setq user-ans (vl-catch-all-apply 'getkword (list "\n설정창으로 다시 돌아가시겠습니까? [Yes(Y)/No(N)] <Y>: ")))
                             (if (vl-catch-all-error-p user-ans)
                               (setq loop-draw nil)
                               (if (= user-ans "No") (setq loop-draw nil))
                             )
                           )
                         )
                       )
                      )
                    ) ;; end cond
                  ) ;; end while loop-draw
                ) ;; end progn (if boundary-orient)
              ) ;; end if boundary-orient
            ) ;; end progn (if boundary-ent)
          ) ;; end if boundary-ent
        ) ;; end progn (if loop-program)
      ) ;; end if loop-program
      ;; ----- 도면 작업 루프 원본 끝 -----
    )
    ((= next-step "CANCEL")
       (princ "\nTSP 명령어가 취소되었습니다.")
       (setq next-step nil)
      )
    )
  )
  
  (if old-layer (setvar "CLAYER" old-layer))
  (setq *error* old-err)
  
  (setvar "cmdecho" 1)
  (princ)
)


;;;;==========================================================================
;;;; defun tsp-extract-number-only : 텍스트에서 숫자와 소수점('.')만 추출
;;;;==========================================================================
(defun tsp-extract-number-only (str / i char res)
  (setq res "")
  (setq i 1)
  (while (<= i (strlen str))
    (setq char (substr str i 1))
    (if (or (and (>= (ascii char) 48) (<= (ascii char) 57))
            (= (ascii char) 46))
      (setq res (strcat res char))
    )
    (setq i (1+ i))
  )
  (if (= res "") "0.0" res)
)

;;;;==========================================================================
;;;; defun tsp-get-nvalue-from-drawing : 도면에서 텍스트를 드래그하여 N치 추출
;;;;==========================================================================
(defun tsp-get-nvalue-from-drawing (/ ss i ent ent-data txt-str pt-x pt-y txt-h txt-list row-list current-row prev-y new-n-values depth-str depth-val n-text)
  (princ "\n[N치 자동입력] 깊이와 N치 텍스트들을 드래그하여 선택하세요: ")
  (setq ss (ssget '((0 . "TEXT"))))
  (if (not ss)
    (progn (princ "\n선택된 텍스트가 없습니다.") nil)
    (progn
      (if (= (rem (sslength ss) 2) 1)
        (progn
          (alert "선택된 텍스트의 총 개수가 홀수입니다.\n깊이와 N치가 짝수 개로 맞는지 확인하고 다시 선택해주세요.")
          nil
        )
        (progn
          (setq txt-list '() i 0)
          (while (< i (sslength ss))
            (setq ent (ssname ss i))
            (setq ent-data (entget ent))
            (setq txt-str (cdr (assoc 1 ent-data)))
            (setq txt-h (cdr (assoc 40 ent-data)))
            (setq pt-x (car (cdr (assoc 10 ent-data))))
            (setq pt-y (cadr (cdr (assoc 10 ent-data))))
            (setq txt-list (append txt-list (list (list pt-y pt-x txt-str txt-h))))
            (setq i (1+ i))
          )
          (setq txt-list (vl-sort txt-list (function (lambda (a b) (> (car a) (car b))))))
          (setq row-list '() current-row '() prev-y (car (nth 0 txt-list)))
          (foreach item txt-list
            (setq pt-y (nth 0 item) txt-h (nth 3 item))
            (if (<= (abs (- prev-y pt-y)) (* txt-h 0.5))
              (setq current-row (append current-row (list item)))
              (progn
                (setq row-list (append row-list (list current-row)))
                (setq current-row (list item) prev-y pt-y)
              )
            )
          )
          (if current-row (setq row-list (append row-list (list current-row))))
          (setq new-n-values '())
          (foreach row row-list
            (if (= (length row) 2)
              (progn
                (setq row (vl-sort row (function (lambda (a b) (< (cadr a) (cadr b))))))
                (setq depth-str (tsp-extract-number-only (nth 2 (nth 0 row))))
                (setq depth-val (atof depth-str))
                (setq n-text (nth 2 (nth 1 row)))
                (setq new-n-values (append new-n-values (list (list depth-val n-text))))
              )
            )
          )
          (if (> (length new-n-values) 0)
            (progn
              (alert (strcat "총 " (itoa (length new-n-values)) "쌍의 N치 데이터가 성공적으로 추가되었습니다."))
              new-n-values
            )
            (progn
              (alert "유효한 N치 데이터를 찾을 수 없습니다.\n행의 짝(깊이, N치)이 맞게 선택되었는지 확인해주세요.")
              nil
            )
          )
        )
      )
    )
  )
)

